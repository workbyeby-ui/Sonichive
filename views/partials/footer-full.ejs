<style>
  /* ── FOOTER (self-contained) ── */
  footer {
    background: #0A0A0A;
    border-top: 1px solid rgba(255,255,255,.06);
    padding: 5rem 0 0;
    position: relative;
    overflow: hidden;
  }

  footer::before {
    content: '';
    position: absolute;
    top: -80px;
    left: -60px;
    width: 380px;
    height: 380px;
    background: radial-gradient(circle, rgba(212,32,32,.08) 0%, transparent 65%);
    pointer-events: none;
  }

  /* Tagline strip */
  .foot-top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid rgba(255,255,255,.06);
    margin-bottom: 3.5rem;
  }

  .foot-top-tag {
    font-family: var(--fh, 'Poppins', sans-serif);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 400;
    letter-spacing: -.04em;
    color: rgba(255,255,255,.88);
    line-height: 1.1;
    max-width: 560px;
  }

  .foot-top-tag em {
    color: #D42020;
    font-style: normal;
  }

  .foot-top-cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    background: rgba(212,32,32,.08);
    border: 1px solid rgba(212,32,32,.22);
    color: #D42020;
    border-radius: 100px;
    padding: .6rem 1.5rem;
    font-size: .85rem;
    font-weight: 500;
    font-family: var(--fh, 'Poppins', sans-serif);
    text-decoration: none;
    transition: transform 160ms cubic-bezier(0.23,1,0.32,1),
                background 160ms ease-out,
                box-shadow 160ms ease-out,
                border-color 160ms ease-out;
    white-space: nowrap;
  }

  @media (hover: hover) and (pointer: fine) {
    .foot-top-cta:hover {
      background: rgba(212,32,32,.14);
      border-color: rgba(212,32,32,.35);
      box-shadow: 0 0 24px rgba(212,32,32,.14);
    }
  }

  .foot-top-cta:active {
    transform: scale(0.97);
  }

  /* Main grid */
  .foot-g {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.3fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  .foot-brand p {
    color: rgba(255,255,255,.35);
    font-size: .875rem;
    line-height: 1.75;
    margin-top: 1.25rem;
    max-width: 260px;
  }

  /* Social links */
  .foot-soc {
    display: flex;
    gap: .45rem;
    margin-top: 1.75rem;
    flex-wrap: wrap;
  }

  .soc-a {
    width: 35px;
    height: 35px;
    border-radius: 9px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.07);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,.3);
    transition: transform 150ms cubic-bezier(0.23,1,0.32,1),
                background 150ms ease-out,
                border-color 150ms ease-out,
                color 150ms ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    .soc-a:hover {
      background: rgba(212,32,32,.1);
      border-color: rgba(212,32,32,.25);
      color: #D42020;
    }
  }

  .soc-a:active {
    transform: scale(0.88);
  }

  /* Nav columns */
  .foot-col h4 {
    font-family: var(--fh, 'Poppins', sans-serif);
    font-size: .7rem;
    font-weight: 500;
    letter-spacing: .12em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    color: rgba(255,255,255,.42);
  }

  .foot-col a {
    display: block;
    color: rgba(255,255,255,.3);
    font-size: .875rem;
    margin-bottom: .65rem;
    transition: color 150ms ease-out,
                transform 180ms cubic-bezier(0.23,1,0.32,1);
    transform-origin: left;
  }

  @media (hover: hover) and (pointer: fine) {
    .foot-col a:hover {
      color: rgba(255,255,255,.88);
      transform: translateX(5px);
    }
  }

  /* Contact column */
  .foot-contact p {
    color: rgba(255,255,255,.35);
    font-size: .875rem;
    margin-bottom: .65rem;
    display: flex;
    align-items: flex-start;
    gap: .5rem;
    line-height: 1.55;
  }

  .foot-contact a {
    color: #D42020;
    display: inline;
    margin-bottom: 0;
    transform: none !important;
    transition: color 150ms ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    .foot-contact a:hover {
      color: #FF5252;
    }
  }

  /* Bottom bar */
  .foot-bot {
    border-top: 1px solid rgba(255,255,255,.06);
    padding: 1.75rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .foot-bot p {
    color: rgba(255,255,255,.22);
    font-size: .78rem;
  }

  .foot-locs {
    display: flex;
    gap: .35rem;
    flex-wrap: wrap;
  }

  .foot-locs span {
    font-size: .69rem;
    color: rgba(255,255,255,.28);
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 100px;
    padding: .18rem .6rem;
    cursor: default;
    letter-spacing: .04em;
    transition: background 150ms ease-out,
                color 150ms ease-out,
                border-color 150ms ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    .foot-locs span:hover {
      background: rgba(255,255,255,.07);
      color: rgba(255,255,255,.55);
      border-color: rgba(255,255,255,.12);
    }
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .foot-g { grid-template-columns: 1fr 1fr; }
    .foot-top { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
  }

  @media (max-width: 640px) {
    footer { padding-top: 3.5rem; }
    .foot-g { grid-template-columns: 1fr; gap: 2rem; }
    .foot-top { padding-bottom: 2.5rem; margin-bottom: 2.5rem; }
    .foot-top-tag { font-size: clamp(1.75rem, 7vw, 2.5rem); }
  }
</style>

