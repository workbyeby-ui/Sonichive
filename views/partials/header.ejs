<script>
(function(){
  var ham=document.getElementById('nav-ham');
  var links=document.getElementById('nav-links');
  var dd=document.querySelector('.nav-dd');
  if(!ham||!links)return;
  function openNav(){
    links.classList.add('open');
    ham.setAttribute('aria-expanded','true');
    ham.setAttribute('aria-label','Close navigation menu');
    document.body.style.overflow='hidden';
    ham.style.color='#0A0A0F';
    ham.style.borderColor='rgba(0,0,0,.18)';
    ham.querySelector('svg').innerHTML='<path d="M4 4l12 12M16 4L4 16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>';
  }
  function closeNav(){
    links.classList.remove('open');
    if(dd)dd.classList.remove('open');
    ham.setAttribute('aria-expanded','false');
    ham.setAttribute('aria-label','Open navigation menu');
    document.body.style.overflow='';
    ham.style.color='';
    ham.style.borderColor='';
    ham.querySelector('svg').innerHTML='<path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>';
  }
  ham.addEventListener('click',function(){
    links.classList.contains('open')?closeNav():openNav();
  });
  document.addEventListener('keydown',function(e){
    if(e.key==='Escape'&&links.classList.contains('open')){closeNav();ham.focus();}
  });
  // Close on nav link click (single-page-like navigation)
  links.querySelectorAll('a').forEach(function(a){
    a.addEventListener('click',function(){if(window.innerWidth<=768)closeNav();});
  });
})();
</script>
