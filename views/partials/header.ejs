.skip-link:focus{top:0}
#nav a:focus-visible,.nd-toggle:focus-visible,.nav-cta:focus-visible,.nav-ham:focus-visible{outline:2px solid #D42020;outline-offset:3px;border-radius:4px}
@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important;animation-iteration-count:1!important}}

/* ── HAMBURGER BUTTON ── */
.nav-ham{display:none;background:none;border:1px solid rgba(255,255,255,.22);border-radius:8px;padding:7px 9px;cursor:pointer;color:#fff;transition:color .3s,border-color .3s;flex-shrink:0;line-height:0}
#nav.s .nav-ham{color:#0A0A0F;border-color:rgba(0,0,0,.14)}
.nav-ham svg{display:block;transition:transform .2s}

/* ── MOBILE NAV OVERLAY ── */
@media(max-width:768px){
  .nav-ham{display:inline-flex;align-items:center;justify-content:center}
  .nav-cta{display:none}
  .nav-links{display:none;position:fixed;inset:0;padding:68px 1.5rem 2rem;background:rgba(250,250,250,.97);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);flex-direction:column;z-index:997;overflow-y:auto}
  .nav-links.open{display:flex}
  .nav-links>a{font-size:1rem;color:#0A0A0F!important;padding:.85rem 0;border-bottom:1px solid rgba(0,0,0,.07);font-weight:400;display:block}
  .nav-links>a::after{display:none!important}
  .nav-dd{width:100%}
  .nd-toggle{font-size:1rem;color:#0A0A0F!important;padding:.85rem 0;border-bottom:1px solid rgba(0,0,0,.07);width:100%;justify-content:space-between}
  .mega-wrap{position:static;transform:none!important;width:100%;border-radius:12px;box-shadow:none;opacity:0;max-height:0;overflow:hidden;pointer-events:none;border:1px solid rgba(0,0,0,.08);margin:.5rem 0;transition:opacity .2s,max-height .35s ease}
  .nav-dd.open .mega-wrap{opacity:1;max-height:800px;pointer-events:auto}
  .mega-grid{grid-template-columns:1fr 1fr}
  .mc-img-w{height:80px}.mc-img-w img{height:70px}
  .mc{padding:.8rem .7rem}
  .mega-wrap::before{display:none}
}
</style>
