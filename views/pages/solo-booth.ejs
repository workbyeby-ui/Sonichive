<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Solo Silence Booth — SonicHive | 1-Person Acoustic Pod Dubai</title>
  <meta name="description"
    content="The SonicHive Solo Silence Booth delivers 30dB of noise reduction for private calls, deep focus, and confidential work. Dubai's best-selling office pod.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
    rel="stylesheet">
  <style>
    :root {
      --bg: #FAFAFA;
      --bg2: #F2F3F5;
      --bg3: #E8EAED;
      --red: #D42020;
      --red-d: rgba(212, 32, 32, .07);
      --red-b: rgba(212, 32, 32, .22);
      --text: #0A0A0F;
      --muted: #6B7280;
      --border: rgba(0, 0, 0, .09);
      --card: rgba(0, 0, 0, .03);
      --fh: 'Space Grotesk', sans-serif;
      --fb: 'DM Sans', sans-serif;
      --max: 1280px
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    html {
      scroll-behavior: smooth
    }

    body{
      background: var(--bg);
      color: var(--text);
      font-family: var(--fb);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden
    }

    a {
      color: inherit;
      text-decoration: none
    }

    img {
      max-width: 100%;
      display: block
    }

    .wrap {
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 2rem
    }

    .r {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity .7s ease, transform .7s ease
    }

    .r.on {
      opacity: 1;
      transform: none
    }

    .d1 {
      transition-delay: .1s
    }

    .d2 {
      transition-delay: .2s
    }

    .d3 {
      transition-delay: .3s
    }

    .d4 {
      transition-delay: .4s
    }

    .s-label {
      font-size: .72rem;
      font-weight:400;
      letter-spacing: .15em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: .9rem
    }

    .s-title {
      font-family: var(--fh);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight:400;
      line-height: 1.05;
      letter-spacing: -.025em;
      margin-bottom: 1rem
    }

    /* NAV */
    #nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      background: rgba(10, 10, 15, .92);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255, 255, 255, .08)
    }

    .nav-i {
      max-width: var(--max);
      margin: 0 auto;
      padding: 1.2rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem
    }

    .logo-t {
      font-family: var(--fh);
      font-size: 1.3rem;
      font-weight:400;
      letter-spacing: -.02em;
      color: #FFF
    }

    .logo-t em {
      color: var(--red);
      font-style: normal
    }

    .nav-links {
      display: flex;
      gap: 1.75rem;
      align-items: center
    }

    .nav-links a {
      font-size: .875rem;
      color: rgba(255, 255, 255, .5);
      font-weight: 500;
      transition: color .2s
    }

    .nav-links a:hover,
    .nav-links a.cur {
      color: #FFF
    }

    .nav-cta {
      background: var(--red);
      color: #FFF;
      border: none;
      border-radius: 100px;
      padding: .6rem 1.4rem;
      font-size: .875rem;
      font-weight:400;
      cursor: pointer;
      transition: transform .2s, box-shadow .2s;
      font-family: var(--fb);
      white-space: nowrap;
      display: inline-block
    }

    .nav-cta:hover {
      transform: scale(1.04);
      box-shadow: 0 0 24px rgba(212, 32, 32, .4)
    }

    /* PRODUCT HERO */
    #prod-hero {
      background: #0A0A0A;
      min-height: 92vh;
      display: flex;
      align-items: center;
      position: relative;
      overflow: hidden;
      padding: 8rem 2rem 5rem
    }

    #prod-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 65% 50%, rgba(212, 32, 32, .12), transparent 60%)
    }

    .ph-grid {
      max-width: var(--max);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: center;
      position: relative;
      width: 100%
    }

    .ph-img-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative
    }

    .ph-img-glow {
      position: absolute;
      inset: -10%;
      background: radial-gradient(circle, rgba(212, 32, 32, .15), transparent 65%);
      pointer-events: none
    }

    .ph-img {
      width: 75%;
      max-width: 360px;
      filter: drop-shadow(0 40px 80px rgba(212, 32, 32, .25));
      transition: transform .5s
    }

    .ph-img:hover {
      transform: scale(1.03) translateY(-8px)
    }

    .ph-info .breadcrumb {
      font-size: .75rem;
      color: rgba(255, 255, 255, .35);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: .5rem
    }

    .ph-info .breadcrumb a {
      color: rgba(255, 255, 255, .35);
      transition: color .2s
    }

    .ph-info .breadcrumb a:hover {
      color: var(--red)
    }

    .ph-tag {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      background: var(--red-d);
      border: 1px solid var(--red-b);
      border-radius: 100px;
      padding: .35rem 1rem;
      font-size: .72rem;
      font-weight:400;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 1.5rem
    }

    .ph-name {
      font-family: var(--fh);
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      font-weight:400;
      letter-spacing: -.04em;
      color: #FFF;
      line-height: .95;
      margin-bottom: .75rem
    }

    .ph-cap {
      color: var(--red);
      font-size: 1.1rem;
      font-weight:400;
      margin-bottom: 1.25rem
    }

    .ph-desc {
      color: rgba(255, 255, 255, .55);
      font-size: 1rem;
      line-height: 1.8;
      max-width: 480px;
      margin-bottom: 2.5rem
    }

    .ph-specs-row {
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
      margin-bottom: 2.5rem
    }

    .ph-spec {
      text-align: center
    }

    .ph-spec strong {
      font-family: var(--fh);
      font-size: 1.6rem;
      font-weight:400;
      color: #FFF;
      display: block;
      line-height: 1
    }

    .ph-spec span {
      font-size: .72rem;
      color: rgba(255, 255, 255, .4);
      letter-spacing: .1em;
      text-transform: uppercase;
      margin-top: .2rem;
      display: block
    }

    .ph-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap
    }

    .btn-red {
      background: var(--red);
      color: #FFF;
      border: none;
      border-radius: 100px;
      padding: .9rem 2.5rem;
      font-size: .975rem;
      font-weight:400;
      cursor: pointer;
      transition: transform .2s, box-shadow .2s;
      font-family: var(--fb);
      display: inline-block
    }

    .btn-red:hover {
      transform: scale(1.04);
      box-shadow: 0 0 32px rgba(212, 32, 32, .45)
    }

    .btn-wh {
      background: rgba(255, 255, 255, .07);
      border: 1px solid rgba(255, 255, 255, .15);
      color: #FFF;
      border-radius: 100px;
      padding: .9rem 2.5rem;
      font-size: .975rem;
      font-weight: 500;
      transition: all .2s;
      font-family: var(--fb);
      display: inline-block
    }

    .btn-wh:hover {
      background: rgba(255, 255, 255, .14)
    }

    .btn-o {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text);
      border-radius: 100px;
      padding: .875rem 2.25rem;
      font-size: .95rem;
      font-weight: 500;
      cursor: pointer;
      transition: all .2s;
      font-family: var(--fb);
      display: inline-block
    }

    .btn-o:hover {
      border-color: var(--red-b);
      color: var(--red)
    }

    /* BADGES STRIP */
    #badges {
      background: #111;
      border-top: 1px solid rgba(255, 255, 255, .06);
      border-bottom: 1px solid rgba(255, 255, 255, .06);
      padding: 2rem 0
    }

    .badges-row {
      display: flex;
      gap: 3rem;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap
    }

    .badge-item {
      display: flex;
      align-items: center;
      gap: .75rem;
      color: rgba(255, 255, 255, .5);
      font-size: .875rem
    }

    .badge-item strong {
      color: #FFF;
      font-weight:400
    }

    .badge-ic {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: var(--red-d);
      border: 1px solid var(--red-b);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0
    }

    /* FEATURES */
    #features {
      padding: 7rem 0
    }

    .feat-head {
      text-align: center;
      margin-bottom: 4rem
    }

    .feat-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem
    }

    .feat-card {
      background: #FFF;
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2rem;
      transition: transform .3s, box-shadow .3s, border-color .3s
    }

    .feat-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 16px 40px rgba(0, 0, 0, .08);
      border-color: var(--red-b)
    }

    .feat-ic {
      width: 48px;
      height: 48px;
      border-radius: 13px;
      background: var(--red-d);
      border: 1px solid var(--red-b);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      margin-bottom: 1.25rem
    }

    .feat-name {
      font-family: var(--fh);
      font-size: 1rem;
      font-weight:400;
      margin-bottom: .5rem
    }

    .feat-desc {
      font-size: .9rem;
      color: var(--muted);
      line-height: 1.75
    }

    /* PERFECT FOR */
    #perfect-for {
      padding: 7rem 0;
      background: var(--bg2)
    }

    .pf-lay {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center
    }

    .pf-txt h2 {
      font-family: var(--fh);
      font-size: clamp(2rem, 3.5vw, 2.8rem);
      font-weight:400;
      letter-spacing: -.025em;
      margin-bottom: 1.25rem;
      line-height: 1.05
    }

    .pf-txt p {
      color: var(--muted);
      line-height: 1.85;
      font-size: .975rem;
      margin-bottom: 1.5rem
    }

    .pf-list {
      display: flex;
      flex-direction: column;
      gap: .85rem;
      margin-top: 1rem
    }

    .pf-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      background: #FFF;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1rem 1.25rem;
      transition: border-color .2s
    }

    .pf-item:hover {
      border-color: var(--red-b)
    }

    .pf-item-ic {
      font-size: 1.3rem;
      flex-shrink: 0;
      margin-top: .05rem
    }

    .pf-item h4 {
      font-family: var(--fh);
      font-size: .9rem;
      font-weight:400;
      margin-bottom: .2rem
    }

    .pf-item p {
      font-size: .825rem;
      color: var(--muted);
      line-height: 1.55
    }

    .pf-img-wrap {
      border-radius: 24px;
      overflow: hidden;
      position: relative
    }

    .pf-img-wrap img {
      width: 100%;
      height: 460px;
      object-fit: cover;
      transition: transform .5s
    }

    .pf-img-wrap:hover img {
      transform: scale(1.03)
    }

    /* SPECS TABLE */
    #specs {
      padding: 7rem 0
    }

    .spec-inner {
      max-width: 860px;
      margin: 0 auto
    }

    .spec-table {
      width: 100%;
      border-collapse: collapse;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid var(--border)
    }

    .spec-table th {
      background: var(--bg3);
      padding: 1.1rem 1.5rem;
      text-align: left;
      font-family: var(--fh);
      font-size: .8rem;
      font-weight:400;
      letter-spacing: .05em;
      text-transform: uppercase;
      color: var(--muted);
      border-bottom: 1px solid var(--border)
    }

    .spec-table td {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--border);
      font-size: .9rem;
      background: #FFF
    }

    .spec-table tr:last-child td {
      border-bottom: none
    }

    .spec-table tr:hover td {
      background: var(--bg2)
    }

    .spec-table .sn {
      font-weight:400;
      color: var(--text)
    }

    .spec-table .sv {
      color: var(--muted)
    }

    .spec-table .chk {
      color: var(--red);
      font-weight:400
    }

    /* TESTIMONIAL */
    #testimonial {
      padding: 7rem 0;
      background: #0A0A0A;
      position: relative;
      overflow: hidden
    }

    #testimonial::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 50%, rgba(212, 32, 32, .08), transparent 65%)
    }

    .testi-in {
      position: relative;
      max-width: 760px;
      margin: 0 auto;
      text-align: center
    }

    .testi-stars {
      color: var(--red);
      font-size: 1.1rem;
      letter-spacing: 4px;
      margin-bottom: 2rem
    }

    .testi-q {
      font-family: var(--fh);
      font-size: clamp(1.25rem, 2.5vw, 1.75rem);
      font-weight:400;
      color: #FFF;
      line-height: 1.5;
      font-style: italic;
      margin-bottom: 2rem
    }

    .testi-name {
      font-size: .9rem;
      font-weight:400;
      color: rgba(255, 255, 255, .6)
    }

    .testi-loc {
      font-size: .8rem;
      color: rgba(255, 255, 255, .35);
      margin-top: .2rem
    }

    /* RELATED */
    #related {
      padding: 7rem 0;
      background: var(--bg2)
    }

    .related-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 3rem
    }

    .rel-card {
      background: #FFF;
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2rem;
      cursor: pointer;
      transition: transform .3s, border-color .3s, box-shadow .3s;
      display: flex;
      flex-direction: column
    }

    .rel-card:hover {
      transform: translateY(-6px);
      border-color: var(--red-b);
      box-shadow: 0 20px 50px rgba(0, 0, 0, .1)
    }

    .rel-tag {
      font-size: .7rem;
      font-weight:400;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--red);
      background: var(--red-d);
      border-radius: 100px;
      padding: .25rem .75rem;
      display: inline-block;
      margin-bottom: 1rem;
      align-self: flex-start
    }

    .rel-img {
      height: 160px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.25rem
    }

    .rel-img img {
      height: 100%;
      width: auto;
      object-fit: contain;
      filter: drop-shadow(0 10px 24px rgba(0, 0, 0, .12));
      transition: transform .4s
    }

    .rel-card:hover .rel-img img {
      transform: scale(1.06) translateY(-4px)
    }

    .rel-name {
      font-family: var(--fh);
      font-size: 1rem;
      font-weight:400;
      margin-bottom: .3rem
    }

    .rel-cap {
      font-size: .78rem;
      color: var(--red);
      font-weight:400;
      margin-bottom: .6rem
    }

    .rel-desc {
      font-size: .85rem;
      color: var(--muted);
      line-height: 1.6;
      flex: 1
    }

    .rel-link {
      margin-top: 1.25rem;
      font-size: .82rem;
      font-weight:400;
      color: var(--text);
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      transition: gap .2s, color .2s
    }

    .rel-link:hover {
      color: var(--red);
      gap: .75rem
    }

    /* CTA */
    #prod-cta {
      padding: 7rem 0;
      background: var(--bg)
    }

    .pcta-in {
      text-align: center;
      max-width: 680px;
      margin: 0 auto
    }

    .pcta-in h2 {
      font-family: var(--fh);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight:400;
      letter-spacing: -.025em;
      margin-bottom: 1rem
    }

    .pcta-in p {
      color: var(--muted);
      line-height: 1.75;
      margin-bottom: 2.5rem;
      font-size: 1.05rem
    }

    .btn-row {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap
    }

    /* FOOTER */
    footer {
      background: #0A0A0A;
      border-top: 1px solid rgba(255, 255, 255, .06);
      padding: 4.5rem 0 2rem
    }

    .foot-g {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1.3fr;
      gap: 3rem;
      margin-bottom: 3.5rem
    }

    .foot-brand p {
      color: rgba(255, 255, 255, .4);
      font-size: .9rem;
      line-height: 1.7;
      margin-top: 1rem;
      max-width: 280px
    }

    .foot-soc {
      display: flex;
      gap: .75rem;
      margin-top: 1.5rem
    }

    .soc-a {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: rgba(255, 255, 255, .05);
      border: 1px solid rgba(255, 255, 255, .08);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .75rem;
      font-weight:400;
      transition: all .2s;
      color: rgba(255, 255, 255, .4)
    }

    .soc-a:hover {
      background: var(--red-d);
      border-color: var(--red-b);
      color: var(--red)
    }

    .foot-col h4 {
      font-family: var(--fh);
      font-size: .8rem;
      font-weight:400;
      letter-spacing: .06em;
      text-transform: uppercase;
      margin-bottom: 1.25rem;
      color: rgba(255, 255, 255, .9)
    }

    .foot-col a {
      display: block;
      color: rgba(255, 255, 255, .4);
      font-size: .875rem;
      margin-bottom: .6rem;
      transition: color .2s
    }

    .foot-col a:hover {
      color: #FFF
    }

    .foot-contact p {
      color: rgba(255, 255, 255, .4);
      font-size: .875rem;
      margin-bottom: .6rem
    }

    .foot-contact a {
      color: var(--red)
    }

    .foot-bot {
      border-top: 1px solid rgba(255, 255, 255, .06);
      padding-top: 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem
    }

    .foot-bot p {
      color: rgba(255, 255, 255, .3);
      font-size: .8rem
    }

    .foot-locs {
      display: flex;
      gap: .6rem;
      flex-wrap: wrap
    }

    .foot-locs span {
      font-size: .72rem;
      color: rgba(255, 255, 255, .35);
      background: rgba(255, 255, 255, .04);
      border: 1px solid rgba(255, 255, 255, .08);
      border-radius: 100px;
      padding: .2rem .7rem
    }

    @media(max-width:1024px) {
      .ph-grid {
        grid-template-columns: 1fr;
        gap: 3rem;
        text-align: center
      }

      .ph-img {
        width: 65%;
        max-width: 300px;
        margin: 0 auto
      }

      .ph-specs-row {
        justify-content: center
      }

      .ph-actions {
        justify-content: center
      }

      .ph-desc {
        margin: 0 auto 2.5rem
      }

      .pf-lay {
        grid-template-columns: 1fr;
        gap: 3rem
      }

      .related-grid {
        grid-template-columns: 1fr 1fr
      }

      .foot-g {
        grid-template-columns: 1fr 1fr
      }
    }

    @media(max-width:768px) {
      .nav-links {
        display: none
      }

      .feat-grid {
        grid-template-columns: 1fr 1fr
      }

      .related-grid {
        grid-template-columns: 1fr
      }

      .badges-row {
        gap: 1.5rem
      }

      .foot-g {
        grid-template-columns: 1fr
      }
    }

    @media(max-width:520px) {
      .feat-grid {
        grid-template-columns: 1fr
      }
    }
    /* MEGA MENU */
    .nav-dd{position:static;display:flex;align-items:center}
    .nd-toggle{display:flex;align-items:center;gap:5px;cursor:pointer;color:var(--muted);font-size:.875rem;font-weight:500;border:none;background:none;font-family:var(--fb);padding:0;transition:color .2s;position:relative;padding-bottom:2px}
    .nav-dd.open .nd-toggle,.nd-toggle:hover{color:var(--text)}
    .nd-chev{transition:transform .25s ease;flex-shrink:0}
