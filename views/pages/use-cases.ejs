<script>
/* -- Hero load animation -- */
window.addEventListener('load', () => document.body.classList.add('loaded'));

/* -- General reveal (Intersection Observer) -- */
const revealObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('on'); revealObs.unobserve(e.target); }
  });
}, { threshold: .1 });
document.querySelectorAll('.r').forEach(el => revealObs.observe(el));

/* -- Journey: scroll-pair reveal -- */
const ucRows = document.querySelectorAll('.uc-row');
const rowObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('in-view');
      rowObs.unobserve(e.target);
    }
  });
}, { threshold: 0.15 });
ucRows.forEach(row => rowObs.observe(row));

/* -- Scroll: nav solid + hero outro -- */
(function(){
  const navEl = document.getElementById('nav');
  const heroC = document.getElementById('hero-content');
  const heroS = document.querySelector('.uc-hero');
  window.addEventListener('scroll', () => {
    const sy = window.scrollY;
    const heroH = heroS ? heroS.offsetHeight - 80 : window.innerHeight - 80;
    if (navEl) { sy > heroH ? navEl.classList.add('nav-solid') : navEl.classList.remove('nav-solid'); }
    if (heroS && heroC) {
      const progress = Math.min(sy / (heroS.offsetHeight * 0.55), 1);
      heroC.style.transform = `translateY(${progress * -70}px)`;
      heroC.style.opacity = Math.max(0, 1 - progress * 2);
    }
  }, { passive: true });
})();

</script>
