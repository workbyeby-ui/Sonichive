<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/webp" href="images/Faveicon-black.webp">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Use Cases - SonicHive Acoustic Pods</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"></noscript>
  <style>
:root{--bg:#FAFAFA;--dark:#0A0A0A;--red:#D42020;--red-d:rgba(212,32,32,.07);--red-b:rgba(212,32,32,.22);--text:#0A0A0F;--muted:#6B7280;--border:rgba(0,0,0,.09);--fh:'Poppins',sans-serif;--max:1440px;--ease:cubic-bezier(0.22,1,0.36,1)}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;overflow-x:hidden}
body{background:#fff;color:#1D1D1F;font-family:var(--fh);-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{color:inherit;text-decoration:none}
img{max-width:100%;display:block}




/* -- HERO -- */
.uc-hero{height:100vh;min-height:680px;display:flex;flex-direction:column;justify-content:flex-end;padding:0 0 6rem;position:relative;overflow:hidden;background:#000}
.hero-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to right,rgba(0,0,0,.55) 0%,rgba(0,0,0,.25) 50%,rgba(0,0,0,.05) 100%),linear-gradient(to top,rgba(0,0,0,.55) 0%,transparent 55%);z-index:1}
.hero-inner{max-width:var(--max);margin:0 auto;padding:0 4rem;position:relative;z-index:2;will-change:transform,opacity;text-align:left}
.hero-eyebrow{font-size:.7rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--red);margin-bottom:1.5rem;overflow:hidden}
.hero-eyebrow span{display:block;transform:translateY(110%);transition:transform 1s var(--ease) .15s}
body.loaded .hero-eyebrow span{transform:translateY(0)}
.hero-h1{font-size:clamp(1.75rem,5.2vw,5rem);font-weight:300;letter-spacing:-.045em;line-height:1;margin-bottom:2.25rem;color:#fff;white-space:nowrap}
.hero-line{display:block;overflow:hidden}
.hero-line span{display:block;transform:translateY(110%);transition:transform 1.1s var(--ease)}
.hero-line:nth-child(1) span{transition-delay:.25s}
.hero-line:nth-child(2) span{transition-delay:.38s}
.hero-line:nth-child(3) span{transition-delay:.51s}
body.loaded .hero-line span{transform:translateY(0)}
.hero-h1 em{color:var(--red);font-style:normal}
.hero-sub{color:rgba(255,255,255,.7);font-size:1.05rem;line-height:1.8;max-width:500px;opacity:0;transform:translateY(22px);transition:opacity .9s ease .85s,transform .9s var(--ease) .85s}
body.loaded .hero-sub{opacity:1;transform:translateY(0)}

/* Stats strip */
.hero-stats{display:flex;gap:0;margin-top:3.5rem;opacity:0;transform:translateY(16px);transition:opacity .8s ease 1.05s,transform .8s var(--ease) 1.05s}
body.loaded .hero-stats{opacity:1;transform:translateY(0)}
.h-stat{padding:0 2.5rem 0 0;border-right:1px solid rgba(255,255,255,.2);margin-right:2.5rem}
.h-stat:last-child{border-right:none}
.h-stat-n{font-size:1.8rem;font-weight:300;letter-spacing:-.04em;color:#fff;line-height:1}
.h-stat-l{font-size:.7rem;color:rgba(255,255,255,.5);letter-spacing:.06em;margin-top:.3rem;text-transform:uppercase}

/* Scroll hint */
.hero-scroll-hint{display:flex;align-items:center;gap:.75rem;position:absolute;bottom:2.5rem;right:4rem;color:rgba(255,255,255,.5);font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;opacity:0;transition:opacity .8s ease 1.3s}
body.loaded .hero-scroll-hint{opacity:1}
.scroll-line{width:36px;height:1px;background:rgba(255,255,255,.2);position:relative;overflow:hidden}
.scroll-line::after{content:'';position:absolute;inset:0;background:var(--red);animation:scan 2.2s ease-in-out infinite 1.5s;transform:translateX(-100%)}
@keyframes scan{0%{transform:translateX(-100%)}50%{transform:translateX(0)}100%{transform:translateX(100%)}}

/* -- JOURNEY (scroll-paired reveal) -- */
.journey{background:#fff}
.uc-row{display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid rgba(0,0,0,.07);overflow:hidden;min-height:580px}
.uc-row:nth-child(even) .uc-img-side{order:2}
.uc-row:nth-child(even) .uc-text-side{order:1}
.uc-img-side{position:relative;overflow:hidden}
.uc-img-side img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transform:scale(1.06) translateX(-24px);opacity:0;transition:transform 1.2s var(--ease),opacity 1s ease}
.uc-row:nth-child(even) .uc-img-side img{transform:scale(1.06) translateX(24px)}
.uc-img-side::after{content:'';position:absolute;inset:0;background:linear-gradient(to right,rgba(0,0,0,.1) 0%,transparent 50%),linear-gradient(to top,rgba(0,0,0,.45) 0%,transparent 40%);z-index:1;pointer-events:none}
.uc-img-num{position:absolute;bottom:1.75rem;left:2rem;font-size:5rem;font-weight:700;color:rgba(255,255,255,.18);letter-spacing:-.06em;line-height:1;z-index:2;user-select:none}
.uc-text-side{display:flex;flex-direction:column;justify-content:center;padding:5rem 4.5rem 5rem 4rem;background:#F5F5F7;transform:translateX(36px);opacity:0;transition:transform 1.2s var(--ease) .08s,opacity 1s ease .08s}
.uc-row:nth-child(even) .uc-text-side{transform:translateX(-36px)}
.uc-row.in-view .uc-img-side img{transform:scale(1) translateX(0);opacity:1}
.uc-row.in-view .uc-text-side{transform:translateX(0);opacity:1}
.ch-num{font-size:clamp(3rem,5vw,5rem);font-weight:700;color:rgba(0,0,0,.06);letter-spacing:-.06em;line-height:1;margin-bottom:-.75rem;font-variant-numeric:tabular-nums;user-select:none}
.ch-tag{font-size:.68rem;font-weight:400;letter-spacing:.18em;text-transform:uppercase;color:var(--red);margin-bottom:.65rem}
.ch-title{font-size:clamp(1.8rem,2.6vw,2.6rem);font-weight:300;letter-spacing:-.035em;line-height:1.05;color:#1D1D1F;margin-bottom:.9rem}
.ch-desc{color:rgba(0,0,0,.55);font-size:.875rem;line-height:1.75;margin-bottom:1.1rem;max-width:390px}
.ch-benefits{display:flex;flex-direction:column;gap:0;margin-bottom:1.1rem}
.ch-b{display:flex;align-items:center;gap:.75rem;font-size:.82rem;color:rgba(0,0,0,.7);padding:.38rem 0;border-bottom:1px solid rgba(0,0,0,.07)}
.ch-b:last-child{border-bottom:none}
.ch-b-dot{width:4px;height:4px;border-radius:50%;background:var(--red);flex-shrink:0}
.ch-rec{background:rgba(0,0,0,.04);border:1px solid rgba(0,0,0,.08);border-radius:10px;padding:.65rem 1rem;font-size:.76rem;color:rgba(0,0,0,.5);margin-bottom:1.1rem;display:flex;align-items:center;gap:.5rem}
.ch-rec svg{flex-shrink:0;color:var(--red)}
.ch-rec strong{color:rgba(0,0,0,.75);font-weight:500}
.ch-cta{display:inline-flex;align-items:center;gap:.55rem;font-size:.85rem;font-weight:500;color:var(--red);transition:gap .25s ease,opacity .2s}
.ch-cta:hover{gap:1rem;opacity:.8}

/* -- INDUSTRIES -- */
.industries{background:#FAFAFA;padding:9rem 0;position:relative}
.industries::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(212,32,32,.3) 40%,rgba(212,32,32,.4) 50%,rgba(212,32,32,.3) 60%,transparent)}
.ind-wrap{max-width:1280px;margin:0 auto;padding:0 3rem}
.ind-head{margin-bottom:5rem;max-width:640px}
.ind-eyebrow{font-size:.68rem;font-weight:400;letter-spacing:.18em;text-transform:uppercase;color:var(--red);margin-bottom:1.1rem}
.ind-head h2{font-size:clamp(2.5rem,4.5vw,4.5rem);font-weight:300;letter-spacing:-.045em;color:var(--text);line-height:.95}
.ind-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem}
.ind-card{background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:20px;padding:2rem 1.75rem 2.25rem;position:relative;overflow:hidden;transition:transform .4s var(--ease),box-shadow .4s ease;cursor:default}
.ind-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--red);transform:scaleX(0);transform-origin:left;transition:transform .4s var(--ease)}
.ind-card:hover{transform:translateY(-7px);box-shadow:0 24px 64px rgba(0,0,0,.1)}
.ind-card:hover::after{transform:scaleX(1)}
.ind-ic{width:40px;height:40px;background:rgba(212,32,32,.07);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:1.4rem;color:var(--red)}
.ind-name{font-size:.95rem;font-weight:500;color:var(--text);margin-bottom:.45rem;letter-spacing:-.01em}
.ind-desc{font-size:.8rem;color:var(--muted);line-height:1.7}

/* -- CTA -- */
.uc-cta{background:#F5F5F7;padding:11rem 0;position:relative;overflow:hidden;text-align:center}
.cta-radial{position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 50% 110%,rgba(212,32,32,.18),transparent 55%),radial-gradient(ellipse 40% 35% at 15% -10%,rgba(212,32,32,.06),transparent 50%)}
.cta-word{position:absolute;bottom:-3rem;left:50%;transform:translateX(-50%);font-size:clamp(8rem,18vw,20rem);font-weight:700;letter-spacing:-.06em;color:rgba(0,0,0,.05);white-space:nowrap;user-select:none;line-height:1;pointer-events:none}
.cta-inner{position:relative;z-index:1;max-width:700px;margin:0 auto;padding:0 2rem}
.cta-tag{font-size:.68rem;font-weight:400;letter-spacing:.18em;text-transform:uppercase;color:var(--red);margin-bottom:1.5rem}
.cta-h{font-size:clamp(2.5rem,5.5vw,5.5rem);font-weight:300;letter-spacing:-.045em;color:#1D1D1F;line-height:.92;margin-bottom:1.5rem}
.cta-p{color:rgba(0,0,0,.55);font-size:1rem;line-height:1.8;max-width:460px;margin:0 auto 3rem}
.btn-row{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
.btn-primary{background:var(--red);color:#fff;border:none;border-radius:100px;padding:.875rem 2.25rem;font-size:.9rem;font-weight:500;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:var(--fh);display:inline-block}
.btn-primary:hover{transform:scale(1.04);box-shadow:0 0 32px rgba(212,32,32,.45)}
.btn-ghost{background:rgba(0,0,0,.05);border:1px solid rgba(0,0,0,.15);color:rgba(0,0,0,.75);border-radius:100px;padding:.875rem 2.25rem;font-size:.9rem;font-weight:400;cursor:pointer;transition:background .2s,border-color .2s;font-family:var(--fh);display:inline-block}
.btn-ghost:hover{background:rgba(0,0,0,.09);border-color:rgba(0,0,0,.25)}


/* -- REVEAL UTILITY -- */
.r{opacity:0;transform:translateY(26px);transition:opacity .75s var(--ease),transform .75s var(--ease)}
.r.on{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}

/* -- RESPONSIVE -- */
@media(max-width:1100px){
  .uc-row{grid-template-columns:1fr}
  .uc-row:nth-child(even) .uc-img-side,.uc-row:nth-child(even) .uc-text-side{order:unset}
  .uc-img-side{min-height:320px}
  .uc-text-side{padding:4rem 3rem;transform:translateY(24px)}
  .uc-row:nth-child(even) .uc-text-side{transform:translateY(24px)}
  .uc-row.in-view .uc-text-side{transform:translateY(0)}
  .uc-img-side img{transform:scale(1.06) translateY(-10px)}
  .uc-row:nth-child(even) .uc-img-side img{transform:scale(1.06) translateY(-10px)}
  .uc-row.in-view .uc-img-side img{transform:scale(1) translateY(0)}
  .ch-desc{max-width:100%}
  .ind-grid{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:768px){
  .uc-hero{min-height:100svh;height:auto;padding:calc(64px + 3.5rem) 0 3.5rem;justify-content:center}
  .hero-inner{padding:0 1.5rem}
  .hero-h1{margin-bottom:1.5rem}
  .hero-sub{max-width:100%;font-size:.95rem}
  .hero-stats{flex-wrap:wrap;margin-top:2rem}
  .h-stat{padding:0 1.25rem 0 0;margin-right:1.25rem;margin-bottom:.75rem}
  .hero-scroll-hint{display:none}
  .uc-img-side{min-height:260px}
  .uc-text-side{padding:3rem 1.75rem}
  .ch-title{font-size:clamp(1.75rem,6vw,2.5rem)}
  .ch-desc{max-width:100%}
  .industries{padding:5rem 0}
  .ind-wrap{padding:0 1.5rem}
  .ind-head{margin-bottom:2.5rem}
  .ind-head h2{font-size:clamp(1.9rem,7vw,4.5rem)}
  .uc-cta{padding:5.5rem 0}
  .cta-inner{padding:0 1.5rem}
  .cta-p{max-width:100%}
  .cta-h{font-size:clamp(2rem,7.5vw,5.5rem)}
}
@media(max-width:520px){
  .hero-h1{font-size:clamp(1.5rem,8vw,2.8rem);white-space:normal}
  .hero-stats{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-top:1.75rem}
  .h-stat{padding:.75rem;margin:0;border-right:none;background:rgba(0,0,0,.03);border-radius:10px;border-bottom:1px solid rgba(0,0,0,.06)}
  .h-stat:last-child{border-right:none;border-bottom:1px solid rgba(0,0,0,.06)}
  .ind-grid{grid-template-columns:1fr}
  .btn-row{flex-direction:column;align-items:stretch}
  .btn-primary,.btn-ghost{text-align:center;padding:.875rem 1.5rem}
}
@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important;animation-iteration-count:1!important}}
  </style>
</head>
<body>

<%- include('../partials/header', { page: 'use-cases' }) %>
<div id="main-content" tabindex="-1" style="outline:none;position:absolute"></div>

<!-- ------------------- HERO ------------------- -->
<section class="uc-hero">
  <img class="hero-video" src="images/banner.webp" alt="Your Space, Your Pace - SonicHive acoustic pod in use">
  <div class="hero-overlay"></div>
  <div class="hero-inner" id="hero-content">
    <p class="hero-eyebrow"><span>Use Cases</span></p>
    <h1 class="hero-h1">
      <span class="hero-line"><span>A Pod for <em>Every</em> Environment.</span></span>
    </h1>
    <div class="hero-stats">
      <div class="h-stat">
        <div class="h-stat-n">30 ±5 dB</div>
        <div class="h-stat-l">Noise Reduction</div>
      </div>
      <div class="h-stat">
        <div class="h-stat-n" style="font-size:2.6rem;line-height:.9">8</div>
        <div class="h-stat-l">Use Cases</div>
      </div>
      <div class="h-stat">
        <div class="h-stat-n">48h</div>
        <div class="h-stat-l">Delivery Dubai</div>
      </div>
      <div class="h-stat">
        <div class="h-stat-n">5yr</div>
        <div class="h-stat-l">Warranty</div>
      </div>
    </div>
  </div>
  <div class="hero-scroll-hint">
    <span class="scroll-line"></span>
    <span>Scroll to explore</span>
  </div>
</section>

<!-- ------------------- JOURNEY ------------------- -->
<div class="journey" id="journey">

  <!-- 01 Corporate -->
  <div class="uc-row" id="corporate">
    <div class="uc-img-side">
      <img loading="eager"
        src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2070&auto=format&fit=crop"
        alt="Modern corporate office open plan">
      <span class="uc-img-num">01</span>
    </div>
    <div class="uc-text-side">
      <div class="ch-num">01</div>
      <p class="ch-tag">Corporate Office</p>
      <h2 class="ch-title">Silence Inside<br>the Open Plan.</h2>
      <p class="ch-desc">Open-plan offices transformed collaboration but created a noise problem that no amount of headphones can fully solve. SonicHive pods drop into any floor plan and create instant acoustic zones for work that truly demands silence.</p>
      <div class="ch-benefits">
        <div class="ch-b"><span class="ch-b-dot"></span>Private sales calls and client conversations</div>
        <div class="ch-b"><span class="ch-b-dot"></span>Video conferencing without background noise</div>
        <div class="ch-b"><span class="ch-b-dot"></span>HR discussions and confidential interviews</div>
        <div class="ch-b"><span class="ch-b-dot"></span>Deep focus work sessions</div>
        <div class="ch-b"><span class="ch-b-dot"></span>Team huddles without disturbing the office</div>
      </div>
      <div class="ch-rec">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
        Recommended: <strong>Solo, Duo, Quartet, Hexa</strong>
      </div>
      <a href="contact.html" class="ch-cta">Get a Quote for Your Office <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg></a>
    </div>
  </div>

  <!-- 02 Co-Working -->
  <div class="uc-row" id="coworking">
    <div class="uc-img-side">
      <img loading="lazy"
        src="https://images.unsplash.com/photo-1497366811353-6870744d04b2?q=80&w=2070&auto=format&fit=crop"
        alt="Co-working shared workspace">
      <span class="uc-img-num">02</span>
    </div>
    <div class="uc-text-side">
      <div class="ch-num">02</div>
      <p class="ch-tag">Co-Working Spaces</p>
      <h2 class="ch-title">Premium Zones<br>Members Love.</h2>
      <p class="ch-desc">Co-working spaces that install SonicHive pods see bookings fill immediately. Members pay a premium for bookable acoustic pods, driving revenue per square foot while solving the number-one complaint in shared environments: noise.</p>
      <div class="ch-benefits">
        <div class="ch-b"><span class="ch-b-dot"></span>Bookable private booths as a premium perk</div>
        <div class="ch-b"><span class="ch-b-dot"></span>Quiet zones for deep work and long focus sessions</div>
        <div class="ch-b"><span class="ch-b-dot"></span>Private meeting spaces without building new rooms</div>
        <div class="ch-b"><span class="ch-b-dot"></span>Instant differentiation in a crowded market</div>
        <div class="ch-b"><span class="ch-b-dot"></span>Flexible relocation as space layout evolves</div>
      </div>
      <div class="ch-rec">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
        Recommended: <strong>Solo, Duo, Quartet</strong>
      </div>
      <a href="contact.html" class="ch-cta">Enquire for Co-Working <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg></a>
    </div>
  </div>

  <!-- 03 Education -->
  <div class="uc-row" id="education">
    <div class="uc-img-side">
      <img loading="lazy"
        src="https://images.unsplash.com/photo-1481627834876-b7833e8f5570?q=80&w=2070&auto=format&fit=crop"
        alt="University library study space">
      <span class="uc-img-num">03</span>
    </div>
    <div class="uc-text-side">
      <div class="ch-num">03</div>
      <p class="ch-tag">Education</p>
      <h2 class="ch-title">Distraction-Free<br>Learning.</h2>
      <p class="ch-desc">Libraries, language centres, universities, and schools face the same challenge: providing quiet individual spaces in open facilities. SonicHive creates focused environments within existing buildings - no permanent construction needed.</p>
      <div class="ch-benefits">
        <div class="ch-b"><span class="ch-b-dot"></span>Library study pods for individual focused work</div>
        <div class="ch-b"><span class="ch-b-dot"></span>Language practice booths for speaking exercises</div>
        <div class="ch-b"><span class="ch-b-dot"></span>Quiet zones in open-plan university campuses</div>
        <div class="ch-b"><span class="ch-b-dot"></span>Individual tutoring and assessment rooms</div>
        <div class="ch-b"><span class="ch-b-dot"></span>Student counselling and welfare conversations</div>
      </div>
      <div class="ch-rec">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
