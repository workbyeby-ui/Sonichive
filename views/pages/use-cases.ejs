<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Use Cases — SonicHive Acoustic Pods</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
:root{--bg:#FAFAFA;--dark:#0A0A0A;--red:#D42020;--red-d:rgba(212,32,32,.07);--red-b:rgba(212,32,32,.22);--text:#0A0A0F;--muted:#6B7280;--border:rgba(0,0,0,.09);--fh:'Poppins',sans-serif;--max:1440px;--ease:cubic-bezier(0.22,1,0.36,1)}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:#fff;color:#1D1D1F;font-family:var(--fh);-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{color:inherit;text-decoration:none}
img{max-width:100%;display:block}

/* ── NAV ── */
#nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(10,10,10,.85);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,.06);box-shadow:0 1px 0 rgba(0,0,0,.3)}
.nav-i{max-width:var(--max);margin:0 auto;padding:1.2rem 2rem;display:flex;align-items:center;justify-content:space-between;gap:2rem}
.logo{display:flex;align-items:center;gap:10px}
.logo-t{font-family:var(--fh);font-size:1.3rem;font-weight:400;letter-spacing:-.02em;color:#fff}
.logo-t em{color:var(--red);font-style:normal}
.nav-links{display:flex;gap:1.75rem;align-items:center}
.nav-links a{font-size:.875rem;color:rgba(255,255,255,.5);font-weight:400;transition:color .2s}
.nav-links a:hover,.nav-links a.cur{color:#fff}
.nav-cta{background:var(--red);color:#fff;border:none;border-radius:100px;padding:.6rem 1.4rem;font-size:.875rem;font-weight:400;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:var(--fh);white-space:nowrap}
.nav-cta:hover{transform:scale(1.04);box-shadow:0 0 24px rgba(212,32,32,.4)}
.nav-dd{position:static;display:flex;align-items:center}
.nd-toggle{display:flex;align-items:center;gap:5px;cursor:pointer;color:rgba(255,255,255,.5);font-size:.875rem;font-weight:400;border:none;background:none;font-family:var(--fh);padding:0;transition:color .2s;position:relative;padding-bottom:2px}
.nav-dd.open .nd-toggle,.nd-toggle:hover{color:#fff}
.nd-chev{transition:transform .25s ease;flex-shrink:0}
.nav-dd.open .nd-chev{transform:rotate(180deg)}
.mega-wrap{position:absolute;top:calc(100% + 14px);left:50%;transform:translateX(-50%) translateY(-12px);width:min(1080px,calc(100vw - 2rem));background:#fff;border:1px solid rgba(0,0,0,.09);border-radius:20px;overflow:hidden;box-shadow:0 4px 6px rgba(0,0,0,.04),0 20px 50px rgba(0,0,0,.15);opacity:0;pointer-events:none;transition:opacity .22s ease,transform .22s var(--ease);z-index:400}
.nav-dd.open .mega-wrap{opacity:1;pointer-events:auto;transform:translateX(-50%) translateY(0)}
.mega-wrap::before{content:"";position:absolute;top:0;left:15%;right:15%;height:1px;background:linear-gradient(90deg,transparent,rgba(212,32,32,.8) 40%,rgba(212,32,32,.9) 50%,rgba(212,32,32,.8) 60%,transparent);z-index:2}
.mega-bg{position:absolute;inset:0;background:transparent}
.mega-head{display:flex;align-items:center;justify-content:space-between;padding:1.1rem 1.5rem .85rem;position:relative;z-index:1}
.mega-eye{font-size:.6rem;font-weight:400;letter-spacing:.22em;text-transform:uppercase;color:rgba(0,0,0,.35)}
.mega-all-link{font-size:.76rem;color:rgba(0,0,0,.4);transition:color .2s;display:flex;align-items:center;gap:.35rem}
.mega-all-link:hover{color:rgba(0,0,0,.8)}
.mega-divider{height:1px;background:rgba(0,0,0,.08)}
.mega-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.4rem;padding:1rem;position:relative;z-index:1}
.mc{display:flex;flex-direction:column;padding:1.3rem 1.2rem 1.4rem;border-radius:14px;text-decoration:none;position:relative;overflow:hidden;transition:background .2s}
.mc::after{content:"";position:absolute;inset:0;border-radius:14px;border:1px solid transparent;transition:border-color .2s;pointer-events:none}
.mc-img-w{height:160px;display:flex;align-items:flex-end;justify-content:center;margin-bottom:.9rem}
.mc-img-w img{height:150px;width:auto;object-fit:contain;filter:drop-shadow(0 4px 14px rgba(0,0,0,.2));transition:transform .35s var(--ease),filter .35s ease}
.mc:hover .mc-img-w img{transform:translateY(-8px) scale(1.06);filter:drop-shadow(0 10px 24px rgba(0,0,0,.28))}
.mc-svg-w{height:120px;display:flex;align-items:center;justify-content:center;margin-bottom:.9rem;transition:transform .35s var(--ease)}
.mc:hover .mc-svg-w{transform:translateY(-6px) scale(1.05)}
.mc-badge{display:inline-block;font-size:.59rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;padding:.17rem .65rem;border-radius:100px;margin-bottom:.45rem;width:fit-content}
.mc-name{font-size:.95rem;font-weight:400;color:#0A0A0F;letter-spacing:-.01em;margin-bottom:.3rem}
.mc-desc{font-size:.71rem;color:rgba(0,0,0,.45);line-height:1.55;flex:1}
.mc-link{display:inline-flex;align-items:center;gap:.3rem;margin-top:.7rem;font-size:.72rem;font-weight:400;opacity:0;transform:translateX(-5px);transition:opacity .18s,transform .18s}
.mc:hover .mc-link{opacity:1;transform:none}
.mc-vrt:hover{background:rgba(212,32,32,.05)}.mc-vrt:hover::after{border-color:rgba(212,32,32,.2)}.mc-vrt .mc-badge{background:rgba(212,32,32,.1);color:#EF5050;border:1px solid rgba(212,32,32,.22)}.mc-vrt .mc-link{color:#EF5050}
.mc-plus:hover{background:rgba(184,134,11,.05)}.mc-plus:hover::after{border-color:rgba(146,64,14,.22)}.mc-plus .mc-badge{background:rgba(184,134,11,.1);color:#92400E;border:1px solid rgba(146,64,14,.25)}.mc-plus .mc-link{color:#92400E}
.mc-art:hover{background:rgba(99,102,241,.05)}.mc-art:hover::after{border-color:rgba(67,56,202,.2)}.mc-art .mc-badge{background:rgba(99,102,241,.1);color:#4338CA;border:1px solid rgba(67,56,202,.22)}.mc-art .mc-link{color:#4338CA}
.mc-home:hover{background:rgba(20,184,166,.05)}.mc-home:hover::after{border-color:rgba(15,118,110,.2)}.mc-home .mc-badge{background:rgba(20,184,166,.1);color:#0F766E;border:1px solid rgba(15,118,110,.22)}.mc-home .mc-link{color:#0F766E}
.mc-vr:hover{background:rgba(37,99,235,.05)}.mc-vr:hover::after{border-color:rgba(37,99,235,.2)}.mc-vr .mc-badge{background:rgba(37,99,235,.1);color:#60A5FA;border:1px solid rgba(37,99,235,.22)}.mc-vr .mc-link{color:#60A5FA}
.mega-foot{display:flex;align-items:center;gap:1.25rem;padding:.85rem 1.5rem;border-top:1px solid rgba(0,0,0,.08);position:relative;z-index:1}
.mf-link{display:flex;align-items:center;gap:.45rem;font-size:.76rem;color:rgba(0,0,0,.45);transition:color .2s;text-decoration:none;white-space:nowrap}
.mf-link:hover{color:rgba(0,0,0,.75)}
.mf-sep{width:1px;height:14px;background:rgba(0,0,0,.1);flex-shrink:0}
.mf-cta{color:rgba(212,32,32,.75)!important}.mf-cta:hover{color:#D42020!important}

/* ── HERO ── */
.uc-hero{height:100vh;min-height:680px;display:flex;flex-direction:column;justify-content:flex-end;padding:0 0 6rem;position:relative;overflow:hidden;background:#fff}
.hero-noise{position:absolute;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E");opacity:.4}
.hero-radial{position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 15% 80%,rgba(212,32,32,.14),transparent 55%),radial-gradient(ellipse 50% 40% at 85% 20%,rgba(212,32,32,.07),transparent 50%)}
.hero-grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(0,0,0,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,.04) 1px,transparent 1px);background-size:72px 72px;mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 0%,transparent 100%)}
.hero-inner{max-width:var(--max);margin:0 auto;padding:0 4rem;position:relative;z-index:2}
.hero-eyebrow{font-size:.7rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--red);margin-bottom:1.5rem;overflow:hidden}
.hero-eyebrow span{display:block;transform:translateY(110%);transition:transform 1s var(--ease) .15s}
body.loaded .hero-eyebrow span{transform:translateY(0)}
.hero-h1{font-size:clamp(3.5rem,7.5vw,8rem);font-weight:300;letter-spacing:-.045em;line-height:.92;margin-bottom:2.25rem}
.hero-line{display:block;overflow:hidden}
.hero-line span{display:block;transform:translateY(110%);transition:transform 1.1s var(--ease)}
.hero-line:nth-child(1) span{transition-delay:.25s}
.hero-line:nth-child(2) span{transition-delay:.38s}
.hero-line:nth-child(3) span{transition-delay:.51s}
body.loaded .hero-line span{transform:translateY(0)}
.hero-h1 em{color:var(--red);font-style:normal}
.hero-sub{color:rgba(0,0,0,.5);font-size:1.05rem;line-height:1.8;max-width:500px;opacity:0;transform:translateY(22px);transition:opacity .9s ease .85s,transform .9s var(--ease) .85s}
body.loaded .hero-sub{opacity:1;transform:translateY(0)}

/* Stats strip */
.hero-stats{display:flex;gap:0;margin-top:3.5rem;opacity:0;transform:translateY(16px);transition:opacity .8s ease 1.05s,transform .8s var(--ease) 1.05s}
body.loaded .hero-stats{opacity:1;transform:translateY(0)}
.h-stat{padding:0 2.5rem 0 0;border-right:1px solid rgba(0,0,0,.12);margin-right:2.5rem}
.h-stat:last-child{border-right:none}
.h-stat-n{font-size:1.8rem;font-weight:300;letter-spacing:-.04em;color:#1D1D1F;line-height:1}
.h-stat-l{font-size:.7rem;color:rgba(0,0,0,.45);letter-spacing:.06em;margin-top:.3rem;text-transform:uppercase}

/* Scroll hint */
.hero-scroll-hint{display:flex;align-items:center;gap:.75rem;position:absolute;bottom:2.5rem;right:4rem;color:rgba(0,0,0,.35);font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;opacity:0;transition:opacity .8s ease 1.3s}
body.loaded .hero-scroll-hint{opacity:1}
.scroll-line{width:36px;height:1px;background:rgba(0,0,0,.12);position:relative;overflow:hidden}
.scroll-line::after{content:'';position:absolute;inset:0;background:var(--red);animation:scan 2.2s ease-in-out infinite 1.5s;transform:translateX(-100%)}
@keyframes scan{0%{transform:translateX(-100%)}50%{transform:translateX(0)}100%{transform:translateX(100%)}}

/* ── JOURNEY (sticky split) ── */
.journey{display:grid;grid-template-columns:55% 45%;background:#fff}

/* Left: sticky visual */
.j-visual{position:sticky;top:0;height:100vh;overflow:hidden}
.j-images{position:relative;width:100%;height:100%}
.j-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transform:scale(1.06);transition:opacity .9s var(--ease),transform 1.4s var(--ease)}
.j-img.active{opacity:1;transform:scale(1)}
.j-vignette{position:absolute;inset:0;background:linear-gradient(to right,rgba(0,0,0,.08) 0%,transparent 50%),linear-gradient(to top,rgba(0,0,0,.55) 0%,transparent 45%),linear-gradient(to bottom,rgba(0,0,0,.35) 0%,transparent 30%);z-index:1}
.j-caption{position:absolute;bottom:2.25rem;left:2.25rem;z-index:2;font-size:.68rem;font-weight:400;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.6);transition:opacity .4s ease}

/* Progress rail */
.j-rail{position:absolute;right:1.75rem;top:50%;transform:translateY(-50%);z-index:10;display:flex;flex-direction:column;align-items:center;gap:.5rem}
.j-dot{width:5px;height:5px;border-radius:50%;background:rgba(0,0,0,.2);cursor:pointer;transition:background .35s ease,transform .35s ease}
.j-dot.active{background:var(--red);transform:scale(1.6)}

/* Right: scrolling chapters */
.j-chapters{background:#F5F5F7;border-left:1px solid rgba(0,0,0,.08)}

.chapter{height:100vh;padding:0 4.5rem 0 4rem;display:flex;flex-direction:column;justify-content:center;border-bottom:1px solid rgba(0,0,0,.07);position:relative;overflow:hidden}
.chapter:last-child{border-bottom:none}

/* Ghost number */
.ch-num{font-size:clamp(4rem,6vw,7rem);font-weight:700;color:rgba(0,0,0,.05);letter-spacing:-.06em;line-height:1;margin-bottom:-1.25rem;font-variant-numeric:tabular-nums;user-select:none;transition:color .6s ease}
.chapter.active .ch-num{color:rgba(212,32,32,.07)}

.ch-tag{font-size:.68rem;font-weight:400;letter-spacing:.18em;text-transform:uppercase;color:var(--red);margin-bottom:.65rem}
.ch-title{font-size:clamp(1.8rem,2.6vw,2.6rem);font-weight:300;letter-spacing:-.035em;line-height:1.05;color:#1D1D1F;margin-bottom:.9rem}
.ch-desc{color:rgba(0,0,0,.55);font-size:.875rem;line-height:1.75;margin-bottom:1.1rem;max-width:390px}
.ch-benefits{display:flex;flex-direction:column;gap:0;margin-bottom:1.1rem}
.ch-b{display:flex;align-items:center;gap:.75rem;font-size:.82rem;color:rgba(0,0,0,.7);padding:.38rem 0;border-bottom:1px solid rgba(0,0,0,.07)}
.ch-b:last-child{border-bottom:none}
.ch-b-dot{width:4px;height:4px;border-radius:50%;background:var(--red);flex-shrink:0}
.ch-rec{background:rgba(0,0,0,.04);border:1px solid rgba(0,0,0,.08);border-radius:10px;padding:.65rem 1rem;font-size:.76rem;color:rgba(0,0,0,.5);margin-bottom:1.1rem;display:flex;align-items:center;gap:.5rem}
.ch-rec svg{flex-shrink:0;color:var(--red)}
.ch-rec strong{color:rgba(0,0,0,.75);font-weight:500}
.ch-cta{display:inline-flex;align-items:center;gap:.55rem;font-size:.85rem;font-weight:500;color:var(--red);transition:gap .25s ease,opacity .2s}
.ch-cta:hover{gap:1rem;opacity:.8}

/* Chapter reveal */
.cr{opacity:0;transform:translateY(24px);transition:opacity .65s var(--ease),transform .65s var(--ease)}
.chapter.in-view .cr{opacity:1;transform:none}
.chapter.in-view .cr:nth-child(1){transition-delay:.05s}
.chapter.in-view .cr:nth-child(2){transition-delay:.12s}
.chapter.in-view .cr:nth-child(3){transition-delay:.2s}
.chapter.in-view .cr:nth-child(4){transition-delay:.28s}
.chapter.in-view .cr:nth-child(5){transition-delay:.36s}
.chapter.in-view .cr:nth-child(6){transition-delay:.44s}
.chapter.in-view .cr:nth-child(7){transition-delay:.52s}

/* ── INDUSTRIES ── */
.industries{background:#FAFAFA;padding:9rem 0;position:relative}
.industries::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(212,32,32,.3) 40%,rgba(212,32,32,.4) 50%,rgba(212,32,32,.3) 60%,transparent)}
.ind-wrap{max-width:1280px;margin:0 auto;padding:0 3rem}
.ind-head{margin-bottom:5rem;max-width:640px}
.ind-eyebrow{font-size:.68rem;font-weight:400;letter-spacing:.18em;text-transform:uppercase;color:var(--red);margin-bottom:1.1rem}
.ind-head h2{font-size:clamp(2.5rem,4.5vw,4.5rem);font-weight:300;letter-spacing:-.045em;color:var(--text);line-height:.95}
.ind-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem}
.ind-card{background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:20px;padding:2rem 1.75rem 2.25rem;position:relative;overflow:hidden;transition:transform .4s var(--ease),box-shadow .4s ease;cursor:default}
.ind-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--red);transform:scaleX(0);transform-origin:left;transition:transform .4s var(--ease)}
.ind-card:hover{transform:translateY(-7px);box-shadow:0 24px 64px rgba(0,0,0,.1)}
.ind-card:hover::after{transform:scaleX(1)}
.ind-ic{width:40px;height:40px;background:rgba(212,32,32,.07);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:1.4rem;color:var(--red)}
.ind-name{font-size:.95rem;font-weight:500;color:var(--text);margin-bottom:.45rem;letter-spacing:-.01em}
.ind-desc{font-size:.8rem;color:var(--muted);line-height:1.7}

/* ── CTA ── */
.uc-cta{background:#F5F5F7;padding:11rem 0;position:relative;overflow:hidden;text-align:center}
.cta-radial{position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 50% 110%,rgba(212,32,32,.18),transparent 55%),radial-gradient(ellipse 40% 35% at 15% -10%,rgba(212,32,32,.06),transparent 50%)}
.cta-word{position:absolute;bottom:-3rem;left:50%;transform:translateX(-50%);font-size:clamp(8rem,18vw,20rem);font-weight:700;letter-spacing:-.06em;color:rgba(0,0,0,.05);white-space:nowrap;user-select:none;line-height:1;pointer-events:none}
.cta-inner{position:relative;z-index:1;max-width:700px;margin:0 auto;padding:0 2rem}
.cta-tag{font-size:.68rem;font-weight:400;letter-spacing:.18em;text-transform:uppercase;color:var(--red);margin-bottom:1.5rem}
.cta-h{font-size:clamp(2.5rem,5.5vw,5.5rem);font-weight:300;letter-spacing:-.045em;color:#1D1D1F;line-height:.92;margin-bottom:1.5rem}
.cta-p{color:rgba(0,0,0,.55);font-size:1rem;line-height:1.8;max-width:460px;margin:0 auto 3rem}
.btn-row{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
.btn-primary{background:var(--red);color:#fff;border:none;border-radius:100px;padding:.875rem 2.25rem;font-size:.9rem;font-weight:500;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:var(--fh);display:inline-block}
.btn-primary:hover{transform:scale(1.04);box-shadow:0 0 32px rgba(212,32,32,.45)}
.btn-ghost{background:rgba(0,0,0,.05);border:1px solid rgba(0,0,0,.15);color:rgba(0,0,0,.75);border-radius:100px;padding:.875rem 2.25rem;font-size:.9rem;font-weight:400;cursor:pointer;transition:background .2s,border-color .2s;font-family:var(--fh);display:inline-block}
.btn-ghost:hover{background:rgba(0,0,0,.09);border-color:rgba(0,0,0,.25)}

/* ── FOOTER ── */
footer{background:#0A0A0A;border-top:1px solid rgba(255,255,255,.06);padding:4.5rem 0 2rem}
.foot-g{display:grid;grid-template-columns:2fr 1fr 1fr 1.3fr;gap:3rem;margin-bottom:3.5rem;max-width:var(--max);margin-left:auto;margin-right:auto;padding:0 2rem}
.foot-brand p{color:rgba(255,255,255,.4);font-size:.9rem;line-height:1.7;margin-top:1rem;max-width:280px}
.foot-soc{display:flex;gap:.75rem;margin-top:1.5rem}
.soc-a{width:36px;height:36px;border-radius:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:400;transition:all .2s;color:rgba(255,255,255,.4)}
.soc-a:hover{background:var(--red-d);border-color:var(--red-b);color:var(--red)}
.foot-col h4{font-family:var(--fh);font-size:.8rem;font-weight:400;letter-spacing:.06em;text-transform:uppercase;margin-bottom:1.25rem;color:rgba(255,255,255,.9)}
.foot-col a{display:block;color:rgba(255,255,255,.4);font-size:.875rem;margin-bottom:.6rem;transition:color .2s}
.foot-col a:hover{color:#fff}
.foot-contact p{color:rgba(255,255,255,.4);font-size:.875rem;margin-bottom:.6rem;display:flex;align-items:center;gap:.45rem}
.foot-contact a{color:var(--red);display:inline;margin-bottom:0}
.foot-bot{border-top:1px solid rgba(255,255,255,.06);padding-top:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;max-width:var(--max);margin:0 auto;padding-left:2rem;padding-right:2rem}
.foot-bot p{color:rgba(255,255,255,.3);font-size:.8rem}
.foot-locs{display:flex;gap:.6rem;flex-wrap:wrap}
.foot-locs span{font-size:.72rem;color:rgba(255,255,255,.35);background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:100px;padding:.2rem .7rem}

/* ── REVEAL UTILITY ── */
.r{opacity:0;transform:translateY(26px);transition:opacity .75s var(--ease),transform .75s var(--ease)}
.r.on{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}

/* ── RESPONSIVE ── */
@media(max-width:1100px){
  .journey{grid-template-columns:1fr}
  .j-visual{display:none}
  .j-chapters{border-left:none;border-top:1px solid rgba(0,0,0,.07)}
  .chapter{height:auto;min-height:0;padding:5rem 3rem 4rem}
  .ch-num{font-size:4rem;margin-bottom:-1rem}
