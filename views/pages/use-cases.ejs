<script>
/* ── Hero load animation ── */
window.addEventListener('load', () => document.body.classList.add('loaded'));

/* ── General reveal (Intersection Observer) ── */
const revealObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('on'); revealObs.unobserve(e.target); }
  });
}, { threshold: .1 });
document.querySelectorAll('.r').forEach(el => revealObs.observe(el));

/* ── Journey: chapter switching ── */
const chapters  = document.querySelectorAll('.chapter');
const jImgs     = document.querySelectorAll('.j-img');
const jDots     = document.querySelectorAll('.j-dot');
const jCaption  = document.getElementById('j-caption');

const captions = [
  'Corporate Office', 'Co-Working', 'Education',
  'Creative Studios', 'Healthcare', 'Transit & Hospitality', 'Home Office'
];

function activateChapter(idx) {
  jImgs.forEach((img, i)  => img.classList.toggle('active', i === idx));
  jDots.forEach((dot, i)  => dot.classList.toggle('active', i === idx));
  if (jCaption) jCaption.textContent = captions[idx];
}

const chapterObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const idx = parseInt(e.target.dataset.index);
      activateChapter(idx);
      e.target.classList.add('in-view', 'active');
    }
  });
}, { rootMargin: '-49% 0px -49% 0px', threshold: 0 });

chapters.forEach(ch => chapterObs.observe(ch));

/* Dot click → scroll to chapter */
jDots.forEach(dot => {
  dot.addEventListener('click', () => {
    const idx = parseInt(dot.dataset.idx);
    chapters[idx]?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });
});

/* ── Hero grid parallax ── */
const heroGrid = document.getElementById('hero-grid');
if (heroGrid) {
  window.addEventListener('scroll', () => {
    heroGrid.style.transform = `translateY(${window.scrollY * .25}px)`;
  }, { passive: true });
}

/* ── Mega menu ── */
(function(){
  const dd  = document.querySelector('.nav-dd');
  const btn = document.querySelector('.nd-toggle');
  if (!dd || !btn) return;
  btn.addEventListener('click', e => { e.stopPropagation(); dd.classList.toggle('open'); });
  document.addEventListener('click', () => dd.classList.remove('open'));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') dd.classList.remove('open'); });
})();
</script>
<script src="popup.js?v=3"></script>
</body>
