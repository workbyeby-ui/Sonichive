<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/webp" href="images/Faveicon-black.webp">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SonicHive - Premium Acoustic Office Pods | Dubai, UAE</title>
  <meta name="description" content="Premium soundproof office pods engineered for the Middle East's most demanding workspaces. Silence Booths in Dubai, Qatar, Saudi Arabia.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#FAFAFA;--bg2:#F2F3F5;--bg3:#E8EAED;--red:#D42020;--red-d:rgba(212,32,32,0.07);--red-b:rgba(212,32,32,0.22);--text:#0A0A0F;--muted:#6B7280;--border:rgba(0,0,0,0.09);--card:rgba(0,0,0,0.03);--fh:'Poppins',sans-serif;--fb:'Poppins',sans-serif;--max:1280px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth;overflow-x:hidden;max-width:100%}
    body{background:var(--bg);color:var(--text);font-family:var(--fb);-webkit-font-smoothing:antialiased;overflow-x:hidden;max-width:100%}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .wrap{max-width:var(--max);margin:0 auto;padding:0 2rem}

    /* SCROLL PROGRESS */
    #pg-bar{position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,var(--red),#FF6B6B);z-index:9999;width:0%;border-radius:0 3px 3px 0;transition:width .05s linear}

    /* CURSOR GLOW */
    #cg{position:fixed;pointer-events:none;width:480px;height:480px;border-radius:50%;background:radial-gradient(circle,rgba(212,32,32,.055) 0%,transparent 70%);transform:translate(-50%,-50%);z-index:0;opacity:0;transition:opacity .5s;will-change:transform}

    /* SECTION NAV DOTS */
    #sec-dots{position:fixed;right:1.5rem;top:50%;transform:translateY(-50%);z-index:500;display:flex;flex-direction:column;gap:.7rem}
    .sd{width:10px;height:10px;border-radius:50%;background:rgba(0,0,0,.12);cursor:pointer;transition:all .3s;border:2px solid transparent;position:relative}
    .sd::before{content:'';position:absolute;inset:-10px;border-radius:50%}
    .sd.on{background:var(--red);transform:scale(1.5)}
    @media(max-width:1024px){#sec-dots{display:none}}

    /* REVEAL CLASSES */
    .r{opacity:0;transform:translateY(32px);transition:opacity .8s ease,transform .85s cubic-bezier(.22,1,.36,1)}
    .r.on{opacity:1;transform:none}
    .rl{opacity:0;transform:translateX(-52px);transition:opacity .8s ease,transform .85s cubic-bezier(.22,1,.36,1)}
    .rl.on{opacity:1;transform:none}
    .rr{opacity:0;transform:translateX(52px);transition:opacity .8s ease,transform .85s cubic-bezier(.22,1,.36,1)}
    .rr.on{opacity:1;transform:none}
    .rs{opacity:0;transform:scale(.88);transition:opacity .7s ease,transform .7s cubic-bezier(.34,1.56,.64,1)}
    .rs.on{opacity:1;transform:none}
    .d1{transition-delay:.08s}.d2{transition-delay:.18s}.d3{transition-delay:.28s}.d4{transition-delay:.38s}.d5{transition-delay:.48s}

    .s-label{font-size:.72rem;font-weight:400;letter-spacing:.15em;text-transform:uppercase;color:var(--red);margin-bottom:.9rem;display:flex;align-items:center;gap:.6rem}
    .s-label::before{content:'';width:22px;height:2px;background:var(--red);border-radius:2px;flex-shrink:0}
    .s-title{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:400;line-height:1.05;letter-spacing:-.025em;margin-bottom:1rem}
    .s-sub{color:var(--muted);font-size:1.05rem;line-height:1.75;max-width:520px}

    

    /* HERO */
    #hero{position:relative;height:100vh;display:flex;flex-direction:column;overflow:hidden;background:#FFF}
    .h-vid{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center center;z-index:0}
    .h-ov{display:none}
    .h-orb{display:none}
    @keyframes orbF1{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(40px,50px) scale(1.06)}}
    @keyframes orbF2{0%,100%{transform:translate(0,0)}50%{transform:translate(30px,-40px) scale(1.1)}}
    .h-con{position:relative;z-index:10;flex:1;display:flex;align-items:center;padding:7rem 5% 4rem}
    .h-left{width:52%;display:flex;flex-direction:column;align-items:flex-start;text-align:left}
    .h-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(0,0,0,.06);border:1px solid rgba(0,0,0,.12);border-radius:100px;padding:.4rem 1.1rem;font-size:.72rem;font-weight:400;letter-spacing:.12em;text-transform:uppercase;color:#0A0A0F;margin-bottom:2rem;animation:fsd .8s ease both}
    @keyframes fsd{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:none}}
    .h-dot{width:6px;height:6px;border-radius:50%;background:#0A0A0F;animation:blink 2s ease infinite;flex-shrink:0}
    @keyframes blink{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.7)}}
    .h-h1{font-family:var(--fh);font-size:clamp(2.5rem,4.5vw,5.5rem);font-weight:400;line-height:.95;letter-spacing:-.035em;color:#0A0A0F;margin-bottom:1.75rem;animation:fsu .9s .2s ease both}
    @keyframes fsu{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:none}}
    .h-h1 .ac{color:#0A0A0F;display:block}
    .h-sub{font-size:clamp(.95rem,1.2vw,1.1rem);color:rgba(0,0,0,.55);max-width:480px;line-height:1.75;margin-bottom:2.5rem;animation:fsu .9s .4s ease both}
    .h-ctas{display:flex;gap:1rem;align-items:center;flex-wrap:wrap;animation:fsu .9s .6s ease both}
    .h-stats-row{display:flex;gap:0;align-items:stretch;margin-top:3rem;border:1px solid rgba(0,0,0,.1);border-radius:16px;overflow:hidden;animation:fsu .9s .8s ease both;flex-wrap:wrap;width:100%}
    .hsr-item{padding:1.1rem 1.75rem;text-align:center;border-right:1px solid rgba(0,0,0,.1);flex:1;min-width:100px}
    .hsr-item:last-child{border-right:none}
    .hsr-num{font-family:var(--fh);font-size:1.6rem;font-weight:400;color:#0A0A0F;line-height:1}
    .hsr-num span{color:#0A0A0F}
    .hsr-lab{font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(0,0,0,.4);margin-top:.3rem}
    .btn-red{background:var(--red);color:#FFF;border:none;border-radius:100px;padding:.875rem 2.5rem;font-size:1rem;font-weight:400;cursor:pointer;transition:transform .25s,box-shadow .25s;font-family:var(--fb);display:inline-block;position:relative;overflow:hidden}
    .btn-red::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.15),transparent);opacity:0;transition:opacity .2s}
    .btn-red:hover{transform:scale(1.05) translateY(-2px);box-shadow:0 8px 32px rgba(212,32,32,.55)}
    .btn-red:hover::after{opacity:1}
    .btn-wh{background:transparent;border:1px solid rgba(0,0,0,.2);color:#0A0A0F;border-radius:100px;padding:.875rem 2.5rem;font-size:1rem;font-weight:500;cursor:pointer;transition:all .25s;font-family:var(--fb);display:inline-block}
    .btn-wh:hover{background:rgba(0,0,0,.05);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.1)}
    .h-scroll{position:absolute;bottom:2.5rem;right:5%;z-index:10;display:flex;flex-direction:column;align-items:center;gap:.5rem;color:rgba(0,0,0,.4);font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;animation:fadeIn 1s 1.2s ease both;cursor:pointer}
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}
    .h-bar{width:1px;height:48px;background:linear-gradient(to bottom,rgba(0,0,0,.4),transparent);animation:sp 1.8s ease-in-out infinite}
    @keyframes sp{0%,100%{opacity:1}50%{opacity:.3}}
    /* transparent nav → dark text on light hero */
    #nav[data-nav="transparent"]:not(.s) .logo-img{filter:brightness(0)!important}
    #nav[data-nav="transparent"]:not(.s) .nav-links a{color:rgba(0,0,0,.6)!important}
    #nav[data-nav="transparent"]:not(.s) .nav-links a:hover,#nav[data-nav="transparent"]:not(.s) .nav-links a.cur{color:#0A0A0F!important}
    #nav[data-nav="transparent"]:not(.s) .nd-toggle{color:rgba(0,0,0,.6)!important}
    #nav[data-nav="transparent"]:not(.s) .nd-toggle:hover,#nav[data-nav="transparent"]:not(.s) .nav-dd.open .nd-toggle{color:#0A0A0F!important}
    #nav[data-nav="transparent"]:not(.s) .nav-cta{color:#FFF!important}
    @media(max-width:1024px){.h-left{width:65%}}
    @media(max-width:768px){
      #hero{height:100vh;height:100dvh}
      /* Gradient from bottom — content pinned to bottom on readable background */
      #hero::before{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(250,250,250,.98) 0%,rgba(250,250,250,.88) 38%,rgba(250,250,250,.45) 60%,transparent 100%);z-index:5;pointer-events:none}
      .h-vid{object-fit:cover;object-position:center 15%}
      .h-ov{display:none!important}
      .h-orb{display:none!important}
      .h-con{padding:0 1.25rem 2.75rem;align-items:flex-end;position:relative;z-index:10}
      .h-left{width:100%;align-items:center;text-align:center}
      .h-badge{display:none}
      .h-h1{font-size:clamp(1.65rem,7vw,2.2rem);margin-bottom:1rem;line-height:1.05}
      .h-sub{display:none}
      .h-ctas{flex-direction:row;width:100%;gap:.5rem;justify-content:center}
      .btn-red{flex:1;text-align:center;padding:.65rem .75rem;font-size:.8rem}
      .btn-wh{display:block;flex:1;text-align:center;padding:.62rem .75rem;font-size:.8rem;border-color:rgba(0,0,0,.18)}
      .h-stats-row{display:none}
      .h-scroll{display:none}
    }

    /* SCROLL ANIMATION */
    #sa-section{position:relative;height:550vh;background:#FFF}
    #sa-sticky{position:sticky;top:68px;height:calc(100vh - 68px);width:100%;overflow:hidden;display:flex;align-items:center;justify-content:center;background:#FFF}
    #sa-bg-layer{position:absolute;inset:0;z-index:0;background:#FFF;transition:background .12s ease}
    #sa-canvas{display:block;max-width:100%;max-height:calc(100vh - 68px);width:auto;height:auto;position:relative;z-index:1;-webkit-mask-image:linear-gradient(to right,transparent,#000 7%,#000 93%,transparent);mask-image:linear-gradient(to right,transparent,#000 7%,#000 93%,transparent)}
    #sa-loader{position:absolute;inset:0;background:#FFF;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;z-index:10;transition:opacity .6s}
    #sa-loader-track{width:180px;height:2px;background:rgba(0,0,0,.1);border-radius:2px;overflow:hidden}
    #sa-loader-fill{height:100%;background:var(--red);width:0%;border-radius:2px;transition:width .08s linear}
    #sa-loader p{font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(0,0,0,.35);font-family:var(--fb)}
    #sa-hud{position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:.75rem;opacity:0;transition:opacity .4s}
    #sa-hud.vis{opacity:1}
    #sa-hud-label{font-size:.65rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(0,0,0,.35);font-family:var(--fb)}
    #sa-hud-track{width:100px;height:2px;background:rgba(0,0,0,.1);border-radius:2px;overflow:hidden}
    #sa-hud-fill{height:100%;background:rgba(0,0,0,.4);width:0%;border-radius:2px}
    #sa-scroll-hint{position:absolute;bottom:5rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.4rem;color:rgba(0,0,0,.35);font-size:.65rem;letter-spacing:.14em;text-transform:uppercase;animation:saHintPulse 2s ease-in-out infinite;font-family:var(--fb)}
    #sa-scroll-hint.gone{opacity:0;pointer-events:none;transition:opacity .4s}
    @keyframes saHintPulse{0%,100%{opacity:.35}50%{opacity:.7}}
    #sa-scroll-hint svg{animation:saArrow .9s ease-in-out infinite}
    @keyframes saArrow{0%,100%{transform:translateY(0)}50%{transform:translateY(5px)}}
    @media(max-width:768px){#sa-section{height:300vh}#sa-sticky{top:60px;height:calc(100vh - 60px)}#sa-canvas{max-height:calc(100vh - 120px);-webkit-mask-image:none;mask-image:none}#sa-hud{bottom:1.5rem}#sa-scroll-hint{bottom:3rem}}

    /* SA OVERLAY LAYERS - absolute inside sticky so only the canvas is behind the blur */
    #sa-glass-layer{position:absolute;inset:0;backdrop-filter:blur(26px);-webkit-backdrop-filter:blur(26px);background:rgba(250,250,250,.3);z-index:2;opacity:0;pointer-events:none}
    #sa-text-layer{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:3;opacity:0;pointer-events:none}
    .sat-inner{text-align:center}
    .sat-label{font-size:.72rem;font-weight:400;letter-spacing:.18em;text-transform:uppercase;color:var(--red);margin-bottom:1.2rem;display:flex;align-items:center;justify-content:center;gap:.55rem}
    .sat-label::before,.sat-label::after{content:'';width:22px;height:2px;background:var(--red);border-radius:2px;flex-shrink:0}
    .sat-h{font-family:var(--fh);font-size:clamp(2rem,5vw,4rem);font-weight:300;letter-spacing:-.03em;color:var(--text);line-height:1.15}
    .sat-h strong{font-weight:600;color:var(--red)}
    /* words: no CSS transition - opacity/transform are scroll-driven */
    .sa-word{display:inline-block;opacity:0;transform:translateY(50px);will-change:opacity,transform}

    /* SA MOBILE TEXT - inside sticky, hidden on desktop */
    #sa-mob-text{display:none;flex-shrink:0;width:100%;text-align:center;padding:0.6rem 1.5rem 0.4rem;position:relative;z-index:4}
    #sa-mob-text .sat-label{font-size:.68rem;margin-bottom:.5rem}
    #sa-mob-text .sat-h{font-size:clamp(1.7rem,6.5vw,2.4rem);color:var(--text)}
    @media(max-width:768px){
      #sa-section{height:300vh}
      #sa-glass-layer,#sa-text-layer{display:none!important}
      #sa-mob-text{display:block}
      #sa-sticky{flex-direction:column;justify-content:flex-end;align-items:center;padding-bottom:12vh;gap:4.5rem}
      #sa-canvas{max-height:calc(58vh - 60px)!important;-webkit-mask-image:none!important;mask-image:none!important}
    }

    /* TICKER */
    #ticker-s{background:#0A0A0A;padding:1.2rem 0;overflow:hidden}
    .tick-t{display:flex;width:max-content;animation:tick 28s linear infinite}
    .tick-t:hover{animation-play-state:paused}
    @keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .tick-i{display:flex;align-items:center;gap:.9rem;padding:0 2.5rem;white-space:nowrap;font-size:.85rem;color:rgba(255,255,255,.45)}
    .tick-i strong{color:#FFF;font-family:var(--fh);font-size:1rem;font-weight:400}
    .tick-sep{color:var(--red);opacity:.6}

    /* SECTION SHARED */
    .sec-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:4rem;flex-wrap:wrap;gap:1.5rem}
    .sec-link{font-size:.875rem;font-weight:400;color:var(--red);display:inline-flex;align-items:center;gap:.4rem;transition:gap .2s,transform .2s}
    .sec-link:hover{gap:.7rem;transform:translateX(3px)}

    /* PRODUCTS TEASER */
    #products-teaser{padding:7rem 0}
    .pt-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2.5rem}
    .pt-card{background:#FAFAFA;border:none;border-radius:30px;display:flex;flex-direction:row;align-items:stretch;transition:box-shadow .3s,transform .3s;text-decoration:none;color:inherit;overflow:hidden;box-shadow:15px 15px 30px #d4d4d4,-15px -15px 30px #ffffff;position:relative}
    .pt-card:hover{box-shadow:18px 18px 36px #cccccc,-18px -18px 36px #ffffff;transform:translateY(-3px)}
    .pt-left{flex:1;display:flex;flex-direction:column;padding:2rem 2rem 4.5rem}
    .pt-right{width:240px;flex-shrink:0;display:flex;align-items:center;justify-content:center;padding:1.5rem 1.5rem 1.5rem 0}
    .pt-pod-wrap{display:flex;flex-direction:column;align-items:center}
    .pt-pod-wrap img{width:auto;max-height:320px;object-fit:contain;transition:transform .4s cubic-bezier(.34,1.56,.64,1)}
    .pt-pod-shadow{width:65%;height:18px;background:radial-gradient(ellipse at center,rgba(0,0,0,.22) 0%,transparent 68%);border-radius:50%;margin-top:2px;transition:width .4s,opacity .4s}
    .pt-card:hover .pt-pod-wrap img{transform:scale(1.06) translateY(-8px)}
    .pt-card:hover .pt-pod-shadow{width:50%;opacity:.65}
    .pt-series{display:flex;align-items:center;gap:.6rem;margin-bottom:1.25rem}
    .pt-series-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .pt-series-meta{display:flex;flex-direction:column;gap:.35rem}
    .pt-series-name{font-size:.68rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase}
    .pt-series-line{height:2.5px;border-radius:2px;width:32px}
    .pt-name{font-family:var(--fh);font-size:1.5rem;font-weight:700;letter-spacing:-.025em;margin-bottom:.4rem}
    .pt-meta{font-size:.82rem;font-weight:500;margin-bottom:.85rem}
    .pt-desc{font-size:.875rem;color:var(--muted);line-height:1.7;flex:1;margin-bottom:1.5rem}
    .pt-btn{display:inline-flex;align-items:center;gap:.5rem;font-size:.82rem;font-weight:500;color:var(--text);border:1.5px solid rgba(0,0,0,.15);border-radius:100px;padding:.55rem 1.25rem;transition:background .22s,color .22s,border-color .22s;position:absolute;left:2rem;bottom:2rem}
    .pt-btn svg{transition:transform .22s}
    .pt-btn:hover{background:#0A0A0F;color:#FFF;border-color:#0A0A0F}
    .pt-btn:hover svg{transform:translateX(4px)}

    /* STATS COUNTER ROW */
    #stats-row{padding:5rem 0;background:var(--bg2);position:relative;overflow:hidden}
    #stats-row::before{content:'';position:absolute;left:-40px;top:50%;transform:translateY(-50%);width:260px;height:260px;background-image:radial-gradient(circle,rgba(212,32,32,.18) 1.5px,transparent 1.5px);background-size:18px 18px;pointer-events:none;opacity:.7}
    #stats-row::after{content:'';position:absolute;right:-40px;top:50%;transform:translateY(-50%);width:260px;height:260px;background-image:radial-gradient(circle,rgba(212,32,32,.18) 1.5px,transparent 1.5px);background-size:18px 18px;pointer-events:none;opacity:.7}
    .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem;position:relative;z-index:1}
    .stat-outer{border-radius:20px;padding:1.5px;background:radial-gradient(circle 230px at 0% 0%,#D42020,#cccccc);position:relative;transition:transform .3s}
    .stat-outer:hover{transform:translateY(-4px)}
    @keyframes statDot{0%,100%{top:10%;right:10%}25%{top:10%;right:calc(100% - 32px)}50%{top:calc(100% - 28px);right:calc(100% - 32px)}75%{top:calc(100% - 28px);right:10%}}
    .stat-dot{width:5px;aspect-ratio:1;position:absolute;background:#D42020;box-shadow:0 0 8px #D42020,0 0 18px rgba(212,32,32,.5);border-radius:100px;z-index:2;right:10%;top:10%;animation:statDot 6s linear infinite;pointer-events:none}
    .stat-item{background:#fff;border-radius:19px;padding:1.6rem 1.1rem 1.3rem;text-align:center;display:flex;flex-direction:column;align-items:center;position:relative;overflow:hidden}
    .stat-ray{width:160px;height:32px;border-radius:100px;position:absolute;background:rgba(212,32,32,.07);opacity:.6;filter:blur(12px);transform-origin:10%;top:0;left:0;transform:rotate(40deg);pointer-events:none}
    .stat-line{position:absolute}
    .stat-topl{top:10%;left:0;right:0;height:1px;background:linear-gradient(90deg,rgba(212,32,32,.18) 0%,rgba(0,0,0,.05) 55%,transparent 100%)}
    .stat-bottoml{bottom:10%;left:0;right:0;height:1px;background:rgba(0,0,0,.04)}
    .stat-leftl{left:10%;top:0;bottom:0;width:1px;background:linear-gradient(180deg,rgba(212,32,32,.12) 0%,rgba(0,0,0,.04) 55%,transparent 100%)}
    .stat-rightl{right:10%;top:0;bottom:0;width:1px;background:rgba(0,0,0,.03)}
    /* per-card patterns */
    .stats-grid>.stat-outer:nth-child(1) .stat-item{background-color:#fff;background-image:radial-gradient(circle,rgba(212,32,32,.07) 1px,transparent 1px);background-size:18px 18px}
    .stats-grid>.stat-outer:nth-child(2) .stat-item{background-color:#fff;background-image:repeating-linear-gradient(45deg,rgba(212,32,32,.05) 0,rgba(212,32,32,.05) 1px,transparent 0,transparent 50%);background-size:14px 14px}
    .stats-grid>.stat-outer:nth-child(3) .stat-item{background-color:#fff;background-image:repeating-linear-gradient(0deg,rgba(212,32,32,.06) 0,rgba(212,32,32,.06) 1px,transparent 0,transparent 14px)}
    .stats-grid>.stat-outer:nth-child(4) .stat-item{background-color:#fff;background-image:linear-gradient(rgba(212,32,32,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(212,32,32,.05) 1px,transparent 1px);background-size:20px 20px}
    .stat-icon{width:44px;height:44px;border-radius:50%;background:rgba(212,32,32,.08);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;position:relative;z-index:1}
    .stat-icon svg{width:18px;height:18px}
    .stat-num{font-family:var(--fh);font-size:clamp(1.5rem,2.8vw,2.2rem);font-weight:500;color:var(--text);line-height:1;margin-bottom:.4rem;position:relative;z-index:1}
    .stat-lab{font-size:.65rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:.8rem;position:relative;z-index:1}
    .stat-dash{width:28px;height:3px;background:var(--red);border-radius:2px;position:relative;z-index:1}
    @media(max-width:768px){.stats-grid{grid-template-columns:1fr 1fr;gap:.75rem}.stat-outer{border-radius:15px}.stat-item{padding:1.25rem .85rem 1rem;border-radius:14px}.stat-icon{width:40px;height:40px;margin-bottom:.85rem}.stat-icon svg{width:18px;height:18px}.stat-num{font-size:clamp(1.2rem,5vw,1.6rem);margin-bottom:.35rem}.stat-lab{font-size:.58rem;margin-bottom:.65rem}.stat-dash{width:20px;height:2px}}

    /* VALUE PROPS */
    #value-props{padding:6rem 0;position:relative;overflow:hidden;background-color:var(--bg2);background-image:linear-gradient(to right,rgba(242,243,245,.92) 20%,rgba(242,243,245,.6) 45%,rgba(242,243,245,.15) 70%,transparent 100%),url('images/why-bg.webp');background-size:cover;background-position:center}
    #value-props .wrap{position:relative;z-index:1}
    .vp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:6rem}
    .vp-card{background:rgba(255,255,255,.82);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.9);border-radius:16px;padding:1.75rem;transition:transform .35s cubic-bezier(.34,1.56,.64,1),box-shadow .3s;position:relative;overflow:hidden}
    .vp-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--red),#FF6B6B);transform:scaleX(0);transform-origin:left;transition:transform .4s ease}
    .vp-card:hover{transform:translateY(-6px);box-shadow:0 20px 50px rgba(0,0,0,.12)}
    .vp-card:hover::after{transform:scaleX(1)}
    .vp-card-top{display:flex;align-items:center;gap:1rem;margin-bottom:1.1rem}
    .vp-icon{width:44px;height:44px;border-radius:50%;background:rgba(212,32,32,.08);display:flex;align-items:center;justify-content:center;color:var(--red);flex-shrink:0;transition:background .3s}
    .vp-card:hover .vp-icon{background:rgba(212,32,32,.14)}
    .vp-metric{display:flex;align-items:baseline;gap:.15rem}
    .vp-metric-num{font-family:var(--fh);font-size:2.6rem;font-weight:300;color:var(--red);line-height:1}
    .vp-metric-unit{font-size:.9rem;color:var(--muted);font-weight:400;padding-bottom:.1rem}
    .vp-divider{width:30px;height:2px;background:var(--red);border-radius:2px;margin-bottom:.75rem}
    .vp-name{font-family:var(--fh);font-size:1.05rem;font-weight:500;margin-bottom:.5rem}
    .vp-desc{font-size:.85rem;color:var(--muted);line-height:1.7;margin-bottom:1.25rem}
    .vp-lnk{font-size:.8rem;font-weight:400;color:var(--red);display:inline-flex;align-items:center;gap:.35rem;transition:gap .2s}
    .vp-lnk:hover{gap:.6rem}

    /* PROCESS */
    #process{background:#0D0D0D;padding:0}
    .proc-inner{max-width:var(--max);margin:0 auto;display:grid;grid-template-columns:1fr 1.6fr}
    .proc-left{padding:6rem 3rem 6rem 2rem;display:flex;flex-direction:column;justify-content:center}
    .proc-label{font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--red);font-family:var(--fb);margin-bottom:1.5rem}
    .proc-title{font-family:var(--fh);font-size:clamp(2rem,3vw,3.25rem);font-weight:400;color:#FFF;line-height:1.05;letter-spacing:-.02em;margin-bottom:1.25rem}
    .proc-desc{font-size:.9rem;color:rgba(255,255,255,.45);line-height:1.8;margin-bottom:2.5rem;max-width:300px}
    .proc-right{padding:5rem 2rem 5rem 4rem;display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;border-left:1px solid rgba(255,255,255,.07)}
    .ps-card{display:flex;flex-direction:column;gap:.75rem}
    .ps-icon{width:46px;height:46px;border:1.5px solid rgba(212,32,32,.45);border-radius:10px;display:flex;align-items:center;justify-content:center;color:var(--red);flex-shrink:0;margin-bottom:.25rem}
    .ps-card-title{font-family:var(--fh);font-size:1rem;font-weight:400;color:#FFF;line-height:1.2}
    .ps-card-desc{font-size:.82rem;color:rgba(255,255,255,.4);line-height:1.65}
    @media(max-width:1024px){.proc-inner{grid-template-columns:1fr}.proc-right{border-left:none;border-top:1px solid rgba(255,255,255,.07);padding:3rem 2rem 4rem}}
    @media(max-width:768px){.proc-right{grid-template-columns:1fr}.proc-left{padding:4rem 1.5rem 2rem}}

    /* USE CASE TEASER */
    #uc-teaser{padding:7rem 0;background:var(--bg2)}
    .uc-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:4rem}
    .uc-card{border-radius:20px;overflow:hidden;position:relative;aspect-ratio:16/9;cursor:pointer}
    .uc-card img{width:100%;height:100%;object-fit:cover;transition:transform .6s cubic-bezier(.4,0,.2,1)}
    .uc-card:hover img{transform:scale(1.07)}
    .uc-card-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.82) 0%,transparent 55%);display:flex;flex-direction:column;justify-content:flex-end;padding:2rem;transition:background .4s}
    .uc-card:hover .uc-card-ov{background:linear-gradient(to top,rgba(0,0,0,.9) 0%,rgba(212,32,32,.08) 60%,transparent 100%)}
    .uc-card-tag{font-size:.7rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.65);margin-bottom:.4rem;transform:translateY(6px);transition:transform .3s}
    .uc-card-title{font-family:var(--fh);font-size:1.2rem;font-weight:400;color:#FFF;transform:translateY(6px);transition:transform .3s .05s}
    .uc-card:hover .uc-card-tag,.uc-card:hover .uc-card-title{transform:none}
    .uc-card-arr{position:absolute;top:1.25rem;right:1.25rem;width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;color:#FFF;font-size:1rem;opacity:0;transform:scale(.6) rotate(-45deg);transition:all .3s}
    .uc-card:hover .uc-card-arr{opacity:1;transform:scale(1) rotate(0)}
    .uc-card.tall{grid-row:span 2;aspect-ratio:auto}
    .uc-card.tall img{height:100%}

    /* TESTIMONIALS */
    #testimonials{padding:7rem 0;background:var(--bg2);overflow:hidden}
    .t-head{margin-bottom:3rem;text-align:center}
    .t-head-left .s-sub{color:var(--muted);font-size:.95rem;line-height:1.7;max-width:440px;margin-top:.6rem;margin-left:auto;margin-right:auto}
    .t-track-w{overflow:hidden;width:100%;-webkit-mask:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent);mask:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent)}
    .t-track{display:flex;gap:1.5rem;width:max-content;animation:tScroll 32s linear infinite;will-change:transform}
    .t-track:hover{animation-play-state:paused}
    @keyframes tScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
    .t-card{width:290px;aspect-ratio:1/1;background:#FFF;border:1px solid var(--border);border-radius:16px;padding:1.3rem 1.5rem;flex-shrink:0;box-shadow:0 2px 16px rgba(0,0,0,.05);position:relative;overflow:hidden}
    .t-qmark{font-size:3rem;line-height:1;color:var(--red);font-family:Georgia,serif;margin-bottom:.1rem;display:block}
    .t-stars{color:var(--red);font-size:.78rem;letter-spacing:2px;margin-bottom:.7rem}
    .t-quote{font-size:.85rem;color:var(--text);line-height:1.7;margin-bottom:1.1rem;font-style:italic}
    .t-divider{height:1px;background:var(--border);margin-bottom:.9rem}
    .t-author{display:flex;align-items:center;gap:.7rem}
    .t-avatar{width:38px;height:38px;border-radius:50%;object-fit:cover;flex-shrink:0;background:var(--bg3)}
    .t-name{font-weight:600;font-size:.82rem;color:var(--text)}
    .t-loc{font-size:.72rem;color:var(--muted);margin-top:.1rem}
    .t-bg-quote{position:absolute;bottom:-1.5rem;right:1rem;font-size:7rem;line-height:1;color:rgba(212,32,32,.07);font-family:Georgia,serif;pointer-events:none;user-select:none}

    /* CTA STRIP */
    #cta-strip{padding:7rem 0;background:#0A0A0A;position:relative;overflow:hidden;background-image:url('images/sonichive-office-pods_silence-booth-3.webp');background-size:cover;background-position:center}
    #cta-strip::before{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,.78),rgba(0,0,0,.88));z-index:0}
    #cta-strip::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(212,32,32,.5),transparent);z-index:1}
    #cta-strip .wrap{position:relative;z-index:1}
    .ctas-in{position:relative;text-align:center;max-width:700px;margin:0 auto}
    .ctas-in h2{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:400;letter-spacing:-.025em;color:#FFF;margin-bottom:1rem}
    .ctas-in p{color:rgba(255,255,255,.55);line-height:1.75;margin-bottom:2.5rem;font-size:1.05rem}
    .ctas-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
    #cta-strip .btn-wh{color:#fff;border-color:rgba(255,255,255,.35)}
    #cta-strip .btn-wh:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.6);box-shadow:0 8px 24px rgba(0,0,0,.3)}

    /* CLIENT BANNER */
    #clients{padding:4rem 0;background:#FFF;overflow:hidden;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
    .clients-head{text-align:center;margin-bottom:2.5rem}
    .clients-label{font-size:.68rem;font-weight:400;letter-spacing:.22em;text-transform:uppercase;color:rgba(0,0,0,.35)}
    .marquee-track{overflow:hidden;width:100%}
    .marquee-row{display:flex;width:max-content;will-change:transform}
    .marquee-row.fwd{animation:mFwd 36s linear infinite}
    .marquee-row.rev{animation:mRev 32s linear infinite}
    .marquee-row:hover{animation-play-state:paused}
    @keyframes mFwd{0%{transform:translateX(0)}100%{transform:translateX(-25%)}}
    @keyframes mRev{0%{transform:translateX(-25%)}100%{transform:translateX(0)}}
    .c-chip{display:inline-flex;align-items:center;justify-content:center;width:180px;height:80px;flex-shrink:0;border-right:1px solid rgba(0,0,0,.07);background:#FFF;transition:background .25s}
    .c-chip:hover{background:#F8F8F8}
    .c-chip img{height:36px;width:148px;object-fit:contain;filter:grayscale(100%);opacity:.55;transition:filter .3s,opacity .3s}
    .c-chip:hover img{filter:grayscale(0%);opacity:1}

    @media(max-width:1024px){.pt-grid{grid-template-columns:repeat(2,1fr);gap:1.5rem}.vp-grid{grid-template-columns:1fr 1fr}.process-steps{grid-template-columns:1fr 1fr}.process-steps::before{display:none}}
    @media(max-width:768px){.pt-grid{grid-template-columns:1fr;gap:1rem}.pt-card{flex-direction:column}.pt-left{padding-bottom:1.5rem!important}.pt-right{width:100%;padding:0 1.5rem 1rem;justify-content:center}.pt-pod-wrap img{max-height:160px}.pt-pod-shadow{display:none}.pt-btn{position:static!important;margin:0 1.5rem 1.5rem!important;align-self:flex-start}.vp-grid{grid-template-columns:1fr}.uc-grid{grid-template-columns:1fr}.uc-card.tall{grid-row:auto}#value-props{background-image:linear-gradient(rgba(242,243,245,.93),rgba(242,243,245,.93)),url('images/why-bg.webp')}.h-orb{display:none!important}.h-con,.h-vid{transform:none!important}#cg{display:none!important}#sec-dots{display:none!important}.h-badge,.h-h1,.h-sub,.h-ctas,.h-stats-row,.h-scroll{animation:none!important;opacity:1!important;transform:none!important}.h-dot,.h-bar{animation:none!important}.t-track,.marquee-row{will-change:auto!important}.r,.rl,.rr,.rs{opacity:1!important;transform:none!important;transition:none!important}.r.on,.rl.on,.rr.on,.rs.on{opacity:1!important;transform:none!important}}
    @media(max-width:480px){.h-h1{font-size:clamp(1.55rem,7.5vw,2rem)}.h-ctas{flex-direction:row;gap:.45rem}.btn-red,.btn-wh{flex:1;padding:.6rem .5rem;font-size:.75rem}.h-stats-row{margin-top:1.5rem}.hsr-num{font-size:1.2rem}.hsr-lab{font-size:.6rem}}
  @media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important;animation-iteration-count:1!important}}
    </style>
</head>
