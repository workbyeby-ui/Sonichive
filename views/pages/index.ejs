<script>
/* -- Scroll progress + nav -- */
const pgBar = document.getElementById('pg-bar');
const nav   = document.getElementById('nav');
const hVid  = document.querySelector('.h-vid');
const hCon  = document.querySelector('.h-con');
const hOrb1 = document.querySelector('.h-orb1');
const hOrb2 = document.querySelector('.h-orb2');
const vh    = () => window.innerHeight;

window.addEventListener('scroll', () => {
  const dh = document.documentElement;
  pgBar.style.width = (scrollY / (dh.scrollHeight - dh.clientHeight) * 100) + '%';
  nav.classList.toggle('s', scrollY > 60);
  if (scrollY < vh() * 1.2 && window.innerWidth > 768) {
    const p = scrollY / vh();
    if (hCon)  hCon.style.transform  = `translateY(${scrollY * 0.22}px)`;
    if (hVid)  hVid.style.transform  = `translateY(${scrollY * 0.18}px)`;
    if (hOrb1) hOrb1.style.transform = `translate(${p*30}px,${p*50}px)`;
    if (hOrb2) hOrb2.style.transform = `translate(${-p*20}px,${p*40}px)`;
  }
}, {passive:true});

/* -- Cursor glow -- */
const cg = document.getElementById('cg');
let cgOn = false;
document.addEventListener('mousemove', e => {
  cg.style.left = e.clientX + 'px';
  cg.style.top  = e.clientY + 'px';
  if (!cgOn) { cg.style.opacity = '1'; cgOn = true; }
}, {passive:true});

/* -- Universal reveal observer -- */
const revObs = new IntersectionObserver(es => es.forEach(e => {
  if (e.isIntersecting) { e.target.classList.add('on'); revObs.unobserve(e.target); }
}), {threshold: 0.07});
const observeAll = () =>
  document.querySelectorAll('.r,.rl,.rr,.rs').forEach(el => {
    if (!el.classList.contains('on')) revObs.observe(el);
  });
observeAll();

/* -- Counter animation -- */
const countUp = (el, target, suffix, dur = 1800) => {
  if (el.dataset.counted) return;
  el.dataset.counted = '1';
  const t0 = performance.now();
  const tick = now => {
    const p = Math.min((now - t0) / dur, 1);
    const ease = 1 - Math.pow(1 - p, 3);
    el.textContent = Math.round(ease * target) + suffix;
    if (p < 1) requestAnimationFrame(tick);
  };
  requestAnimationFrame(tick);
};
const cntObs = new IntersectionObserver(es => es.forEach(e => {
  if (e.isIntersecting) {
    const n = e.target.querySelector('.stat-num');
    if (n) countUp(n, +n.dataset.target, n.dataset.suffix || '');
    cntObs.unobserve(e.target);
  }
}), {threshold: 0.5});
document.querySelectorAll('.stat-item').forEach(el => cntObs.observe(el));

/* -- Process line reveal -- */
const procSteps = document.getElementById('proc-steps');
const lineObs = new IntersectionObserver(es => es.forEach(e => {
  if (e.isIntersecting) { e.target.classList.add('line-on'); lineObs.unobserve(e.target); }
}), {threshold: 0.3});
if (procSteps) lineObs.observe(procSteps);

/* -- Ticker -- */
const tItems = [
  {n:'200K+',l:'Pod Installations'},{n:'175+',l:'Countries'},{n:'30 ±5 dB',l:'Sound Reduction'},
  {n:'30K+',l:'Corporate Clients'},{n:'4.9★',l:'Customer Rating'}
];
const mkTick = () => tItems.map(i =>
  `<div class="tick-i"><strong>${i.n}</strong> ${i.l} <span class="tick-sep">·</span></div>`).join('');
document.getElementById('tick').innerHTML = mkTick() + mkTick();

/* -- Client banner -- */
(function(){
  const row1 = [
    {n:'Apple',            url:'images/clients/apple.svg'},
    {n:'Amazon',           url:'images/clients/amazon.svg'},
    {n:'Tesla',            url:'images/clients/tesla.svg'},
    {n:'Boeing',           url:'images/clients/boeing.svg'},
    {n:'American Airlines',url:'images/clients/american-airlines.svg'},
    {n:'Tencent',          url:'images/clients/tencent.svg'},
  ];
  const row2 = [
    {n:'Huawei',           url:'images/clients/huawei.svg'},
    {n:'Bosch',            url:'images/clients/bosch.svg'},
    {n:'Acer',             url:'images/clients/acer.svg'},
    {n:'Pepsi',            url:'images/clients/pepsi.svg'},
    {n:'Starbucks',        url:'images/clients/starbucks.svg'},
  ];
  const chip = c => `<span class="c-chip"><img src="${c.url}" alt="${c.n}" loading="lazy"></span>`;
  const build = (el, clients) => { const h = clients.map(chip).join(''); el.innerHTML = h + h + h + h; };
  build(document.getElementById('mRow1'), row1);
  build(document.getElementById('mRow2'), row2);
})();

observeAll();

/* -- Testimonials -- */
const testis = [
  {q:'Bought a Home Pod for my Dubai apartment - instant peace even with traffic outside. Totally transformed my remote setup.',n:'Sara A.',l:'Dubai, UAE',av:'https://i.pravatar.cc/60?img=47'},
  {q:'Installed a meeting pod in our Abu Dhabi office. Team uses it daily for client calls. Soundproofing is superb.',n:'Khaled M.',l:'Abu Dhabi, UAE',av:'https://i.pravatar.cc/60?img=12'},
  {q:'We put pods in our co-working space. They are constantly booked. The 30 ±5 dB reduction is the real deal.',n:'Rayan G.',l:'Riyadh, KSA',av:'https://i.pravatar.cc/60?img=33'},
  {q:'Our Business Bay office is one giant echo chamber. Three 4-seater pods later - life-savers for our weekly sprints.',n:'Amina R.',l:'Dubai, UAE',av:'https://i.pravatar.cc/60?img=5'},
  {q:'Ventilation is surprisingly good. Hour-long strategy sessions in the 6-seater and stayed perfectly cool.',n:'Fatima A.',l:'Doha, Qatar',av:'https://i.pravatar.cc/60?img=9'},
];
const ttrack = document.getElementById('ttrack');
const cardHTML = testis.map(t => `
  <div class="t-card">
    <span class="t-qmark">&#x201C;</span>
    <div class="t-stars">★★★★★</div>
    <p class="t-quote">${t.q}</p>
    <div class="t-divider"></div>
    <div class="t-author">
      <img class="t-avatar" src="${t.av}" alt="${t.n}" loading="lazy">
      <div><div class="t-name">${t.n}</div><div class="t-loc">${t.l}</div></div>
    </div>
    <span class="t-bg-quote">&#x201D;</span>
  </div>`).join('');
ttrack.innerHTML = cardHTML + cardHTML;

/* -- Section nav dots -- */
const sections     = ['hero','sa-section','products-teaser','clients','stats-row','value-props','process','uc-teaser','testimonials','cta-strip'];
const sectionNames = ['Home','Animation','Products','Stats','Features','Process','Use Cases','Reviews','Contact'];
const dotsEl = document.getElementById('sec-dots');
dotsEl.innerHTML = sections.map((s, i) =>
  `<div class="sd" data-s="${s}" title="${sectionNames[i]}"></div>`).join('');
const sdObs = new IntersectionObserver(es => es.forEach(e => {
  if (e.isIntersecting)
    document.querySelectorAll('.sd').forEach(d => d.classList.toggle('on', d.dataset.s === e.target.id));
}), {threshold: 0.4});
sections.forEach(s => { const el = document.getElementById(s); if (el) sdObs.observe(el); });
document.querySelectorAll('.sd').forEach(d => d.addEventListener('click', () =>
  document.getElementById(d.dataset.s)?.scrollIntoView({behavior:'smooth'})));
</script>

<script>
/* -- Scroll Frame Animation -- */
(function(){
  const TOTAL = 181;
  // desktop: 550vh section, animation fills first 450/550 of scroll range = 7/9
  const ANIM_FRAC = 7 / 9;

  const pad = n => String(n).padStart(3, '0');
  const src = i => 'images/Scroll_animation_frames/ezgif-frame-' + pad(i) + '.webp';

  const section    = document.getElementById('sa-section');
  const canvas     = document.getElementById('sa-canvas');
  const ctx        = canvas.getContext('2d');
  const loader     = document.getElementById('sa-loader');
  const loaderFill = document.getElementById('sa-loader-fill');
  const loaderTxt  = document.getElementById('sa-loader-text');
  const hud        = document.getElementById('sa-hud');
  const hudFill    = document.getElementById('sa-hud-fill');
  const hint       = document.getElementById('sa-scroll-hint');
  const bgLayer    = document.getElementById('sa-bg-layer');
  const glassLayer = document.getElementById('sa-glass-layer');
  const textLayer  = document.getElementById('sa-text-layer');
  const satLabel   = document.getElementById('sat-lbl');
  const words      = document.querySelectorAll('.sa-word');

  const images = new Array(TOTAL);
  let loaded = 0, curFrame = -1, rafId = null, ready = false;

  function edgeColor(x) {
    const mid = Math.floor(canvas.height / 2);
    const h   = Math.min(40, canvas.height);
    const y0  = Math.max(0, mid - h / 2);
    const d   = ctx.getImageData(x, y0, 1, h).data;
    let r = 0, g = 0, b = 0, n = d.length / 4;
    for (let i = 0; i < d.length; i += 4) { r += d[i]; g += d[i+1]; b += d[i+2]; }
    return `rgb(${~~(r/n)},${~~(g/n)},${~~(b/n)})`;
  }

  function draw(idx) {
    const img = images[idx];
    if (!img || !img.complete || idx === curFrame) return;
    curFrame = idx;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.drawImage(img, 0, 0);
    const lc = edgeColor(0);
    const rc = edgeColor(canvas.width - 1);
    bgLayer.style.background = `linear-gradient(to right,${lc},${lc} 35%,${rc} 65%,${rc})`;
  }

  function clamp(v, lo, hi) { return v < lo ? lo : v > hi ? hi : v; }

  function tick() {
    rafId = null;
    const top   = section.getBoundingClientRect().top;
    const range = section.offsetHeight - window.innerHeight;
    const prog  = clamp(-top / range, 0, 1);

    const mobile = window.innerWidth <= 768;
    const frac   = mobile ? 1.0 : ANIM_FRAC;

    /* -- Phase 1: frame animation -- */
    const animProg = clamp(prog / frac, 0, 1);
    const idx      = Math.min(TOTAL - 1, Math.floor(animProg * TOTAL));
    draw(idx);
    hudFill.style.width = (idx / (TOTAL - 1) * 100) + '%';
    if (hint && idx > 2) hint.classList.add('gone');

    if (mobile) return;

    /* -- Phase 2: scroll-driven word reveal (desktop only) -- */
    const textProg = clamp((prog - frac) / (1 - frac), 0, 1);

    /* glass and text container fade in together at start of text phase */
    const containerAlpha = clamp(textProg * 6, 0, 1);
    glassLayer.style.opacity = containerAlpha;
    textLayer.style.opacity  = containerAlpha;

    /* label slides up first */
    if (satLabel) {
      const lp = clamp(textProg * 10, 0, 1);
      satLabel.style.opacity   = lp;
      satLabel.style.transform = `translateY(${(1 - lp) * 22}px)`;
    }

    /* words reveal sequentially - each triggered by scroll, no CSS transition */
    words.forEach((word, i) => {
      const wStart = 0.06 + i * 0.23;
      const wp     = clamp((textProg - wStart) / 0.17, 0, 1);
      word.style.opacity   = wp;
      word.style.transform = `translateY(${(1 - wp) * 52}px)`;
    });
  }

  const onScroll = () => { if (!ready || rafId) return; rafId = requestAnimationFrame(tick); };
  window.addEventListener('scroll', onScroll, { passive: true });
  document.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', () => { if (ready) requestAnimationFrame(tick); }, { passive: true });

  /* preload all frames */
  for (let i = 1; i <= TOTAL; i++) {
    const img = new Image();
    const fi  = i - 1;
    img.onload = () => {
      loaded++;
      const pct = Math.round(loaded / TOTAL * 100);
      loaderFill.style.width = pct + '%';
      loaderTxt.textContent  = 'Loading ' + pct + '%';

      if (loaded === 1) {
        canvas.width  = img.naturalWidth;
        canvas.height = img.naturalHeight;
        draw(0);
      }
      if (loaded >= Math.ceil(TOTAL * 0.3) && !ready) {
        ready = true;
        loader.style.opacity = '0';
        hud.classList.add('vis');
        setTimeout(() => { loader.style.display = 'none'; }, 650);
        tick();
      }
    };
    img.src = src(i);
    images[fi] = img;
  }
})();
</script><script src="popup.js?v=3"></script>
<style>
  /* Last in document — overrides nav.css mobile transparent rule.
     Homepage has a light hero so logo + hamburger must be dark on mobile. */
  @media(max-width:768px){
    #nav[data-nav="transparent"]:not(.s) .logo-img{filter:brightness(0)!important}
    #nav[data-nav="transparent"]:not(.s) .nav-ham{color:#0A0A0F!important;border-color:rgba(0,0,0,.22)!important}
  }
</style>
</body>
