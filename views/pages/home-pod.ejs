<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SonicHive Home Pod — Acoustic Office Pod for Remote Workers | Dubai</title>
  <meta name="description" content="The SonicHive Home Pod — smart home integrated acoustic pod for remote workers. 30dB+ noise reduction for Dubai apartments and home offices.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#FAFAFA;--bg2:#F2F3F5;--bg3:#E8EAED;--red:#D42020;--red-d:rgba(212,32,32,.07);--red-b:rgba(212,32,32,.22);--text:#0A0A0F;--muted:#6B7280;--border:rgba(0,0,0,.09);--card:rgba(0,0,0,.03);--fh:'Poppins',sans-serif;--fb:'Poppins',sans-serif;--max:1280px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:var(--fb);-webkit-font-smoothing:antialiased;overflow-x:hidden}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .wrap{max-width:var(--max);margin:0 auto;padding:0 2rem}
    .r{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease}
    .r.on{opacity:1;transform:none}
    .d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}
    .s-label{font-size:.72rem;font-weight:400;letter-spacing:.15em;text-transform:uppercase;color:var(--red);margin-bottom:.9rem}
    .s-title{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:400;line-height:1.05;letter-spacing:-.025em;margin-bottom:1rem}
    #nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(250,250,250,.92);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,0,0,.07)}
    .nav-i{max-width:var(--max);margin:0 auto;padding:1.2rem 2rem;display:flex;align-items:center;justify-content:space-between;gap:2rem}
    .logo{display:flex;align-items:center;gap:10px}
    .logo-t{font-family:var(--fh);font-size:1.3rem;font-weight:400;letter-spacing:-.02em;color:var(--text)}
    .logo-t em{color:var(--red);font-style:normal}
    .nav-links{display:flex;gap:1.75rem;align-items:center}
    .nav-links a{font-size:.875rem;color:var(--muted);font-weight:500;transition:color .2s}
    .nav-links a:hover,.nav-links a.cur{color:var(--text)}
    .nav-cta{background:var(--red);color:#FFF;border:none;border-radius:100px;padding:.6rem 1.4rem;font-size:.875rem;font-weight:400;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:var(--fb);white-space:nowrap;display:inline-block}
    .nav-cta:hover{transform:scale(1.04);box-shadow:0 0 24px rgba(212,32,32,.4)}
    #prod-hero{background:#FFF;min-height:92vh;display:flex;align-items:center;position:relative;overflow:hidden;padding:8rem 2rem 5rem}
    #prod-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 35% 50%,rgba(212,32,32,.04),transparent 60%)}
    .ph-grid{max-width:var(--max);margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;position:relative;width:100%}
    .ph-img-wrap{display:flex;flex-direction:column;gap:1rem}
    .ph-main-wrap{position:relative;border-radius:20px;overflow:hidden;min-height:300px}
    .ph-img-glow{display:none}
    .ph-img{width:100%;height:460px;border-radius:20px;object-fit:contain;background:var(--bg2);transition:opacity .3s,transform .4s;box-shadow:0 16px 40px rgba(0,0,0,.1)}
    .ph-img.fade{opacity:0;transform:scale(.97)}
    .ph-img:hover{transform:scale(1.02) translateY(-4px)}
    .ph-thumbs{display:flex;gap:.55rem;overflow-x:auto;scrollbar-width:none;-ms-overflow-style:none}
    .ph-thumbs::-webkit-scrollbar{display:none}
    .ph-thumb{flex-shrink:0;width:72px;height:72px;border-radius:12px;border:2px solid var(--border);background:var(--bg2);cursor:pointer;transition:border-color .2s,transform .15s;overflow:hidden;position:relative}
    .ph-thumb img{width:100%;height:100%;object-fit:cover;transition:transform .3s}
    .ph-thumb:hover{border-color:var(--red-b);transform:translateY(-2px)}
    .ph-thumb:hover img{transform:scale(1.06)}
    .ph-thumb.act{border-color:var(--red);box-shadow:0 0 0 3px var(--red-d)}
    .ph-tlabel{position:absolute;bottom:0;left:0;right:0;font-size:.48rem;font-weight:400;text-align:center;background:rgba(0,0,0,.55);color:#FFF;padding:.2rem 0;letter-spacing:.06em;text-transform:uppercase;pointer-events:none}
    .ph-color-bar{display:flex;align-items:center;gap:.8rem;flex-wrap:wrap;padding:.65rem 1rem;background:#FFF;border:1px solid var(--border);border-radius:12px}
    .ph-clabel{font-size:.78rem;color:var(--muted);white-space:nowrap;flex-shrink:0}
    .ph-clabel b{color:var(--text)}
    .ph-swatches{display:flex;gap:.45rem;align-items:center;flex-wrap:wrap}
    .sw{width:24px;height:24px;border-radius:50%;cursor:pointer;transition:transform .18s,box-shadow .18s;border:2px solid rgba(0,0,0,.1);flex-shrink:0;outline:none;display:flex;align-items:center;justify-content:center}
    .sw:hover{transform:scale(1.22)}
    .sw.act{box-shadow:0 0 0 2px #FFF,0 0 0 4px var(--red);transform:scale(1.12)}
    .sw-custom{background:conic-gradient(from 0deg,#e8342a,#f6c90e,#2cb67d,#4a6cf7,#e8342a);border-color:transparent;font-size:.6rem;color:#FFF;text-shadow:0 1px 2px rgba(0,0,0,.5);font-weight:400}
    .ph-info .breadcrumb{font-size:.75rem;color:var(--muted);margin-bottom:1.5rem;display:flex;align-items:center;gap:.5rem}
    .ph-info .breadcrumb a{color:var(--muted);transition:color .2s}
    .ph-info .breadcrumb a:hover{color:var(--red)}
    .ph-tag{display:inline-flex;align-items:center;gap:.5rem;background:var(--red-d);border:1px solid var(--red-b);border-radius:100px;padding:.35rem 1rem;font-size:.72rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;color:var(--red);margin-bottom:1.5rem}
    .ph-name{font-family:var(--fh);font-size:clamp(2.5rem,5vw,4.5rem);font-weight:400;letter-spacing:-.04em;color:var(--text);line-height:.95;margin-bottom:.75rem}
    .ph-cap{color:var(--red);font-size:1.1rem;font-weight:400;margin-bottom:1.25rem}
    .ph-desc{color:var(--muted);font-size:1rem;line-height:1.8;max-width:480px;margin-bottom:2.5rem}
    .ph-specs-row{display:flex;gap:2rem;flex-wrap:wrap;margin-bottom:2.5rem}
    .ph-spec{text-align:center}
    .ph-spec strong{font-family:var(--fh);font-size:1.6rem;font-weight:400;color:var(--text);display:block;line-height:1}
    .ph-spec span{font-size:.72rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-top:.2rem;display:block}
    .ph-actions{display:flex;gap:1rem;flex-wrap:wrap}
    .btn-red{background:var(--red);color:#FFF;border:none;border-radius:100px;padding:.9rem 2.5rem;font-size:.975rem;font-weight:400;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:var(--fb);display:inline-block}
    .btn-red:hover{transform:scale(1.04);box-shadow:0 0 32px rgba(212,32,32,.45)}
    .btn-wh{background:transparent;border:1px solid rgba(0,0,0,.15);color:var(--text);border-radius:100px;padding:.9rem 2.5rem;font-size:.975rem;font-weight:500;transition:all .2s;font-family:var(--fb);display:inline-block}
    .btn-wh:hover{background:var(--bg2);border-color:rgba(0,0,0,.25)}
    .btn-o{background:transparent;border:1px solid var(--border);color:var(--text);border-radius:100px;padding:.875rem 2.25rem;font-size:.95rem;font-weight:500;cursor:pointer;transition:all .2s;font-family:var(--fb);display:inline-block}
    .btn-o:hover{border-color:var(--red-b);color:var(--red)}
    #badges{background:#111;border-top:1px solid rgba(255,255,255,.06);border-bottom:1px solid rgba(255,255,255,.06);padding:2rem 0}
    .badges-row{display:flex;gap:3rem;align-items:center;justify-content:center;flex-wrap:wrap}
    .badge-item{display:flex;align-items:center;gap:.75rem;color:rgba(255,255,255,.5);font-size:.875rem}
    .badge-item strong{color:#FFF;font-weight:400}
    .badge-ic{width:36px;height:36px;border-radius:10px;background:var(--red-d);border:1px solid var(--red-b);display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
    /* PROBLEM SECTION */
    #problem{padding:7rem 0;background:#FFF}
    .prob-lay{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
    .prob-txt h2{font-family:var(--fh);font-size:clamp(2rem,3.5vw,2.8rem);font-weight:400;letter-spacing:-.025em;margin-bottom:1.25rem;line-height:1.05}
    .prob-txt h2 em{color:var(--red);font-style:normal}
    .prob-txt p{color:var(--muted);line-height:1.85;font-size:.975rem;margin-bottom:1.25rem}
    .prob-noises{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin-top:1.75rem}
    .noise-card{background:#FFF;border:1px solid var(--border);border-radius:12px;padding:.85rem 1rem;display:flex;align-items:center;gap:.75rem;transition:border-color .2s,box-shadow .2s}
    .noise-card:hover{border-color:var(--red-b);box-shadow:0 4px 14px rgba(212,32,32,.06)}
    .nc-ic{width:38px;height:38px;border-radius:10px;background:var(--red-d);border:1px solid var(--red-b);display:flex;align-items:center;justify-content:center;color:var(--red);flex-shrink:0}
    .nc-body strong{display:block;font-size:.84rem;font-weight:500;color:var(--text);line-height:1.25}
    .nc-body span{font-size:.76rem;color:var(--muted)}
    .prob-img-wrap{position:relative}
    .prob-img{border-radius:24px;overflow:hidden;box-shadow:0 24px 60px rgba(0,0,0,.1)}
    .prob-img img{width:100%;height:500px;object-fit:cover;transition:transform .6s;display:block}
    .prob-img:hover img{transform:scale(1.03)}
    .prob-overlay{position:absolute;bottom:1.5rem;right:1.5rem;left:1.5rem;background:rgba(255,255,255,.96);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-radius:16px;padding:1.1rem 1.25rem;display:flex;align-items:center;gap:1rem;box-shadow:0 8px 32px rgba(0,0,0,.12)}
    .po-logo{width:44px;height:44px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .po-body{flex:1;min-width:0}
    .po-title{font-weight:500;font-size:.92rem;color:var(--text);margin-bottom:.2rem}
    .po-sub{font-size:.76rem;color:var(--muted);line-height:1.45}
    .po-cta{color:var(--red);font-size:.84rem;font-weight:500;white-space:nowrap;display:flex;align-items:center;gap:.35rem;flex-shrink:0;transition:gap .2s}
    .po-cta:hover{gap:.55rem}
    #features{padding:7rem 0}
    .feat-head{text-align:center;margin-bottom:4rem}
    .feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
    .feat-card{background:#FFF;border:1px solid var(--border);border-radius:20px;padding:2rem;transition:transform .3s,box-shadow .3s,border-color .3s}
    .feat-card:hover{transform:translateY(-5px);box-shadow:0 16px 40px rgba(0,0,0,.08);border-color:var(--red-b)}
    .feat-ic{width:48px;height:48px;border-radius:13px;background:var(--red-d);border:1px solid var(--red-b);display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:1.25rem}
    .feat-name{font-family:var(--fh);font-size:1rem;font-weight:400;margin-bottom:.5rem}
    .feat-desc{font-size:.9rem;color:var(--muted);line-height:1.75}
    #specs{padding:7rem 0;background:var(--bg2)}
    .spec-inner{max-width:860px;margin:0 auto}
    .spec-table{width:100%;border-collapse:collapse;border-radius:20px;overflow:hidden;border:1px solid var(--border)}
    .spec-table th{background:var(--bg3);padding:1.1rem 1.5rem;text-align:left;font-family:var(--fh);font-size:.8rem;font-weight:400;letter-spacing:.05em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border)}
    .spec-table td{padding:1rem 1.5rem;border-bottom:1px solid var(--border);font-size:.9rem;background:#FFF}
    .spec-table tr:last-child td{border-bottom:none}
    .spec-table tr:hover td{background:var(--bg2)}
    .spec-table .sn{font-weight:400;color:var(--text)}
    .spec-table .sv{color:var(--muted)}
    .spec-table .chk{color:var(--red);font-weight:400}
    #testimonial{padding:7rem 0;background:#0A0A0A;position:relative;overflow:hidden}
    #testimonial::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(212,32,32,.08),transparent 65%)}
    .testi-in{position:relative;max-width:760px;margin:0 auto;text-align:center}
    .testi-stars{color:var(--red);font-size:1.1rem;letter-spacing:4px;margin-bottom:2rem}
    .testi-q{font-family:var(--fh);font-size:clamp(1.25rem,2.5vw,1.75rem);font-weight:400;color:#FFF;line-height:1.5;font-style:italic;margin-bottom:2rem}
    .testi-name{font-size:.9rem;font-weight:400;color:rgba(255,255,255,.6)}
    .testi-loc{font-size:.8rem;color:rgba(255,255,255,.35);margin-top:.2rem}
    #related{padding:7rem 0;background:var(--bg2)}
    .related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
    .rel-card{background:#FFF;border:1px solid var(--border);border-radius:20px;padding:2rem;cursor:pointer;transition:transform .3s,border-color .3s,box-shadow .3s;display:flex;flex-direction:column}
    .rel-card:hover{transform:translateY(-6px);border-color:var(--red-b);box-shadow:0 20px 50px rgba(0,0,0,.1)}
    .rel-tag{font-size:.7rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;color:var(--red);background:var(--red-d);border-radius:100px;padding:.25rem .75rem;display:inline-block;margin-bottom:1rem;align-self:flex-start}
    .rel-img{height:160px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem}
    .rel-img img{height:100%;width:auto;object-fit:contain;filter:drop-shadow(0 10px 24px rgba(0,0,0,.12));transition:transform .4s}
    .rel-card:hover .rel-img img{transform:scale(1.06) translateY(-4px)}
    .rel-name{font-family:var(--fh);font-size:1rem;font-weight:400;margin-bottom:.3rem}
    .rel-cap{font-size:.78rem;color:var(--red);font-weight:400;margin-bottom:.6rem}
    .rel-desc{font-size:.85rem;color:var(--muted);line-height:1.6;flex:1}
    .rel-link{margin-top:1.25rem;font-size:.82rem;font-weight:400;color:var(--text);display:inline-flex;align-items:center;gap:.4rem;transition:gap .2s,color .2s}
    .rel-link:hover{color:var(--red);gap:.75rem}
    #prod-cta{padding:7rem 0}
    .pcta-in{text-align:center;max-width:680px;margin:0 auto}
    .pcta-in h2{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:400;letter-spacing:-.025em;margin-bottom:1rem}
    .pcta-in p{color:var(--muted);line-height:1.75;margin-bottom:2.5rem;font-size:1.05rem}
    .btn-row{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
    footer{background:#0A0A0A;border-top:1px solid rgba(255,255,255,.06);padding:4.5rem 0 2rem}
    .foot-g{display:grid;grid-template-columns:2fr 1fr 1fr 1.3fr;gap:3rem;margin-bottom:3.5rem}
    .foot-brand p{color:rgba(255,255,255,.4);font-size:.9rem;line-height:1.7;margin-top:1rem;max-width:280px}
    .foot-soc{display:flex;gap:.75rem;margin-top:1.5rem}
    .soc-a{width:36px;height:36px;border-radius:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:400;transition:all .2s;color:rgba(255,255,255,.4)}
    .soc-a:hover{background:var(--red-d);border-color:var(--red-b);color:var(--red)}
    .foot-col h4{font-family:var(--fh);font-size:.8rem;font-weight:400;letter-spacing:.06em;text-transform:uppercase;margin-bottom:1.25rem;color:rgba(255,255,255,.9)}
    .foot-col a{display:block;color:rgba(255,255,255,.4);font-size:.875rem;margin-bottom:.6rem;transition:color .2s}
    .foot-col a:hover{color:#FFF}
    .foot-contact p{color:rgba(255,255,255,.4);font-size:.875rem;margin-bottom:.6rem;display:flex;align-items:center;gap:.45rem}
    .foot-contact a{color:var(--red);display:inline;margin-bottom:0}
    .foot-bot{border-top:1px solid rgba(255,255,255,.06);padding-top:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
    .foot-bot p{color:rgba(255,255,255,.3);font-size:.8rem}
    .foot-locs{display:flex;gap:.6rem;flex-wrap:wrap}
    .foot-locs span{font-size:.72rem;color:rgba(255,255,255,.35);background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:100px;padding:.2rem .7rem}
    @media(max-width:1024px){.ph-grid{grid-template-columns:1fr;gap:3rem;text-align:center}.ph-img{max-width:400px;margin:0 auto}.ph-specs-row{justify-content:center}.ph-actions{justify-content:center}.ph-desc{margin:0 auto 2.5rem}.prob-lay{grid-template-columns:1fr;gap:3rem}.related-grid{grid-template-columns:1fr 1fr}.foot-g{grid-template-columns:1fr 1fr}}
    @media(max-width:768px){.feat-grid{grid-template-columns:1fr 1fr}.related-grid{grid-template-columns:1fr}.badges-row{gap:1.5rem}.prob-noises{grid-template-columns:1fr}.foot-g{grid-template-columns:1fr}#prod-hero{padding:5.5rem 1.25rem 3rem}.ph-grid{gap:2rem}.ph-name{font-size:clamp(2rem,7vw,3.5rem)}.ph-actions{flex-direction:column;gap:.75rem}.btn-red,.btn-wh{text-align:center;width:100%}#problem,#features,#specs,#testimonial,#related,#prod-cta{padding:4.5rem 0}.feat-head{margin-bottom:2.5rem}}
    @media(max-width:520px){.feat-grid{grid-template-columns:1fr}}
    /* MEGA MENU */
    .nav-dd{position:static;display:flex;align-items:center}
    .nd-toggle{display:flex;align-items:center;gap:5px;cursor:pointer;color:var(--muted);font-size:.875rem;font-weight:500;border:none;background:none;font-family:var(--fb);padding:0;transition:color .2s;position:relative;padding-bottom:2px}
    .nav-dd.open .nd-toggle,.nd-toggle:hover{color:var(--text)}
    .nd-chev{transition:transform .25s ease;flex-shrink:0}
    .nav-dd.open .nd-chev{transform:rotate(180deg)}
    .mega-wrap{position:absolute;top:calc(100% + 14px);left:50%;transform:translateX(-50%) translateY(-12px);width:min(1080px,calc(100vw - 2rem));background:#FFFFFF;border:1px solid rgba(0,0,0,.09);border-radius:20px;overflow:hidden;box-shadow:0 4px 6px rgba(0,0,0,.04),0 20px 50px rgba(0,0,0,.1);opacity:0;pointer-events:none;transition:opacity .22s ease,transform .22s cubic-bezier(.22,1,.36,1);z-index:400}
    .nav-dd.open .mega-wrap{opacity:1;pointer-events:auto;transform:translateX(-50%) translateY(0)}
    .mega-wrap::before{content:"";position:absolute;top:0;left:15%;right:15%;height:1px;background:linear-gradient(90deg,transparent,rgba(212,32,32,.8) 40%,rgba(212,32,32,.9) 50%,rgba(212,32,32,.8) 60%,transparent);z-index:2}
    .mega-bg{position:absolute;inset:0;background:transparent}
    .mega-head{display:flex;align-items:center;justify-content:space-between;padding:1.1rem 1.5rem .85rem;position:relative;z-index:1}
    .mega-eye{font-size:.6rem;font-weight:400;letter-spacing:.22em;text-transform:uppercase;color:rgba(0,0,0,.35)}
    .mega-all-link{font-size:.76rem;color:rgba(0,0,0,.4);transition:color .2s;display:flex;align-items:center;gap:.35rem}
    .mega-all-link:hover{color:rgba(0,0,0,.8)}
    .mega-divider{height:1px;background:rgba(0,0,0,.08)}
    .mega-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.4rem;padding:1rem;position:relative;z-index:1}
    .mc{display:flex;flex-direction:column;padding:1.3rem 1.2rem 1.4rem;border-radius:14px;text-decoration:none;position:relative;overflow:hidden;transition:background .2s}
    .mc::after{content:"";position:absolute;inset:0;border-radius:14px;border:1px solid transparent;transition:border-color .2s;pointer-events:none}
    .mc-img-w{height:160px;display:flex;align-items:flex-end;justify-content:center;margin-bottom:.9rem}
    .mc-img-w img{height:150px;width:auto;object-fit:contain;filter:drop-shadow(0 4px 14px rgba(0,0,0,.2));transition:transform .35s cubic-bezier(.22,1,.36,1),filter .35s ease}
    .mc:hover .mc-img-w img{transform:translateY(-8px) scale(1.06);filter:drop-shadow(0 10px 24px rgba(0,0,0,.28))}
    .mc-svg-w{height:120px;display:flex;align-items:center;justify-content:center;margin-bottom:.9rem;transition:transform .35s cubic-bezier(.22,1,.36,1)}
    .mc:hover .mc-svg-w{transform:translateY(-6px) scale(1.05)}
    .mc-badge{display:inline-block;font-size:.59rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;padding:.17rem .65rem;border-radius:100px;margin-bottom:.45rem;width:fit-content}
