<script>
const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('on');obs.unobserve(e.target)}}),{threshold:.08});
document.querySelectorAll('.r').forEach(el=>obs.observe(el));
</script>
<script>
(function(){
  var pimg=document.getElementById('pimg');
  if(!pimg)return;
  var cname=document.getElementById('pcname');
  var thumbs=document.querySelectorAll('#pthumbs .ph-thumb');
  var swatches=document.querySelectorAll('.ph-swatches .sw');
  var angles=Array.from(thumbs).map(function(t){return t.querySelector('img').src;});
  var curFilter=swatches[0]?swatches[0].dataset.filter:'none';
  var curIdx=0;
  function applyImg(idx,filter){
    pimg.classList.add('fade');
    setTimeout(function(){pimg.src=angles[idx];if(filter!==undefined)pimg.style.filter=filter;pimg.classList.remove('fade');},220);
  }
  thumbs.forEach(function(btn,i){
    btn.addEventListener('click',function(){
      thumbs.forEach(function(t){t.classList.remove('act');});
      btn.classList.add('act');curIdx=i;applyImg(i,curFilter);
    });
  });
  swatches.forEach(function(sw){
    sw.addEventListener('click',function(){
      swatches.forEach(function(s){s.classList.remove('act');});
      sw.classList.add('act');curFilter=sw.dataset.filter;
      if(cname)cname.textContent=sw.dataset.name;
      applyImg(curIdx,curFilter);
    });
  });
})();
</script>

<script>
(function(){
  var dd=document.querySelector('.nav-dd'),btn=document.querySelector('.nd-toggle');
  if(!dd||!btn)return;
  btn.addEventListener('click',function(e){e.stopPropagation();dd.classList.toggle('open');});
  document.addEventListener('click',function(e){if(!dd.contains(e.target))dd.classList.remove('open');});
  document.addEventListener('keydown',function(e){if(e.key==='Escape')dd.classList.remove('open');});
})();
</script><script src="popup.js?v=3"></script>
