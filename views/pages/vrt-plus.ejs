<script>
const obs = new IntersectionObserver(es => es.forEach(e => { if(e.isIntersecting) e.target.classList.add('on') }), {threshold:.1});
document.querySelectorAll('.r').forEach(el => obs.observe(el));
</script>
<script src="popup.js?v=3"></script>
<script>
(function(){
  var img=document.getElementById('cpick-img-plus');
  var stage=document.getElementById('cpick-stage-plus');
  var badge=document.getElementById('cpick-badge-plus');
  if(!img||!stage) return;
  function hexRgba(hex,a){
    var r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
    return 'rgba('+r+','+g+','+b+','+a+')';
  }
  var first=document.querySelector('.cpick-thumb.active');
  if(first) stage.style.background=hexRgba(first.dataset.bg,.16);
  document.querySelectorAll('.cpick-thumb').forEach(function(btn){
    btn.addEventListener('click',function(){
      var src=this.dataset.src,name=this.dataset.name,bg=this.dataset.bg;
      document.querySelectorAll('.cpick-thumb').forEach(function(b){b.classList.remove('active');b.setAttribute('aria-pressed','false');});
      this.classList.add('active');
      this.setAttribute('aria-pressed','true');
      img.classList.add('fading');
      stage.style.background=hexRgba(bg,.16);
      setTimeout(function(){
        img.src=src;img.alt='VRT+ Pod — '+name;
        if(badge) badge.textContent=name;
        img.classList.remove('fading');
      },190);
    });
  });
})();
</script>
