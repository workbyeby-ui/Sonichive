<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="images/Faveicon-black.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VRT Plus Series, SonicHive Premium Acoustic Pods | Dubai</title>
  <meta name="description" content="SonicHive VRT Plus, premium acoustic pods with enhanced insulation, superior finishes. Solo, Duo, Quartet, Hexa configurations. Dubai UAE.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#FAFAFA;--bg2:#F2F3F5;--bg3:#E8EAED;--red:#D42020;--red-d:rgba(212,32,32,.07);--red-b:rgba(212,32,32,.22);--text:#0A0A0F;--muted:#6B7280;--border:rgba(0,0,0,.09);--card:rgba(0,0,0,.03);--fh:'Poppins',sans-serif;--fb:'Poppins',sans-serif;--max:1280px;--gold:#B8860B;--gold-d:rgba(184,134,11,.08);--gold-b:rgba(184,134,11,.25)}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:var(--fb);-webkit-font-smoothing:antialiased;overflow-x:hidden}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .wrap{max-width:var(--max);margin:0 auto;padding:0 2rem}
    .r{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .75s cubic-bezier(.22,1,.36,1)}
    .r.on{opacity:1;transform:none}
    .d1{transition-delay:.08s}.d2{transition-delay:.18s}.d3{transition-delay:.28s}.d4{transition-delay:.38s}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}


    /* SERIES HERO, Premium dark gold tones */
    .series-hero{padding:8rem 2rem 5.5rem;background:linear-gradient(140deg,#07090F 0%,#0F1118 50%,#1a1200 100%);position:relative;overflow:hidden}
    .series-hero::before{content:'';position:absolute;top:-200px;right:-80px;width:600px;height:600px;background:radial-gradient(circle,rgba(184,134,11,.12),transparent 65%);pointer-events:none}
    .series-hero::after{content:'';position:absolute;bottom:-180px;left:-60px;width:450px;height:450px;background:radial-gradient(circle,rgba(212,32,32,.07),transparent 65%);pointer-events:none}
    .hero-in{max-width:var(--max);margin:0 auto;position:relative;z-index:1}
    .series-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(184,134,11,.15);border:1px solid rgba(184,134,11,.3);border-radius:100px;padding:.35rem 1rem;font-size:.7rem;font-weight:400;letter-spacing:.12em;text-transform:uppercase;color:#D4A832;margin-bottom:1.5rem}
    .s-dot{width:6px;height:6px;border-radius:50%;background:#D4A832;animation:blink 2s infinite;flex-shrink:0}
    .series-name{font-family:var(--fh);font-size:clamp(3rem,8vw,6.5rem);font-weight:400;letter-spacing:-.04em;color:#FFF;line-height:.92;margin-bottom:.5rem}
    .series-name sup{font-size:.4em;color:#D4A832;vertical-align:super;letter-spacing:.05em;font-weight:400}
    .series-tagline{color:rgba(255,255,255,.62);font-size:1.08rem;line-height:1.75;max-width:500px;margin-bottom:3rem}
    .series-badges{display:flex;gap:2rem;flex-wrap:wrap}
    .s-badge{display:flex;align-items:center;gap:.5rem;color:rgba(255,255,255,.45);font-size:.82rem}

    /* PREMIUM BANNER */
    .premium-banner{background:linear-gradient(90deg,rgba(184,134,11,.08),rgba(184,134,11,.04));border:1px solid rgba(184,134,11,.2);border-radius:16px;padding:1.25rem 1.75rem;display:flex;align-items:center;gap:1.5rem;margin-bottom:4rem;flex-wrap:wrap}
    .pb-icon{width:44px;height:44px;border-radius:12px;background:rgba(184,134,11,.12);border:1px solid rgba(184,134,11,.25);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .pb-text strong{font-family:var(--fh);font-size:1rem;font-weight:400;color:var(--text);display:block;margin-bottom:.2rem}
    .pb-text span{font-size:.85rem;color:var(--muted);line-height:1.5}

    /* SIZE SECTION */
    .size-section{padding:6rem 0 7rem}
    .sec-header{text-align:center;margin-bottom:4rem}
    .s-label{font-size:.72rem;font-weight:400;letter-spacing:.15em;text-transform:uppercase;color:var(--red);margin-bottom:.75rem;display:flex;align-items:center;justify-content:center;gap:.6rem}
    .s-label::before,.s-label::after{content:'';flex:1;max-width:40px;height:2px;background:var(--red);border-radius:2px}
    .s-title{font-family:var(--fh);font-size:clamp(2rem,3.5vw,2.75rem);font-weight:400;letter-spacing:-.025em;margin-bottom:.75rem}
    .s-sub{color:var(--muted);font-size:1rem;line-height:1.7}
    .size-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem}
    @media(max-width:768px){.size-grid{grid-template-columns:1fr}}
    .size-card{background:#FFF;border:1px solid var(--border);border-radius:24px;overflow:hidden;transition:border-color .25s,transform .3s,box-shadow .3s;display:flex;flex-direction:column;position:relative}
    .size-card:hover{border-color:rgba(184,134,11,.35);transform:translateY(-6px);box-shadow:0 20px 50px rgba(0,0,0,.09)}
    .sc-img{height:200px;background:linear-gradient(135deg,#F9F7F0,var(--bg2));display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;border-bottom:1px solid var(--border)}
    .sc-ph{display:flex;flex-direction:column;align-items:center;gap:.65rem;color:var(--muted);opacity:.4}
    .sc-ph span{font-size:.68rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase}
    .sc-body{padding:1.5rem;flex:1;display:flex;flex-direction:column}
    .sc-cap{display:inline-flex;align-items:center;gap:.35rem;background:rgba(184,134,11,.1);border:1px solid rgba(184,134,11,.25);border-radius:100px;padding:.25rem .75rem;font-size:.68rem;font-weight:400;letter-spacing:.08em;text-transform:uppercase;color:var(--red);margin-bottom:.85rem;width:fit-content}
    .sc-name{font-family:var(--fh);font-size:1.45rem;font-weight:400;letter-spacing:-.02em;margin-bottom:.35rem}
    .sc-desc{font-size:.85rem;color:var(--muted);line-height:1.65;margin-bottom:1.25rem;flex:1}
    .sc-specs{display:flex;gap:0;margin-bottom:1.4rem;border:1px solid var(--border);border-radius:12px;overflow:hidden}
    .sc-spec{flex:1;text-align:center;padding:.65rem .5rem;border-right:1px solid var(--border)}
    .sc-spec:last-child{border-right:none}
    .sc-spec strong{font-family:var(--fh);font-size:1rem;font-weight:400;color:var(--text);display:block;line-height:1.1}
    .sc-spec span{font-size:.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-top:2px;display:block}
    .sc-cta{display:block;text-align:center;background:var(--bg2);border:1px solid var(--border);border-radius:100px;padding:.7rem 1.5rem;font-size:.85rem;font-weight:400;color:var(--text);transition:all .2s}
    .size-card:hover .sc-cta{background:var(--red);color:#FFF;border-color:var(--red)}

    /* UPGRADE SECTION */
    .upgrade-sec{padding:5rem 0;background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
    .upgrade-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
    @media(max-width:768px){.upgrade-grid{grid-template-columns:1fr}.series-hero{padding:5.5rem 1.25rem 3.5rem}.size-section{padding:3.5rem 0 4rem}.upgrade-sec{padding:3.5rem 0}.cta-sec{padding:4rem 0}}
    .upgrade-label{font-size:.72rem;font-weight:400;letter-spacing:.15em;text-transform:uppercase;color:var(--red);margin-bottom:.75rem;display:flex;align-items:center;gap:.5rem}
    .upgrade-label::before{content:'';width:20px;height:2px;background:var(--red);border-radius:2px}
    .upgrade-title{font-family:var(--fh);font-size:clamp(1.8rem,3vw,2.4rem);font-weight:400;letter-spacing:-.03em;margin-bottom:1.2rem}
    .upgrade-desc{color:var(--muted);font-size:1rem;line-height:1.75;margin-bottom:2rem}
    .upgrade-list{display:flex;flex-direction:column;gap:.85rem}
    .ul-item{display:flex;align-items:flex-start;gap:.85rem;font-size:.9rem;line-height:1.6}
    .ul-check{width:20px;height:20px;border-radius:50%;background:var(--red-d);border:1px solid var(--red-b);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
    .ul-col{display:flex;flex-direction:column;gap:.85rem}
    .comp-card{background:#FFF;border:1px solid var(--border);border-radius:16px;overflow:hidden}
    .comp-row{display:flex;align-items:center;justify-content:space-between;padding:.85rem 1.25rem;border-bottom:1px solid var(--border);font-size:.85rem}
    .comp-row:last-child{border-bottom:none}
    .comp-row span:first-child{color:var(--muted)}
    .comp-row .v-std{color:var(--muted);font-size:.82rem}
    .comp-row .v-plus{font-weight:400;color:var(--text)}
    .comp-head{background:var(--bg2);display:flex;justify-content:flex-end;gap:1rem;padding:.6rem 1.25rem;font-size:.72rem;font-weight:400;letter-spacing:.06em;text-transform:uppercase;color:var(--muted)}
    .comp-head .ch-plus{color:var(--red)}

    /* CTA */
    .cta-sec{padding:6rem 0;text-align:center}
    .cta-title{font-family:var(--fh);font-size:clamp(2rem,3.5vw,2.8rem);font-weight:400;letter-spacing:-.03em;margin-bottom:1rem}
    .cta-sub{color:var(--muted);font-size:1rem;margin-bottom:2.5rem;max-width:440px;margin-left:auto;margin-right:auto;line-height:1.7}
    .cta-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
    .btn-red{background:var(--red);color:#FFF;border-radius:100px;padding:.9rem 2.5rem;font-size:.975rem;font-weight:400;display:inline-block;transition:transform .2s,box-shadow .2s;font-family:var(--fb)}
    .btn-red:hover{transform:scale(1.04);box-shadow:0 0 32px rgba(212,32,32,.45)}
    .btn-o{border:1px solid var(--border);color:var(--text);border-radius:100px;padding:.9rem 2.5rem;font-size:.975rem;font-weight:500;display:inline-block;transition:all .2s;font-family:var(--fb)}
    .btn-o:hover{border-color:var(--red-b);color:var(--red)}

    /* FOOTER */
    footer{background:var(--bg2);border-top:1px solid var(--border);padding:2rem 0}
    .foot-in{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem}
    .foot-logo{display:flex;align-items:center;gap:8px;font-family:var(--fh);font-weight:400;letter-spacing:-.02em;font-size:1.1rem}
    .foot-logo em{color:var(--red);font-style:normal}
    .foot-copy{font-size:.78rem;color:var(--muted)}
    .foot-links{display:flex;gap:1.5rem}
    .foot-links a{font-size:.78rem;color:var(--muted);transition:color .2s}
    .foot-links a:hover{color:var(--text)}
  @media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important;animation-iteration-count:1!important}}

    /* FEATURE ICON GRID */
    .feat-grid-sec{padding:6rem 0;background:#fff}
    .feat-icon-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
    .fig-card{background:var(--bg);border:1px solid var(--border);border-radius:20px;padding:2rem 1.75rem;position:relative;overflow:hidden;transition:transform .35s ease,box-shadow .35s ease}
    .fig-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,0,0,.08)}
    .fig-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--gold),#D4A832);transform:scaleX(0);transform-origin:left;transition:transform .35s ease}
    .fig-card:hover::after{transform:scaleX(1)}
    .fig-icon{width:48px;height:48px;border-radius:14px;background:var(--gold-d);display:flex;align-items:center;justify-content:center;color:var(--gold);margin-bottom:1.25rem}
    .fig-title{font-size:1rem;font-weight:500;color:var(--text);margin-bottom:.5rem;letter-spacing:-.01em}
    .fig-desc{font-size:.82rem;color:var(--muted);line-height:1.7;margin-bottom:1rem}
    .fig-tags{display:flex;flex-wrap:wrap;gap:.4rem}
    .fig-tag{font-size:.65rem;font-weight:400;letter-spacing:.06em;background:var(--gold-d);color:#92400E;border:1px solid var(--gold-b);border-radius:100px;padding:.2rem .65rem}
    @media(max-width:900px){.feat-icon-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:540px){.feat-icon-grid{grid-template-columns:1fr}}

    /* ENGINEERING DEEP DIVE */
    .eng-sec{background:var(--bg2);border-top:1px solid var(--border)}
    .eng-row{display:grid;grid-template-columns:1fr 1fr;min-height:480px}
    .eng-row:not(:last-child){border-bottom:1px solid var(--border)}
    .eng-img{position:relative;overflow:hidden;background:#E8EAED;display:flex;align-items:center;justify-content:center;min-height:380px}
    .eng-img img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0}
    .eng-img-placeholder{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;color:rgba(0,0,0,.2);width:100%;height:100%;min-height:380px}
    .eng-img-placeholder p{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase}
    .eng-txt{padding:4rem;display:flex;flex-direction:column;justify-content:center;background:#fff}
    .eng-eyebrow{font-size:.68rem;font-weight:400;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem}
    .eng-title{font-size:clamp(1.6rem,2.5vw,2.2rem);font-weight:300;letter-spacing:-.035em;color:var(--text);line-height:1.1;margin-bottom:1rem}
    .eng-desc{font-size:.875rem;color:var(--muted);line-height:1.8;margin-bottom:1.5rem;max-width:420px}
    .eng-stats{display:flex;gap:2rem;flex-wrap:wrap;margin-bottom:1.5rem}
    .eng-stat-n{font-size:1.5rem;font-weight:300;letter-spacing:-.04em;color:var(--text);display:block}
    .eng-stat-l{font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);display:block}
    .eng-list{display:flex;flex-direction:column;gap:.5rem}
    .eng-li{display:flex;align-items:flex-start;gap:.65rem;font-size:.83rem;color:rgba(0,0,0,.65);line-height:1.5}
    .eng-li-dot{width:5px;height:5px;border-radius:50%;background:var(--gold);flex-shrink:0;margin-top:.45rem}
    @media(max-width:900px){.eng-row{grid-template-columns:1fr}.eng-txt{padding:2.5rem 2rem}.eng-img-placeholder{min-height:260px}}
    @media(max-width:480px){.eng-txt{padding:2rem 1.5rem}}

    /* VRT+ SMART SECTION */
    .smart-sec{background:#0A0A0F;padding:7rem 0}
    .smart-header{text-align:center;margin-bottom:4rem}
    .smart-eyebrow{font-size:.68rem;font-weight:400;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem}
    .smart-title{font-size:clamp(1.8rem,3.5vw,3rem);font-weight:300;letter-spacing:-.04em;color:#fff;line-height:1.05;margin-bottom:.75rem}
    .smart-sub{color:rgba(255,255,255,.45);font-size:.9rem;line-height:1.7;max-width:500px;margin:0 auto}
    .smart-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.07);border-radius:20px;overflow:hidden;margin-bottom:3rem}
    .smart-card{background:#0A0A0F;padding:2rem 1.75rem;transition:background .3s}
    .smart-card:hover{background:#111}
    .smart-ic{width:44px;height:44px;border-radius:12px;background:rgba(184,134,11,.12);border:1px solid rgba(184,134,11,.2);display:flex;align-items:center;justify-content:center;color:var(--gold);margin-bottom:1.25rem}
    .smart-name{font-size:.95rem;font-weight:400;color:#fff;margin-bottom:.4rem;letter-spacing:-.01em}
    .smart-desc{font-size:.78rem;color:rgba(255,255,255,.38);line-height:1.65}
    .smart-img-row{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.07);border-radius:20px;overflow:hidden}
    .smart-img-panel{position:relative;min-height:320px;background:#111;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:.75rem;color:rgba(255,255,255,.18)}
    .smart-img-panel img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0}
    .smart-img-label{position:absolute;bottom:1.25rem;left:1.25rem;font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.4);background:rgba(0,0,0,.5);padding:.3rem .8rem;border-radius:100px}
    @media(max-width:900px){.smart-grid{grid-template-columns:repeat(2,1fr)}.smart-img-row{grid-template-columns:1fr}}
    @media(max-width:540px){.smart-grid{grid-template-columns:1fr}}
    </style>
</head>
<body>

<%- include('../partials/header', { page: 'vrt-plus' }) %>
<div id="main-content" tabindex="-1" style="outline:none;position:absolute"></div>

<section class="series-hero">
  <div class="hero-in">
    <div class="series-tag"><span class="s-dot"></span>Premium Series</div>
    <h1 class="series-name">VRT<sup>+</sup></h1>
    <p class="series-tagline">Everything in the VRT, elevated. Superior acoustic insulation, premium finishes, and enhanced ventilation for the most discerning workspaces.</p>
    <div class="series-badges">
      <div class="s-badge">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="rgba(255,255,255,.45)" stroke-width="1.3"/><path d="M5 8l2 2 4-4" stroke="rgba(255,255,255,.45)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Up to 30&plusmn;5dB Reduction
      </div>
      <div class="s-badge">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1.5l1.9 3.86 4.26.62-3.08 3 .73 4.24L8 11.1l-3.81 2.02.73-4.24-3.08-3 4.26-.62L8 1.5z" stroke="rgba(255,255,255,.45)" stroke-width="1.3" stroke-linejoin="round"/></svg>
        Premium Finishes
      </div>
      <div class="s-badge">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="10" rx="2" stroke="rgba(255,255,255,.45)" stroke-width="1.3"/><path d="M5 6h6M5 9h4" stroke="rgba(255,255,255,.45)" stroke-width="1.3" stroke-linecap="round"/></svg>
        Enhanced Ventilation
      </div>
      <div class="s-badge">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 2v2M8 12v2M2 8h2M12 8h2" stroke="rgba(255,255,255,.45)" stroke-width="1.3" stroke-linecap="round"/><circle cx="8" cy="8" r="3" stroke="rgba(255,255,255,.45)" stroke-width="1.3"/></svg>
        3-Year Warranty
      </div>
    </div>
  </div>
</section>

<section class="size-section">
  <div class="wrap">
    <div class="sec-header r">
      <div class="s-label">Choose Your Configuration</div>
      <h2 class="s-title">VRT Plus, Five Sizes, One Standard</h2>
      <p class="s-sub">Premium acoustic performance in every configuration. Built for workspaces where quality is non-negotiable.</p>
    </div>

    <div class="premium-banner r">
      <div class="pb-icon">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 2l2.4 4.86 5.37.78-3.88 3.78.92 5.34L11 14.26l-4.81 2.5.92-5.34L3.23 7.64l5.37-.78L11 2z" stroke="#B8860B" stroke-width="1.4" stroke-linejoin="round"/></svg>
      </div>
      <div class="pb-text">
        <strong>Upgraded from VRT, What's new in Plus?</strong>
        <span>Thicker acoustic panels, brushed aluminium trim, dual-zone lighting, and 3-year warranty across all sizes.</span>
      </div>
    </div>

    <div class="size-grid">

      <a href="vrt-plus-solo.html" class="size-card r d1">
        <div class="sc-img" style="padding:.5rem;overflow:hidden"><img src="images/Pods/all Color and Size/Photos of ART and VRT pod/Photos of ART and VRT pod/VRT+/VRT+ S 1.webp" alt="VRT+ S" style="width:100%;height:100%;object-fit:contain"></div>
        <div class="sc-body">
          <div class="sc-cap">1 Person</div>
          <div class="sc-name">VRT+ S</div>
          <div class="sc-desc">Elevated single-occupant pod with enhanced privacy glass and premium interior finish.</div>
          <div class="sc-specs">
            <div class="sc-spec"><strong>30&plusmn;5dB</strong><span>Reduction</span></div>
            <div class="sc-spec"><strong>1000mm</strong><span>Width</span></div>
            <div class="sc-spec"><strong>236kg</strong><span>Weight</span></div>
          </div>
          <span class="sc-cta">View Specifications &#x2192;</span>
        </div>
      </a>

      <a href="vrt-plus-duo.html" class="size-card r d2">
        <div class="sc-img" style="padding:.5rem;overflow:hidden"><img src="images/Pods/all Color and Size/Photos of ART and VRT pod/Photos of ART and VRT pod/VRT+/VRT+ SM 1.webp" alt="VRT+ SM" style="width:100%;height:100%;object-fit:contain"></div>
        <div class="sc-body">
          <div class="sc-cap">2 Persons</div>
          <div class="sc-name">VRT+ SM</div>
          <div class="sc-desc">Compact two-seat premium pod with upgraded acoustics and refined interior details.</div>
          <div class="sc-specs">
            <div class="sc-spec"><strong>30&plusmn;5dB</strong><span>Reduction</span></div>
            <div class="sc-spec"><strong>1100mm</strong><span>Width</span></div>
