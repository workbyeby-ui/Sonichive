    @media(max-width:640px){.cpick-stage{min-height:320px;padding:1.5rem}.cpick-main-img{max-height:270px;max-width:88%}.cpick-dot{width:32px;height:32px}.cpick-row{gap:.6rem;padding:1rem 1rem 1.25rem}}
    </style>
</head>
