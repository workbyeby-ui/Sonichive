<script>
const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('on');obs.unobserve(e.target)}}),{threshold:.08});
document.querySelectorAll('.r').forEach(el=>obs.observe(el));

const nav=document.getElementById('nav');
const onScroll=()=>nav.classList.toggle('s',scrollY>40);
window.addEventListener('scroll',onScroll,{passive:true});
onScroll();

const faqs=[
  {q:'Do the pods need any construction or permanent installation?',a:'No. Our soundproof pods are completely modular and self-contained — plug-and-play for your workspace. No drilling, no contractors, no drama. Install, move, or remove without leaving a trace.'},
  {q:'How long does installation take?',a:'Most pods are fully installed within 2 hours. Our team handles delivery and setup, so you can focus on your workspace transformation, not logistics.'},
  {q:'Can SonicHive pods be customized?',a:"Absolutely. You can customize size, layout, colors, and features. Whether you're a startup or a corporate HQ in Dubai, our pods adapt to your brand and functional needs."},
  {q:'Are the pods ventilated?',a:"Yes — every pod includes a built-in ventilation system that keeps air flowing and temperature balanced. Designed for hours of comfortable use without stuffiness."},
  {q:'What is the noise reduction level?',a:'Our pods achieve up to 30dB of sound reduction, meeting professional standards for acoustic privacy. This effectively eliminates external distractions and prevents internal conversations from being heard outside.'},
  {q:'Do you offer rental pods for events?',a:'Yes. We offer rental pods for trade shows, corporate events, and temporary office setups. Delivered, installed, and collected by our team. Contact us for rental pricing.'},
  {q:'Which spaces are SonicHive pods suitable for?',a:"Corporate offices, co-working spaces, schools, hospitals, retail environments, home offices, airports, and more. Anywhere noise and lack of privacy are a problem, SonicHive is the solution."},
  {q:'Where is your showroom?',a:"Our main showroom is in Downtown Dubai, UAE. You're welcome to visit and experience the pods first-hand. We also have a presence in Qatar, Saudi Arabia, Bahrain, and New Zealand."},
];
const plusIcon=`<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>`;
document.getElementById('faq-list').innerHTML=faqs.map((f,i)=>`
<div class="faq-item${i<2?' r d'+i:''}">
  <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false" type="button">
    ${f.q}
    <span class="faq-icon" aria-hidden="true">${plusIcon}</span>
  </button>
  <div class="faq-body" hidden><p class="faq-ans">${f.a}</p></div>
</div>`).join('');
document.querySelectorAll('.faq-item.r').forEach(el=>obs.observe(el));

function toggleFaq(btn){
  const item=btn.parentElement;
  const body=item.querySelector('.faq-body');
  const open=item.classList.toggle('open');
  btn.setAttribute('aria-expanded',open);
  body.hidden=!open;
}

document.getElementById('qform').onsubmit=async(e)=>{
  e.preventDefault();
  const form=e.target;
  const btn=document.getElementById('qsubmit');
  const errBox=document.getElementById('form-error');
  errBox.style.display='none';
  const required=form.querySelectorAll('[required]');
  let firstInvalid=null;
  required.forEach(el=>{
    if(!el.value.trim()){el.style.borderColor='#D42020';if(!firstInvalid)firstInvalid=el;}
    else{el.style.borderColor='';}
  });
  if(firstInvalid){
    errBox.textContent='Please fill in all required fields.';
    errBox.style.display='block';
    firstInvalid.focus();
    return;
  }
  const ogHtml=btn.innerHTML;
  btn.disabled=true;
  btn.innerHTML='<span>Sending…</span>';
  const data=Object.fromEntries(new FormData(form).entries());
  try{
    const res=await fetch('/api/quote',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});
    if(res.ok){
      btn.innerHTML='<span>✓ Received — we\'ll contact you shortly!</span>';
      btn.style.background='#25D366';
      setTimeout(()=>{btn.innerHTML=ogHtml;btn.style.background='';btn.disabled=false;form.reset();},5000);
    }else{throw new Error('Server error');}
  }catch(err){
    errBox.textContent='Something went wrong. Please try again or email us directly.';
    errBox.style.display='block';
    btn.innerHTML=ogHtml;
    btn.disabled=false;
  }
};
</script>

<script>
(function(){
  var dd=document.querySelector('.nav-dd'),btn=document.querySelector('.nd-toggle');
  if(!dd||!btn)return;
  btn.addEventListener('click',function(e){e.stopPropagation();dd.classList.toggle('open');});
  document.addEventListener('click',function(e){if(!dd.contains(e.target))dd.classList.remove('open');});
  document.addEventListener('keydown',function(e){if(e.key==='Escape')dd.classList.remove('open');});
})();
</script><script>
(function(){
  var pr=document.querySelector('.scroll-prog');
  var glow=document.querySelector('.hero-glow');
  var _r=null;
  function tick(){
    var y=window.scrollY;
    var total=document.documentElement.scrollHeight-window.innerHeight;
    pr.style.width=(total>0?y/total*100:0)+'%';
    if(glow)glow.style.transform='translateX(-50%) translateY('+(y*.28)+'px)';
    _r=null;
  }
  window.addEventListener('scroll',function(){if(!_r)_r=requestAnimationFrame(tick);},{passive:true});
  tick();
  function cnt(el,n,s){var t0=performance.now(),d=1500;requestAnimationFrame(function run(t){var p=Math.min((t-t0)/d,1),e=1-Math.pow(1-p,4);el.textContent=Math.round(n*e)+s;if(p<1)requestAnimationFrame(run);});}
  var cObs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){cnt(e.target,+e.target.dataset.n,e.target.dataset.s||'');cObs.unobserve(e.target);}});},{threshold:.7});
  document.querySelectorAll('[data-n]').forEach(function(el){cObs.observe(el);});
})();
</script><script src="popup.js?v=3"></script>
</body>
</html>
