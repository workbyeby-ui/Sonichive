<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Get a Quote — SonicHive Dubai</title>
  <meta name="description" content="Request a free quote for SonicHive acoustic office pods in Dubai, UAE. Soundproof solutions for any workspace — installed in under 2 hours. Serving UAE, Qatar, Saudi Arabia and Bahrain.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#FFFFFF;--bg-gray:#F5F5F7;--bg-dark:#000000;--red:#D42020;--red-d:rgba(212,32,32,.07);--red-b:rgba(212,32,32,.22);--text:#1D1D1F;--muted:#6E6E73;--border:rgba(0,0,0,.08);--fh:'Poppins',sans-serif;--fb:'Poppins',sans-serif;--max:1280px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:var(--fb);-webkit-font-smoothing:antialiased;overflow-x:hidden}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .wrap{max-width:var(--max);margin:0 auto;padding:0 2rem}
    .r{opacity:0;transform:translateY(32px);transition:opacity .9s ease,transform .9s cubic-bezier(.22,1,.36,1)}
    .r.on{opacity:1;transform:none}
    .d1{transition-delay:.08s}.d2{transition-delay:.17s}.d3{transition-delay:.26s}
    .s-label{font-size:.65rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--red);margin-bottom:1rem;display:flex;align-items:center;gap:.5rem}

    /* NAV */
    #nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:transparent;border-bottom:1px solid transparent;transition:background .4s,border-color .4s,box-shadow .4s}
    #nav.s{background:rgba(250,250,250,.96);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom-color:rgba(0,0,0,.09);box-shadow:0 1px 0 rgba(0,0,0,.06)}
    .nav-i{max-width:var(--max);margin:0 auto;padding:1.2rem 2rem;display:flex;align-items:center;justify-content:space-between;gap:2rem}
    .logo{display:flex;align-items:center;gap:10px}
    .logo-t{font-family:var(--fh);font-size:1.3rem;font-weight:400;letter-spacing:-.02em;color:#FFF;transition:color .4s}
    #nav.s .logo-t{color:var(--text)}
    .logo-t em{color:var(--red);font-style:normal}
    .nav-links{display:flex;gap:1.75rem;align-items:center}
    .nav-links a{font-size:.875rem;color:rgba(255,255,255,.7);font-weight:400;transition:color .3s;position:relative;padding-bottom:2px}
    #nav.s .nav-links a{color:var(--muted)}
    .nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--red);transition:width .25s ease}
    .nav-links a:hover{color:#FFF}
    #nav.s .nav-links a:hover{color:var(--text)}
    .nav-links a:hover::after,.nav-links a.cur::after{width:100%}
    .nav-cta{background:var(--red);color:#FFF;border:none;border-radius:100px;padding:.6rem 1.4rem;font-size:.875rem;font-weight:400;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:var(--fb);white-space:nowrap;display:inline-block}
    .nav-cta:hover{transform:scale(1.04);box-shadow:0 0 24px rgba(212,32,32,.4)}

    /* HERO */
    .contact-hero{background:#000;padding:7rem 0 6rem;position:relative;overflow:hidden}
    .hero-glow{position:absolute;top:-10%;right:30%;width:900px;height:700px;background:radial-gradient(ellipse,rgba(212,32,32,.11) 0%,transparent 60%);pointer-events:none}
    .ch-inner{max-width:var(--max);margin:0 auto;padding:0 2rem;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start}
    .ch-left{padding-top:1.5rem}
    .ch-eyebrow{font-size:.62rem;font-weight:400;letter-spacing:.22em;text-transform:uppercase;color:var(--red);margin-bottom:2rem;display:flex;align-items:center;gap:.6rem}
    .ch-eyebrow::before{content:'';width:20px;height:1px;background:var(--red);flex-shrink:0}
    .ch-left h1{font-size:clamp(3rem,5.5vw,5rem);font-weight:400;letter-spacing:-.04em;line-height:.96;color:#FFF;margin-bottom:1.5rem}
    .ch-left h1 em{color:var(--red);font-style:normal}
    .ch-sub{color:rgba(255,255,255,.44);font-size:1.05rem;line-height:1.8;max-width:440px;margin-bottom:2.5rem}
    .contact-tiles{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}
    .c-tile{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:1.25rem 1.5rem;transition:background .25s,border-color .25s,transform .25s;cursor:pointer;display:flex;align-items:center;gap:.9rem;text-decoration:none}
    .c-tile:hover{background:rgba(255,255,255,.09);border-color:rgba(212,32,32,.35);transform:translateY(-2px)}
    .c-tile.c-wa{border-color:rgba(37,211,102,.15)}
    .c-tile.c-wa:hover{background:rgba(37,211,102,.07);border-color:rgba(37,211,102,.4)}
    .c-tile-ic{width:40px;height:40px;border-radius:11px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:rgba(255,255,255,.7)}
    .c-tile.c-wa .c-tile-ic{background:rgba(37,211,102,.1);border-color:rgba(37,211,102,.25);color:#25D366}
    .c-tile-label{font-size:.68rem;font-weight:400;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-bottom:.2rem}
    .c-tile-val{font-size:.9rem;font-weight:400;color:rgba(255,255,255,.8);line-height:1.3}
    .c-tile.c-wa .c-tile-val{color:#25D366}

    /* FORM CARD */
    .form-card{background:#FFF;border-radius:28px;padding:2.75rem;box-shadow:0 40px 100px rgba(0,0,0,.45),0 0 0 1px rgba(255,255,255,.05);position:relative;overflow:hidden}
    .form-card::before{content:'';position:absolute;top:-80px;right:-80px;width:250px;height:250px;background:radial-gradient(circle,rgba(212,32,32,.05),transparent 70%);pointer-events:none}
    .form-card-hd{margin-bottom:2rem}
    .form-card-hd h2{font-size:1.45rem;font-weight:400;letter-spacing:-.03em;color:var(--text);margin-bottom:.4rem}
    .form-card-hd p{font-size:.875rem;color:var(--muted);line-height:1.6}
    .fgrid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .fl{position:relative}
    .fl input,.fl select,.fl textarea{width:100%;background:#FAFAFA;border:1.5px solid rgba(0,0,0,.1);border-radius:12px;padding:1.45rem 1.1rem .55rem;height:58px;font-size:.9rem;color:var(--text);font-family:var(--fb);outline:none;transition:border-color .2s,box-shadow .2s,background .2s;-webkit-appearance:none}
    .fl textarea{height:auto;min-height:110px;padding:1.45rem 1.1rem .75rem;resize:vertical}
    .fl label{position:absolute;left:1.1rem;top:50%;transform:translateY(-50%);font-size:.875rem;color:var(--muted);pointer-events:none;transition:top .18s ease,font-size .18s ease,color .18s ease;line-height:1}
    .fl textarea~label{top:1.5rem;transform:none}
    .fl input:focus,.fl select:focus,.fl textarea:focus{border-color:var(--red);background:#FFF;box-shadow:0 0 0 3px rgba(212,32,32,.09)}
    .fl input:focus~label,.fl input:not(:placeholder-shown)~label,.fl select:focus~label,.fl select.has-val~label{top:.55rem;transform:none;font-size:.6rem;letter-spacing:.06em;color:var(--red)}
    .fl textarea:focus~label{top:.55rem;font-size:.6rem;letter-spacing:.06em;color:var(--red)}
    .fl select option{background:#FFF;color:var(--text)}
    .full{grid-column:span 2}
    .req{color:var(--red);margin-left:.15rem}
    .submit-btn{width:100%;grid-column:span 2;background:var(--red);color:#FFF;border:none;border-radius:100px;padding:1.1rem 2rem;font-size:1rem;font-weight:400;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:var(--fb);margin-top:.5rem;letter-spacing:.02em;display:flex;align-items:center;justify-content:center;gap:.5rem}
    .submit-btn:hover{transform:scale(1.02);box-shadow:0 0 36px rgba(212,32,32,.4)}
    .submit-btn:disabled{opacity:.65;cursor:not-allowed;transform:none;box-shadow:none}
    .form-note{font-size:.75rem;color:var(--muted);text-align:center;margin-top:1rem;line-height:1.6;display:flex;align-items:center;justify-content:center;gap:.4rem}
    #form-error{color:var(--red);font-size:.8rem;padding:.4rem 0;grid-column:span 2;display:none}

    /* TRUST STRIP */
    .trust-strip{background:var(--bg-gray);border-top:1px solid rgba(0,0,0,.06)}
    .trust-inner{max-width:var(--max);margin:0 auto;padding:0 2rem;display:grid;grid-template-columns:repeat(4,1fr)}
    .trust-item{text-align:center;padding:2.5rem 1.5rem;position:relative}
    .trust-item+.trust-item::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);height:36px;width:1px;background:rgba(0,0,0,.08)}
    .trust-n{font-size:clamp(1.6rem,2.5vw,2.2rem);font-weight:300;color:var(--text);letter-spacing:-.04em;line-height:1;margin-bottom:.4rem}
    .trust-l{font-size:.72rem;color:var(--muted);letter-spacing:.04em}

    /* LOCATIONS */
    #locations{padding:8rem 0;background:#FFF}
    .loc-head{margin-bottom:4.5rem}
    .loc-head h2{font-size:clamp(2rem,3.5vw,2.8rem);font-weight:400;letter-spacing:-.03em;color:var(--text);margin-bottom:0}
    .loc-grid{display:grid;grid-template-columns:repeat(3,1fr)}
    .loc-card{padding:2.5rem;border-top:1px solid rgba(0,0,0,.08);transition:background .3s;position:relative}
    .loc-card:hover{background:var(--bg-gray)}
    .loc-card:not(:nth-child(3n)){border-right:1px solid rgba(0,0,0,.08)}
    .loc-hq-badge{font-size:.58rem;font-weight:400;letter-spacing:.12em;text-transform:uppercase;color:var(--red);background:var(--red-d);border:1px solid var(--red-b);border-radius:100px;padding:.2rem .65rem;display:inline-block;margin-bottom:1rem}
    .loc-flag{font-size:1.5rem;margin-bottom:.9rem;line-height:1}
    .loc-country{font-size:1.05rem;font-weight:400;color:var(--text);margin-bottom:.3rem;letter-spacing:-.01em}
    .loc-city{font-size:.8rem;color:var(--red);font-weight:400;margin-bottom:.85rem;letter-spacing:.02em}
    .loc-detail{font-size:.84rem;color:var(--muted);line-height:1.75}
    .loc-detail a{color:var(--red)}

    /* FAQ */
    #faq{padding:8rem 0;background:var(--bg-gray)}
    .faq-head{margin-bottom:4.5rem}
    .faq-head h2{font-size:clamp(2rem,3.5vw,2.8rem);font-weight:400;letter-spacing:-.03em;color:var(--text);margin-bottom:0}
    .faq-list{border-top:1px solid rgba(0,0,0,.08)}
    .faq-item{border-bottom:1px solid rgba(0,0,0,.08)}
    .faq-btn{width:100%;display:flex;align-items:center;justify-content:space-between;padding:1.75rem 0;background:none;border:none;font-family:var(--fb);font-size:1rem;font-weight:400;color:var(--text);cursor:pointer;gap:2rem;text-align:left;transition:color .2s}
    .faq-btn:hover{color:var(--red)}
    .faq-icon{width:28px;height:28px;border-radius:50%;border:1.5px solid rgba(0,0,0,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .25s,border-color .25s,transform .3s}
    .faq-icon svg{transition:transform .3s ease}
    .faq-item.open .faq-btn{color:var(--red)}
    .faq-item.open .faq-icon{background:var(--red);border-color:var(--red)}
    .faq-item.open .faq-icon svg{transform:rotate(45deg)}
    .faq-item.open .faq-icon path{stroke:#FFF}
    .faq-body{max-height:0;overflow:hidden;transition:max-height .4s cubic-bezier(.22,1,.36,1)}
    .faq-item.open .faq-body{max-height:300px}
    .faq-ans{padding:0 0 1.75rem;font-size:.9rem;color:var(--muted);line-height:1.85;max-width:780px}

    /* FOOTER */
    footer{background:#0A0A0A;border-top:1px solid rgba(255,255,255,.06);padding:4.5rem 0 2rem}
    .foot-g{display:grid;grid-template-columns:2fr 1fr 1fr 1.3fr;gap:3rem;margin-bottom:3.5rem}
    .foot-brand p{color:rgba(255,255,255,.35);font-size:.9rem;line-height:1.7;margin-top:1rem;max-width:280px}
    .foot-soc{display:flex;gap:.75rem;margin-top:1.5rem}
    .soc-a{width:36px;height:36px;border-radius:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;font-size:.75rem;transition:all .2s;color:rgba(255,255,255,.4)}
    .soc-a:hover{background:var(--red-d);border-color:var(--red-b);color:var(--red)}
    .foot-col h4{font-family:var(--fh);font-size:.78rem;font-weight:400;letter-spacing:.08em;text-transform:uppercase;margin-bottom:1.25rem;color:rgba(255,255,255,.9)}
    .foot-col a{display:block;color:rgba(255,255,255,.4);font-size:.875rem;margin-bottom:.6rem;transition:color .2s}
    .foot-col a:hover{color:#FFF}
    .foot-contact p{color:rgba(255,255,255,.4);font-size:.875rem;margin-bottom:.6rem;display:flex;align-items:center;gap:.45rem}
    .foot-contact a{color:var(--red);display:inline;margin-bottom:0}
    .foot-bot{border-top:1px solid rgba(255,255,255,.06);padding-top:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
    .foot-bot p{color:rgba(255,255,255,.25);font-size:.8rem}
    .foot-locs{display:flex;gap:.6rem;flex-wrap:wrap}
    .foot-locs span{font-size:.72rem;color:rgba(255,255,255,.3);background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:100px;padding:.2rem .7rem}

    /* RESPONSIVE */
    @media(max-width:1024px){
      .ch-inner{grid-template-columns:1fr;gap:3.5rem}
      .trust-inner{grid-template-columns:repeat(2,1fr)}
      .trust-item:nth-child(3)::before{display:none}
      .loc-grid{grid-template-columns:1fr 1fr}
      .loc-card:nth-child(2n){border-right:none}
      .loc-card:nth-child(3){border-right:none !important}
      .foot-g{grid-template-columns:1fr 1fr}
    }
    @media(max-width:768px){
      .contact-hero{padding:5rem 0 3rem}
      .ch-inner{padding:0 1.25rem;gap:2.5rem}
      .ch-left{padding-top:0}
      .ch-sub{font-size:.95rem;margin-bottom:1.75rem}
      .contact-tiles{grid-template-columns:1fr;gap:.6rem}
      .c-tile{padding:1rem 1.25rem}
      .form-card{border-radius:18px;padding:1.75rem 1.5rem}
      .fgrid{grid-template-columns:1fr;gap:.75rem}
      .full,.submit-btn,#form-error{grid-column:span 1}
      .fl input,.fl select{height:54px}
      .trust-inner{grid-template-columns:repeat(2,1fr)}
      .loc-grid{grid-template-columns:1fr}
      .loc-card{border-right:none !important}
      #locations{padding:5rem 0}
      #faq{padding:5rem 0}
      .faq-head{margin-bottom:3rem}
      .loc-head{margin-bottom:3rem}
      .foot-g{grid-template-columns:1fr}
    }
    @media(max-width:480px){
      .contact-hero{padding:4.5rem 0 2.5rem}
      .ch-inner{padding:0 1rem;gap:2rem}
      .ch-left h1{font-size:clamp(2.2rem,9vw,3rem)}
      .form-card{border-radius:14px;padding:1.5rem 1.25rem}
      .form-card-hd{margin-bottom:1.5rem}
      .trust-inner{grid-template-columns:1fr}
      .trust-item+.trust-item::before{display:none}
      .contact-tiles{gap:.5rem}
      .submit-btn{padding:.95rem 1.5rem;font-size:.925rem}
    }

    /* MEGA MENU */
    .nav-dd{position:static;display:flex;align-items:center}
    .nd-toggle{display:flex;align-items:center;gap:5px;cursor:pointer;color:rgba(255,255,255,.7);font-size:.875rem;font-weight:400;border:none;background:none;font-family:var(--fb);padding:0;transition:color .3s;position:relative;padding-bottom:2px}
    #nav.s .nd-toggle{color:var(--muted)}
    .nav-dd.open .nd-toggle,.nd-toggle:hover{color:#FFF}
    #nav.s .nav-dd.open .nd-toggle,#nav.s .nd-toggle:hover{color:var(--text)}
    .nd-chev{transition:transform .25s ease;flex-shrink:0}
    .nav-dd.open .nd-chev{transform:rotate(180deg)}
    .mega-wrap{position:absolute;top:calc(100% + 14px);left:50%;transform:translateX(-50%) translateY(-12px);width:min(1080px,calc(100vw - 2rem));background:#FFFFFF;border:1px solid rgba(0,0,0,.09);border-radius:20px;overflow:hidden;box-shadow:0 4px 6px rgba(0,0,0,.04),0 20px 50px rgba(0,0,0,.1);opacity:0;pointer-events:none;transition:opacity .22s ease,transform .22s cubic-bezier(.22,1,.36,1);z-index:400}
    .nav-dd.open .mega-wrap{opacity:1;pointer-events:auto;transform:translateX(-50%) translateY(0)}
    .mega-wrap::before{content:"";position:absolute;top:0;left:15%;right:15%;height:1px;background:linear-gradient(90deg,transparent,rgba(212,32,32,.8) 40%,rgba(212,32,32,.9) 50%,rgba(212,32,32,.8) 60%,transparent);z-index:2}
    .mega-bg{position:absolute;inset:0;background:transparent}
    .mega-head{display:flex;align-items:center;justify-content:space-between;padding:1.1rem 1.5rem .85rem;position:relative;z-index:1}
    .mega-eye{font-size:.6rem;font-weight:400;letter-spacing:.22em;text-transform:uppercase;color:rgba(0,0,0,.35)}
    .mega-all-link{font-size:.76rem;color:rgba(0,0,0,.4);transition:color .2s;display:flex;align-items:center;gap:.35rem}
    .mega-all-link:hover{color:rgba(0,0,0,.8)}
    .mega-divider{height:1px;background:rgba(0,0,0,.08)}
    .mega-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.4rem;padding:1rem;position:relative;z-index:1}
    .mc{display:flex;flex-direction:column;padding:1.3rem 1.2rem 1.4rem;border-radius:14px;text-decoration:none;position:relative;overflow:hidden;transition:background .2s}
    .mc::after{content:"";position:absolute;inset:0;border-radius:14px;border:1px solid transparent;transition:border-color .2s;pointer-events:none}
    .mc-img-w{height:160px;display:flex;align-items:flex-end;justify-content:center;margin-bottom:.9rem}
    .mc-img-w img{height:150px;width:auto;object-fit:contain;filter:drop-shadow(0 4px 14px rgba(0,0,0,.2));transition:transform .35s cubic-bezier(.22,1,.36,1),filter .35s ease}
    .mc:hover .mc-img-w img{transform:translateY(-8px) scale(1.06);filter:drop-shadow(0 10px 24px rgba(0,0,0,.28))}
    .mc-svg-w{height:120px;display:flex;align-items:center;justify-content:center;margin-bottom:.9rem;transition:transform .35s cubic-bezier(.22,1,.36,1)}
    .mc:hover .mc-svg-w{transform:translateY(-6px) scale(1.05)}
    .mc-badge{display:inline-block;font-size:.59rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;padding:.17rem .65rem;border-radius:100px;margin-bottom:.45rem;width:fit-content}
    .mc-name{font-size:.95rem;font-weight:400;color:#0A0A0F;letter-spacing:-.01em;margin-bottom:.3rem}
    .mc-desc{font-size:.71rem;color:rgba(0,0,0,.45);line-height:1.55;flex:1}
    .mc-link{display:inline-flex;align-items:center;gap:.3rem;margin-top:.7rem;font-size:.72rem;font-weight:400;opacity:0;transform:translateX(-5px);transition:opacity .18s,transform .18s}
    .mc:hover .mc-link{opacity:1;transform:none}
    .mc-vrt:hover{background:rgba(212,32,32,.05)}.mc-vrt:hover::after{border-color:rgba(212,32,32,.2)}.mc-vrt .mc-badge{background:rgba(212,32,32,.1);color:#EF5050;border:1px solid rgba(212,32,32,.22)}.mc-vrt .mc-link{color:#EF5050}
    .mc-plus:hover{background:rgba(184,134,11,.05)}.mc-plus:hover::after{border-color:rgba(146,64,14,.22)}.mc-plus .mc-badge{background:rgba(184,134,11,.1);color:#92400E;border:1px solid rgba(146,64,14,.25)}.mc-plus .mc-link{color:#92400E}
    .mc-art:hover{background:rgba(99,102,241,.05)}.mc-art:hover::after{border-color:rgba(67,56,202,.2)}.mc-art .mc-badge{background:rgba(99,102,241,.1);color:#4338CA;border:1px solid rgba(67,56,202,.22)}.mc-art .mc-link{color:#4338CA}
    .mc-home:hover{background:rgba(20,184,166,.05)}.mc-home:hover::after{border-color:rgba(15,118,110,.2)}.mc-home .mc-badge{background:rgba(20,184,166,.1);color:#0F766E;border:1px solid rgba(15,118,110,.22)}.mc-home .mc-link{color:#0F766E}
    .mc-vr:hover{background:rgba(37,99,235,.05)}.mc-vr:hover::after{border-color:rgba(37,99,235,.2)}.mc-vr .mc-badge{background:rgba(37,99,235,.1);color:#60A5FA;border:1px solid rgba(37,99,235,.22)}.mc-vr .mc-link{color:#60A5FA}
    .mega-foot{display:flex;align-items:center;gap:1.25rem;padding:.85rem 1.5rem;border-top:1px solid rgba(0,0,0,.08);position:relative;z-index:1}
    .mf-link{display:flex;align-items:center;gap:.45rem;font-size:.76rem;color:rgba(0,0,0,.45);transition:color .2s;text-decoration:none;white-space:nowrap}
    .mf-link:hover{color:rgba(0,0,0,.75)}
    .mf-sep{width:1px;height:14px;background:rgba(0,0,0,.1);flex-shrink:0}
