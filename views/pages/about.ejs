<script>
const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('on');obs.unobserve(e.target)}}),{threshold:.08});
document.querySelectorAll('.r').forEach(el=>obs.observe(el));
</script>
<script>
const nav=document.getElementById('nav');
const onScroll=()=>nav.classList.toggle('s',scrollY>40);
window.addEventListener('scroll',onScroll,{passive:true});
onScroll();
</script>
<script>
(function(){
  var dd=document.querySelector('.nav-dd'),btn=document.querySelector('.nd-toggle');
  if(!dd||!btn)return;
  btn.addEventListener('click',function(e){e.stopPropagation();dd.classList.toggle('open');});
  document.addEventListener('click',function(e){if(!dd.contains(e.target))dd.classList.remove('open');});
  document.addEventListener('keydown',function(e){if(e.key==='Escape')dd.classList.remove('open');});
})();
</script><script>
(function(){
  var pr=document.querySelector('.scroll-prog');
  var glow=document.querySelector('.hero-glow');
  var heroInner=document.querySelector('.ah-inner');
  var mImg=document.querySelector('.mission-img');
  var _r=null;
  function tick(){
    var y=window.scrollY;
    var total=document.documentElement.scrollHeight-window.innerHeight;
    pr.style.width=(total>0?y/total*100:0)+'%';
    if(glow)glow.style.transform='translateX(-50%) translateY('+(y*.28)+'px)';
    if(heroInner)heroInner.style.opacity=Math.max(0,1-y/450).toFixed(3);
    if(mImg){var r=mImg.getBoundingClientRect(),vp=window.innerHeight;if(r.top<vp&&r.bottom>0){var pct=(vp-r.top)/(vp+r.height);mImg.style.transform='translateY('+((pct*-40+20))+'px)';}}
    _r=null;
  }
  window.addEventListener('scroll',function(){if(!_r)_r=requestAnimationFrame(tick);},{passive:true});
  tick();
  function cnt(el,n,s){var t0=performance.now(),d=1500;requestAnimationFrame(function run(t){var p=Math.min((t-t0)/d,1),e=1-Math.pow(1-p,4);el.textContent=Math.round(n*e)+s;if(p<1)requestAnimationFrame(run);});}
  var cObs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){cnt(e.target,+e.target.dataset.n,e.target.dataset.s||'');cObs.unobserve(e.target);}});},{threshold:.7});
  document.querySelectorAll('[data-n]').forEach(function(el){cObs.observe(el);});
})();
</script><script src="popup.js?v=3"></script>
