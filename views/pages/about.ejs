<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/webp" href="images/Faveicon-black.webp">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>About SonicHive, Dubai's Acoustic Pod Pioneers</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#FFFFFF;--bg-gray:#F5F5F7;--bg-dark:#000000;--red:#D42020;--red-d:rgba(212,32,32,.07);--red-b:rgba(212,32,32,.22);--text:#1D1D1F;--muted:#6E6E73;--border:rgba(0,0,0,.08);--fh:'Poppins',sans-serif;--fb:'Poppins',sans-serif;--max:1280px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:var(--fb);-webkit-font-smoothing:antialiased;overflow-x:hidden}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .wrap{max-width:var(--max);margin:0 auto;padding:0 2rem}
    .r{opacity:0;transform:translateY(32px);transition:opacity .9s ease,transform .9s cubic-bezier(.22,1,.36,1)}
    .r.on{opacity:1;transform:none}
    .d1{transition-delay:.08s}.d2{transition-delay:.17s}.d3{transition-delay:.26s}.d4{transition-delay:.35s}
    .s-label{font-size:.65rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--red);margin-bottom:1rem;display:flex;align-items:center;gap:.5rem}
    .s-title{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:400;line-height:1.05;letter-spacing:-.025em;margin-bottom:1rem}


    /* HERO */
    .about-hero{background:#FFF;padding:9rem 0 0;position:relative;overflow:hidden}
    .hero-glow{position:absolute;top:-15%;left:55%;transform:translateX(-50%);width:1000px;height:800px;background:radial-gradient(ellipse,rgba(212,32,32,.13) 0%,transparent 60%);pointer-events:none}
    .ah-inner{max-width:var(--max);margin:0 auto;padding:0 2rem 6rem;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;position:relative}
    .hero-eyebrow{font-size:.62rem;font-weight:400;letter-spacing:.22em;text-transform:uppercase;color:var(--red);margin-bottom:2rem;display:flex;align-items:center;gap:.6rem}
    .hero-eyebrow::before{content:'';width:20px;height:1px;background:var(--red);flex-shrink:0}
    .ah-left h1{font-size:clamp(3.5rem,6.5vw,6rem);font-weight:400;letter-spacing:-.04em;line-height:.94;color:#1D1D1F;margin-bottom:2rem}
    .ah-left h1 em{color:var(--red);font-style:normal}
    .hero-sub{color:var(--muted);font-size:1.05rem;line-height:1.8;max-width:440px}
    .ah-right{position:relative}
    .about-img-stack{position:relative;height:500px}
    .aimg-main{position:absolute;top:0;right:0;width:88%;height:360px;border-radius:24px;overflow:hidden;box-shadow:0 40px 80px rgba(0,0,0,.65)}
    .aimg-main img{width:100%;height:100%;object-fit:cover;transition:transform .8s ease}
    .aimg-main:hover img{transform:scale(1.04)}
    .aimg-accent{position:absolute;bottom:0;left:0;width:50%;height:220px;border-radius:20px;overflow:hidden;border:3px solid rgba(0,0,0,.08);box-shadow:0 20px 50px rgba(0,0,0,.15)}
    .aimg-accent img{width:100%;height:100%;object-fit:cover}
    .aimg-badge{position:absolute;top:1.5rem;left:1.5rem;background:rgba(255,255,255,.92);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(0,0,0,.08);border-radius:14px;padding:.7rem 1rem;font-size:.78rem;font-weight:400;color:#1D1D1F;display:flex;align-items:center;gap:.5rem}

    /* STATS BAR */
    .hero-stats-bar{border-top:1px solid rgba(0,0,0,.08);padding:3.5rem 0}
    .hero-stats{max-width:var(--max);margin:0 auto;padding:0 2rem;display:grid;grid-template-columns:repeat(4,1fr)}
    .hero-stat{text-align:center;padding:0 2rem;position:relative}
    .hero-stat+.hero-stat::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);height:42px;width:1px;background:rgba(0,0,0,.08)}
    .hs-n{font-size:clamp(1.9rem,3vw,2.7rem);font-weight:300;color:#1D1D1F;letter-spacing:-.04em;line-height:1;margin-bottom:.5rem}
    .hs-l{font-size:.75rem;color:var(--muted);letter-spacing:.04em}

    /* MANIFESTO */
    #manifesto{padding:9rem 2rem;background:#FFF;text-align:center}
    .manifesto-inner{max-width:880px;margin:0 auto}
    .manifesto-label{font-size:.62rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--red);margin-bottom:2.5rem;display:flex;align-items:center;justify-content:center;gap:.65rem}
    .manifesto-label::before,.manifesto-label::after{content:'';width:28px;height:1px;background:var(--red);flex-shrink:0}
    .manifesto-quote{font-size:clamp(1.7rem,3.4vw,2.8rem);font-weight:400;letter-spacing:-.03em;line-height:1.3;color:#1D1D1F}
    .manifesto-quote em{color:var(--red);font-style:normal}

    /* MISSION */
    #mission{padding:8rem 0;background:var(--bg-gray)}
    .mission-wrap{max-width:var(--max);margin:0 auto;padding:0 2rem}
    .mission-lay{display:grid;grid-template-columns:1fr 1fr;gap:7rem;align-items:start}
    .mission-txt .s-label{margin-bottom:1.25rem}
    .mission-txt h2{font-family:var(--fh);font-size:clamp(2rem,3.5vw,2.8rem);font-weight:400;letter-spacing:-.03em;margin-bottom:1.5rem;line-height:1.1;color:#1D1D1F}
    .mission-txt>p{color:var(--muted);line-height:1.85;font-size:1rem;margin-bottom:1.25rem}
    .mission-pillars{margin-top:2.5rem;display:flex;flex-direction:column}
    .mpillar{display:flex;align-items:flex-start;gap:1.25rem;padding:1.5rem 0;border-top:1px solid rgba(0,0,0,.08)}
    .mpillar:last-child{border-bottom:1px solid rgba(0,0,0,.08)}
    .mp-ic{width:38px;height:38px;border-radius:10px;background:var(--red);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:.1rem;color:#FFF}
    .mpillar h3{font-size:.9rem;font-weight:400;margin-bottom:.3rem;color:#1D1D1F}
    .mpillar p{font-size:.84rem;color:var(--muted);line-height:1.65;margin:0}
    .mission-img-wrap{position:sticky;top:100px}
    .mission-img{border-radius:28px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.13)}
    .mission-img img{width:100%;height:540px;object-fit:cover;display:block;transition:transform .8s ease}
    .mission-img:hover img{transform:scale(1.03)}

    /* CLIENTS */
    #clients{padding:5.5rem 0;background:#FFF;border-top:1px solid rgba(0,0,0,.06);overflow:hidden}
    .clients-hd{text-align:center;margin-bottom:3rem;padding:0 2rem}
    .clients-hd p{font-size:.62rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:.65rem}
    .clients-hd h2{font-size:clamp(1.4rem,2.5vw,1.8rem);font-weight:400;letter-spacing:-.025em;color:#1D1D1F}
    .marquee-wrap{overflow:hidden;-webkit-mask-image:linear-gradient(to right,transparent,#000 12%,#000 88%,transparent);mask-image:linear-gradient(to right,transparent,#000 12%,#000 88%,transparent)}
    .marquee-track{display:flex;gap:1rem;width:max-content;animation:marquee 35s linear infinite;padding:0 .5rem}
    .marquee-track:hover{animation-play-state:paused}
    @keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .client-pill{background:#F5F5F7;border:1px solid rgba(0,0,0,.06);border-radius:14px;padding:1.25rem 2.5rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;min-width:160px;height:88px}
    .client-pill img{max-height:42px;max-width:150px;width:auto;height:auto;display:block;object-fit:contain;opacity:.75;filter:grayscale(1);transition:opacity .2s,filter .2s}
    .client-pill:hover img{opacity:1;filter:none}
    .client-pill.text-pill{font-size:.78rem;font-weight:500;color:var(--muted);letter-spacing:.05em;white-space:nowrap}

    /* VALUES */
    #values{padding:8rem 0;background:#FFF;border-top:1px solid rgba(0,0,0,.06)}
    .val-head{text-align:center;margin-bottom:5rem}
    .val-head .s-label{justify-content:center}
    .val-head h2{font-size:clamp(2rem,4vw,3rem);font-weight:400;letter-spacing:-.03em;color:#1D1D1F;margin-bottom:0}
    .val-grid{display:grid;grid-template-columns:repeat(3,1fr)}
    .val-card{padding:2.5rem;border-top:1px solid rgba(0,0,0,.08);transition:background .3s}
    .val-card:hover{background:var(--bg-gray)}
    .val-card:not(:nth-child(3n)){border-right:1px solid rgba(0,0,0,.08)}
    .val-num{font-family:var(--fh);font-size:3.5rem;font-weight:300;color:rgba(212,32,32,.16);line-height:1;margin-bottom:1.5rem;letter-spacing:-.05em}
    .val-name{font-size:1.05rem;font-weight:400;margin-bottom:.65rem;color:#1D1D1F;letter-spacing:-.01em}
    .val-desc{font-size:.875rem;color:var(--muted);line-height:1.75}

    /* JOURNEY */
    #journey{padding:8rem 0;background:var(--bg-gray);color:var(--text)}
    .journey-head{margin-bottom:5rem}
    .journey-head .s-label{color:var(--red)}
    .journey-head h2{font-size:clamp(2.2rem,4.5vw,3.5rem);font-weight:400;letter-spacing:-.04em;color:#1D1D1F;line-height:1;margin-bottom:0}
    .journey-inner{display:grid;grid-template-columns:1fr 1fr;gap:5rem}
    .timeline{position:relative;padding-left:1.25rem}
    .timeline::before{content:'';position:absolute;left:0;top:8px;bottom:0;width:1px;background:linear-gradient(to bottom,var(--red),rgba(212,32,32,.04))}
    .tl-item{position:relative;padding-left:2rem;padding-bottom:3rem}
    .tl-item:last-child{padding-bottom:0}
    .tl-dot{position:absolute;left:-1.25rem;top:7px;width:8px;height:8px;border-radius:50%;background:var(--red);transform:translateX(-50%)}
    .tl-year{font-size:.62rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--red);margin-bottom:.5rem}
    .tl-title{font-size:1.05rem;font-weight:400;color:#1D1D1F;margin-bottom:.45rem;letter-spacing:-.01em}
    .tl-desc{font-size:.875rem;color:var(--muted);line-height:1.7}
    .journey-imgs{display:flex;flex-direction:column;gap:1.25rem;align-self:start;position:sticky;top:100px}
    .journey-imgs img{width:100%;height:230px;object-fit:cover;border-radius:20px;display:block;transition:transform .5s ease}
    .journey-imgs img:hover{transform:scale(1.02)}

    /* CTA */
    #about-cta{padding:9rem 0;background:#FFF;text-align:center;position:relative;overflow:hidden}
    #about-cta::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:700px;height:500px;background:radial-gradient(ellipse,rgba(212,32,32,.06),transparent 70%);pointer-events:none}
    .acta-inner{position:relative;max-width:680px;margin:0 auto;padding:0 2rem}
    .acta-inner .s-label{justify-content:center;color:var(--red);margin-bottom:1.5rem}
    .acta-inner h2{font-size:clamp(2.5rem,5vw,4rem);font-weight:400;letter-spacing:-.04em;color:#1D1D1F;line-height:1;margin-bottom:1.5rem}
    .acta-inner>p{color:var(--muted);line-height:1.75;margin-bottom:3rem;font-size:1.05rem}
    .btn-row{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
    .btn-g{background:var(--red);color:#FFF;border:none;border-radius:100px;padding:.925rem 2.5rem;font-size:.975rem;font-weight:400;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:var(--fb);display:inline-block}
    .btn-g:hover{transform:scale(1.04);box-shadow:0 0 32px rgba(212,32,32,.45)}
    .btn-o{background:transparent;border:1px solid rgba(0,0,0,.18);color:var(--text);border-radius:100px;padding:.925rem 2.5rem;font-size:.975rem;font-weight:400;cursor:pointer;transition:all .2s;font-family:var(--fb);display:inline-block}
    .btn-o:hover{background:rgba(0,0,0,.05)}

    /* RESPONSIVE */
    @media(max-width:1024px){
      .ah-inner{grid-template-columns:1fr;gap:3rem}
      .hero-stats{grid-template-columns:repeat(2,1fr);gap:1.5rem}
      .hero-stat+.hero-stat:nth-child(3)::before{display:none}
      .mission-lay{grid-template-columns:1fr;gap:3rem}
      .mission-img-wrap{position:static}
      .journey-inner{grid-template-columns:1fr;gap:3rem}
      .journey-imgs{position:static;flex-direction:row}
      .journey-imgs img{height:180px;flex:1}
      .val-grid{grid-template-columns:1fr 1fr}
      .val-card:nth-child(2n){border-right:none}
      .val-card:nth-child(3){border-right:none !important}
    }
    @media(max-width:768px){
      #manifesto{padding:5rem 1.5rem}
      .about-hero{padding:6rem 0 0}
      .ah-inner{padding:0 1.25rem 3rem}
      .about-img-stack{height:300px}
      .aimg-main{height:250px}
      .aimg-accent{height:150px;width:48%}
      .hero-stats{grid-template-columns:repeat(2,1fr)}
      .val-grid{grid-template-columns:1fr}
      .val-card{border-right:none !important}
      .mission-img img{height:320px}
      .journey-imgs{flex-direction:column}
      .journey-imgs img{height:200px;flex:none}
    }
    @media(max-width:480px){
      .hero-stats{grid-template-columns:1fr 1fr;gap:1rem}
      .about-img-stack{height:230px}
      .aimg-main{height:190px}
      .aimg-accent{height:110px;width:44%}
    }

    
    .scroll-prog{position:fixed;top:0;left:0;height:2px;background:var(--red);z-index:1100;width:0;pointer-events:none;transition:width .08s linear}
    @media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important;animation-iteration-count:1!important}}
  </style>
</head>
<body>

<%- include('../partials/header', { page: 'about' }) %>
<div id="main-content" tabindex="-1" style="outline:none;position:absolute"></div>

<!-- HERO -->
<section class="about-hero">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="ah-inner">
    <div class="ah-left r">
      <p class="hero-eyebrow">Our Story</p>
      <h1>We Built <em>Silence</em><br>Into a Product.</h1>
      <p class="hero-sub">Born in Dubai. Engineered for the Middle East's most ambitious workspaces. SonicHive set out to solve the one problem that open-plan offices never cracked, giving people a place to think, speak, and meet without the noise of everyone around them.</p>
    </div>
    <div class="ah-right r d2">
      <div class="about-img-stack">
        <div class="aimg-main">
          <img src="/images/Pods/All%20Pods%20Image/VRT%20Large%20Office%20Pods.webp" alt="SonicHive office pods in use" loading="lazy" width="880" height="360">
        </div>
        <div class="aimg-accent">
          <img src="/images/Pods/All%20Pods%20Image/Dubai%20Sonichive%20Showroom.webp" alt="Dubai SonicHive Showroom" loading="lazy" width="440" height="220">
        </div>
        <div class="aimg-badge">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:15px;height:15px;flex-shrink:0" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
          Downtown Dubai Showroom
        </div>
      </div>
    </div>
  </div>
  <div class="hero-stats-bar">
    <div class="hero-stats r d2">
      <div class="hero-stat">
        <div class="hs-n" data-n="800" data-s="+">800+</div>
        <div class="hs-l">Pods Installed</div>
      </div>
      <div class="hero-stat">
        <div class="hs-n" data-n="300" data-s="+">300+</div>
        <div class="hs-l">Corporate Clients</div>
      </div>
      <div class="hero-stat">
        <div class="hs-n">30 ±5 dB</div>
        <div class="hs-l">Noise Reduction</div>
      </div>
      <div class="hero-stat">
        <div class="hs-n" data-n="5" data-s="">5</div>
        <div class="hs-l">Countries Served</div>
      </div>
    </div>
  </div>
</section>

<!-- MANIFESTO -->
<section id="manifesto">
  <div class="manifesto-inner r">
    <p class="manifesto-label">Our Belief</p>
    <p class="manifesto-quote">"Silence is not the absence of sound.<br>It's the presence of <em>focus.</em>"</p>
  </div>
</section>

<!-- MISSION -->
<section id="mission">
  <div class="mission-wrap">
    <div class="mission-lay">
      <div class="mission-txt r">
        <p class="s-label">Our Mission</p>
        <h2>The Noise Problem Deserves a Real Solution.</h2>
        <p>Open-plan offices transformed how people work together, but they created a new problem. With nowhere to focus, nowhere to speak privately, and nowhere to meet without disturbing everyone around you, productivity suffers.</p>
        <p>SonicHive was founded on a simple belief: acoustic privacy shouldn't require permanent construction, massive budgets, or sacrificing your office's design aesthetic. It should be modular, beautiful, and instant.</p>
        <div class="mission-pillars">
          <div class="mpillar">
            <div class="mp-ic" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:18px;height:18px"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.93 0-5.796-.232-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/></svg></div>
            <div><h3>Acoustic Lab Engineering</h3><p>Developed with backing from the largest acoustic testing lab in Asia, genuine, measurable noise reduction in every model.</p></div>
          </div>
          <div class="mpillar">
            <div class="mp-ic" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:18px;height:18px"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"/></svg></div>
            <div><h3>Built for the Middle East</h3><p>Engineered for Dubai's climate, aesthetic standards, and business culture, performing in the region's demanding environments.</p></div>
          </div>
          <div class="mpillar">
            <div class="mp-ic" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:18px;height:18px"><path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/></svg></div>
            <div><h3>Zero Construction Philosophy</h3><p>Fully modular and self-contained. No drilling, no contractors, no downtime.</p></div>
          </div>
          <div class="mpillar">
            <div class="mp-ic" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:18px;height:18px"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.678 48.678 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3-3 3"/></svg></div>
            <div><h3>Sustainability First</h3><p>Recycled acoustic panels and sustainable materials throughout manufacturing, without compromising performance.</p></div>
          </div>
        </div>
      </div>
      <div class="mission-img-wrap r d2">
        <div class="mission-img">
          <img src="/images/Pods/All%20Pods%20Image/office-vr-booth_1777100004941.webp" alt="SonicHive pod in a modern workspace" loading="lazy" width="820" height="540">
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CLIENTS -->
<section id="clients">
  <div class="clients-hd r">
    <p>Trusted by leading organisations across the Middle East</p>
