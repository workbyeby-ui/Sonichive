<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>About SonicHive — Dubai's Acoustic Pod Pioneers</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#FFFFFF;--bg-gray:#F5F5F7;--bg-dark:#000000;--red:#D42020;--red-d:rgba(212,32,32,.07);--red-b:rgba(212,32,32,.22);--text:#1D1D1F;--muted:#6E6E73;--border:rgba(0,0,0,.08);--fh:'Poppins',sans-serif;--fb:'Poppins',sans-serif;--max:1280px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:var(--fb);-webkit-font-smoothing:antialiased;overflow-x:hidden}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .wrap{max-width:var(--max);margin:0 auto;padding:0 2rem}
    .r{opacity:0;transform:translateY(32px);transition:opacity .9s ease,transform .9s cubic-bezier(.22,1,.36,1)}
    .r.on{opacity:1;transform:none}
    .d1{transition-delay:.08s}.d2{transition-delay:.17s}.d3{transition-delay:.26s}.d4{transition-delay:.35s}
    .s-label{font-size:.65rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--red);margin-bottom:1rem;display:flex;align-items:center;gap:.5rem}
    .s-title{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:400;line-height:1.05;letter-spacing:-.025em;margin-bottom:1rem}

    /* NAV — transparent dark over hero, becomes light on scroll */
    #nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:transparent;border-bottom:1px solid transparent;transition:background .4s,border-color .4s,box-shadow .4s}
    #nav.s{background:rgba(250,250,250,.96);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom-color:rgba(0,0,0,.09);box-shadow:0 1px 0 rgba(0,0,0,.06)}
    .nav-i{max-width:var(--max);margin:0 auto;padding:1.2rem 2rem;display:flex;align-items:center;justify-content:space-between;gap:2rem}
    .logo{display:flex;align-items:center;gap:10px}
    .logo-t{font-family:var(--fh);font-size:1.3rem;font-weight:400;letter-spacing:-.02em;color:#FFF;transition:color .4s}
    #nav.s .logo-t{color:var(--text)}
    .logo-t em{color:var(--red);font-style:normal}
    .nav-links{display:flex;gap:1.75rem;align-items:center}
    .nav-links a{font-size:.875rem;color:rgba(255,255,255,.7);font-weight:400;transition:color .3s;position:relative;padding-bottom:2px}
    #nav.s .nav-links a{color:var(--muted)}
    .nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--red);border-radius:1px;transition:width .25s ease}
    .nav-links a:hover{color:#FFF}
    #nav.s .nav-links a:hover{color:var(--text)}
    .nav-links a:hover::after,.nav-links a.cur::after{width:100%}
    .nav-cta{background:var(--red);color:#FFF;border:none;border-radius:100px;padding:.6rem 1.4rem;font-size:.875rem;font-weight:400;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:var(--fb);white-space:nowrap;display:inline-block}
    .nav-cta:hover{transform:scale(1.04);box-shadow:0 0 24px rgba(212,32,32,.4)}

    /* HERO */
    .about-hero{background:#000;padding:9rem 0 0;position:relative;overflow:hidden}
    .hero-glow{position:absolute;top:-15%;left:55%;transform:translateX(-50%);width:1000px;height:800px;background:radial-gradient(ellipse,rgba(212,32,32,.13) 0%,transparent 60%);pointer-events:none}
    .ah-inner{max-width:var(--max);margin:0 auto;padding:0 2rem 6rem;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;position:relative}
    .hero-eyebrow{font-size:.62rem;font-weight:400;letter-spacing:.22em;text-transform:uppercase;color:var(--red);margin-bottom:2rem;display:flex;align-items:center;gap:.6rem}
    .hero-eyebrow::before{content:'';width:20px;height:1px;background:var(--red);flex-shrink:0}
    .ah-left h1{font-size:clamp(3.5rem,6.5vw,6rem);font-weight:400;letter-spacing:-.04em;line-height:.94;color:#FFF;margin-bottom:2rem}
    .ah-left h1 em{color:var(--red);font-style:normal}
    .hero-sub{color:rgba(255,255,255,.44);font-size:1.05rem;line-height:1.8;max-width:440px}
    .ah-right{position:relative}
    .about-img-stack{position:relative;height:500px}
    .aimg-main{position:absolute;top:0;right:0;width:88%;height:360px;border-radius:24px;overflow:hidden;box-shadow:0 40px 80px rgba(0,0,0,.65)}
    .aimg-main img{width:100%;height:100%;object-fit:cover;transition:transform .8s ease}
    .aimg-main:hover img{transform:scale(1.04)}
    .aimg-accent{position:absolute;bottom:0;left:0;width:50%;height:220px;border-radius:20px;overflow:hidden;border:3px solid #000;box-shadow:0 20px 50px rgba(0,0,0,.55)}
    .aimg-accent img{width:100%;height:100%;object-fit:cover}
    .aimg-badge{position:absolute;top:1.5rem;left:1.5rem;background:rgba(0,0,0,.72);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:.7rem 1rem;font-size:.78rem;font-weight:400;color:#FFF;display:flex;align-items:center;gap:.5rem}

    /* STATS BAR */
    .hero-stats-bar{border-top:1px solid rgba(255,255,255,.07);padding:3.5rem 0}
    .hero-stats{max-width:var(--max);margin:0 auto;padding:0 2rem;display:grid;grid-template-columns:repeat(4,1fr)}
    .hero-stat{text-align:center;padding:0 2rem;position:relative}
    .hero-stat+.hero-stat::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);height:42px;width:1px;background:rgba(255,255,255,.08)}
    .hs-n{font-size:clamp(1.9rem,3vw,2.7rem);font-weight:300;color:#FFF;letter-spacing:-.04em;line-height:1;margin-bottom:.5rem}
    .hs-l{font-size:.75rem;color:rgba(255,255,255,.38);letter-spacing:.04em}

    /* MANIFESTO */
    #manifesto{padding:9rem 2rem;background:#FFF;text-align:center}
    .manifesto-inner{max-width:880px;margin:0 auto}
    .manifesto-label{font-size:.62rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--red);margin-bottom:2.5rem;display:flex;align-items:center;justify-content:center;gap:.65rem}
    .manifesto-label::before,.manifesto-label::after{content:'';width:28px;height:1px;background:var(--red);flex-shrink:0}
    .manifesto-quote{font-size:clamp(1.7rem,3.4vw,2.8rem);font-weight:400;letter-spacing:-.03em;line-height:1.3;color:#1D1D1F}
    .manifesto-quote em{color:var(--red);font-style:normal}

    /* MISSION */
    #mission{padding:8rem 0;background:var(--bg-gray)}
    .mission-wrap{max-width:var(--max);margin:0 auto;padding:0 2rem}
    .mission-lay{display:grid;grid-template-columns:1fr 1fr;gap:7rem;align-items:start}
    .mission-txt .s-label{margin-bottom:1.25rem}
    .mission-txt h2{font-family:var(--fh);font-size:clamp(2rem,3.5vw,2.8rem);font-weight:400;letter-spacing:-.03em;margin-bottom:1.5rem;line-height:1.1;color:#1D1D1F}
    .mission-txt>p{color:var(--muted);line-height:1.85;font-size:1rem;margin-bottom:1.25rem}
    .mission-pillars{margin-top:2.5rem;display:flex;flex-direction:column}
    .mpillar{display:flex;align-items:flex-start;gap:1.25rem;padding:1.5rem 0;border-top:1px solid rgba(0,0,0,.08)}
    .mpillar:last-child{border-bottom:1px solid rgba(0,0,0,.08)}
    .mp-ic{width:38px;height:38px;border-radius:10px;background:var(--red);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:.1rem;color:#FFF}
    .mpillar h3{font-size:.9rem;font-weight:400;margin-bottom:.3rem;color:#1D1D1F}
    .mpillar p{font-size:.84rem;color:var(--muted);line-height:1.65;margin:0}
    .mission-img-wrap{position:sticky;top:100px}
    .mission-img{border-radius:28px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.13)}
    .mission-img img{width:100%;height:540px;object-fit:cover;display:block;transition:transform .8s ease}
    .mission-img:hover img{transform:scale(1.03)}

    /* CLIENTS */
    #clients{padding:5.5rem 0;background:#FFF;border-top:1px solid rgba(0,0,0,.06);overflow:hidden}
    .clients-hd{text-align:center;margin-bottom:3rem;padding:0 2rem}
    .clients-hd p{font-size:.62rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:.65rem}
    .clients-hd h2{font-size:clamp(1.4rem,2.5vw,1.8rem);font-weight:400;letter-spacing:-.025em;color:#1D1D1F}
    .marquee-wrap{overflow:hidden;-webkit-mask-image:linear-gradient(to right,transparent,#000 12%,#000 88%,transparent);mask-image:linear-gradient(to right,transparent,#000 12%,#000 88%,transparent)}
    .marquee-track{display:flex;gap:1rem;width:max-content;animation:marquee 35s linear infinite;padding:0 .5rem}
    .marquee-track:hover{animation-play-state:paused}
    @keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .client-pill{background:var(--bg-gray);border-radius:100px;padding:.65rem 1.75rem;font-size:.84rem;font-weight:400;color:#1D1D1F;white-space:nowrap;flex-shrink:0;letter-spacing:.02em}

    /* VALUES */
    #values{padding:8rem 0;background:#FFF;border-top:1px solid rgba(0,0,0,.06)}
    .val-head{text-align:center;margin-bottom:5rem}
    .val-head .s-label{justify-content:center}
    .val-head h2{font-size:clamp(2rem,4vw,3rem);font-weight:400;letter-spacing:-.03em;color:#1D1D1F;margin-bottom:0}
    .val-grid{display:grid;grid-template-columns:repeat(3,1fr)}
    .val-card{padding:2.5rem;border-top:1px solid rgba(0,0,0,.08);transition:background .3s}
    .val-card:hover{background:var(--bg-gray)}
    .val-card:not(:nth-child(3n)){border-right:1px solid rgba(0,0,0,.08)}
    .val-num{font-family:var(--fh);font-size:3.5rem;font-weight:300;color:rgba(212,32,32,.16);line-height:1;margin-bottom:1.5rem;letter-spacing:-.05em}
    .val-name{font-size:1.05rem;font-weight:400;margin-bottom:.65rem;color:#1D1D1F;letter-spacing:-.01em}
    .val-desc{font-size:.875rem;color:var(--muted);line-height:1.75}

    /* JOURNEY */
    #journey{padding:8rem 0;background:#000;color:#FFF}
    .journey-head{margin-bottom:5rem}
    .journey-head .s-label{color:var(--red)}
    .journey-head h2{font-size:clamp(2.2rem,4.5vw,3.5rem);font-weight:400;letter-spacing:-.04em;color:#FFF;line-height:1;margin-bottom:0}
    .journey-inner{display:grid;grid-template-columns:1fr 1fr;gap:5rem}
    .timeline{position:relative;padding-left:1.25rem}
    .timeline::before{content:'';position:absolute;left:0;top:8px;bottom:0;width:1px;background:linear-gradient(to bottom,var(--red),rgba(212,32,32,.04))}
    .tl-item{position:relative;padding-left:2rem;padding-bottom:3rem}
    .tl-item:last-child{padding-bottom:0}
    .tl-dot{position:absolute;left:-1.25rem;top:7px;width:8px;height:8px;border-radius:50%;background:var(--red);transform:translateX(-50%)}
    .tl-year{font-size:.62rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--red);margin-bottom:.5rem}
    .tl-title{font-size:1.05rem;font-weight:400;color:#FFF;margin-bottom:.45rem;letter-spacing:-.01em}
    .tl-desc{font-size:.875rem;color:rgba(255,255,255,.38);line-height:1.7}
    .journey-imgs{display:flex;flex-direction:column;gap:1.25rem;align-self:start;position:sticky;top:100px}
    .journey-imgs img{width:100%;height:230px;object-fit:cover;border-radius:20px;display:block;transition:transform .5s ease}
    .journey-imgs img:hover{transform:scale(1.02)}

    /* CTA */
    #about-cta{padding:9rem 0;background:#000;text-align:center;position:relative;overflow:hidden}
    #about-cta::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:700px;height:500px;background:radial-gradient(ellipse,rgba(212,32,32,.1),transparent 70%);pointer-events:none}
    .acta-inner{position:relative;max-width:680px;margin:0 auto;padding:0 2rem}
    .acta-inner .s-label{justify-content:center;color:var(--red);margin-bottom:1.5rem}
    .acta-inner h2{font-size:clamp(2.5rem,5vw,4rem);font-weight:400;letter-spacing:-.04em;color:#FFF;line-height:1;margin-bottom:1.5rem}
    .acta-inner>p{color:rgba(255,255,255,.44);line-height:1.75;margin-bottom:3rem;font-size:1.05rem}
    .btn-row{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
    .btn-g{background:var(--red);color:#FFF;border:none;border-radius:100px;padding:.925rem 2.5rem;font-size:.975rem;font-weight:400;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:var(--fb);display:inline-block}
    .btn-g:hover{transform:scale(1.04);box-shadow:0 0 32px rgba(212,32,32,.45)}
    .btn-o{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.14);color:#FFF;border-radius:100px;padding:.925rem 2.5rem;font-size:.975rem;font-weight:400;cursor:pointer;transition:all .2s;font-family:var(--fb);display:inline-block}
    .btn-o:hover{background:rgba(255,255,255,.14)}

    /* FOOTER */
    footer{background:#0A0A0A;border-top:1px solid rgba(255,255,255,.06);padding:4.5rem 0 2rem}
    .foot-g{display:grid;grid-template-columns:2fr 1fr 1fr 1.3fr;gap:3rem;margin-bottom:3.5rem}
    .foot-brand p{color:rgba(255,255,255,.35);font-size:.9rem;line-height:1.7;margin-top:1rem;max-width:280px}
    .foot-soc{display:flex;gap:.75rem;margin-top:1.5rem}
    .soc-a{width:36px;height:36px;border-radius:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;font-size:.75rem;transition:all .2s;color:rgba(255,255,255,.4)}
    .soc-a:hover{background:var(--red-d);border-color:var(--red-b);color:var(--red)}
    .foot-col h4{font-family:var(--fh);font-size:.78rem;font-weight:400;letter-spacing:.08em;text-transform:uppercase;margin-bottom:1.25rem;color:rgba(255,255,255,.9)}
    .foot-col a{display:block;color:rgba(255,255,255,.4);font-size:.875rem;margin-bottom:.6rem;transition:color .2s}
    .foot-col a:hover{color:#FFF}
    .foot-contact p{color:rgba(255,255,255,.4);font-size:.875rem;margin-bottom:.6rem;display:flex;align-items:center;gap:.45rem}
    .foot-contact a{color:var(--red);display:inline;margin-bottom:0}
    .foot-bot{border-top:1px solid rgba(255,255,255,.06);padding-top:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
    .foot-bot p{color:rgba(255,255,255,.25);font-size:.8rem}
    .foot-locs{display:flex;gap:.6rem;flex-wrap:wrap}
    .foot-locs span{font-size:.72rem;color:rgba(255,255,255,.3);background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:100px;padding:.2rem .7rem}

    /* RESPONSIVE */
    @media(max-width:1024px){
      .ah-inner{grid-template-columns:1fr;gap:3rem}
      .hero-stats{grid-template-columns:repeat(2,1fr);gap:1.5rem}
      .hero-stat+.hero-stat:nth-child(3)::before{display:none}
      .mission-lay{grid-template-columns:1fr;gap:3rem}
      .mission-img-wrap{position:static}
      .journey-inner{grid-template-columns:1fr;gap:3rem}
      .journey-imgs{position:static;flex-direction:row}
      .journey-imgs img{height:180px;flex:1}
      .val-grid{grid-template-columns:1fr 1fr}
      .val-card:nth-child(2n){border-right:none}
      .val-card:nth-child(3){border-right:none !important}
      .foot-g{grid-template-columns:1fr 1fr}
    }
    @media(max-width:768px){
      .about-hero{padding:6rem 0 0}
      .ah-inner{padding:0 1.25rem 3rem}
      .about-img-stack{height:300px}
      .aimg-main{height:250px}
      .aimg-accent{height:150px;width:48%}
      .hero-stats{grid-template-columns:repeat(2,1fr)}
      .val-grid{grid-template-columns:1fr}
      .val-card{border-right:none !important}
      .mission-img img{height:320px}
      .journey-imgs{flex-direction:column}
      .journey-imgs img{height:200px;flex:none}
      .foot-g{grid-template-columns:1fr}
    }
    @media(max-width:480px){
      .hero-stats{grid-template-columns:1fr 1fr;gap:1rem}
      .about-img-stack{height:240px}
    }

    /* MEGA MENU */
    .nav-dd{position:static;display:flex;align-items:center}
    .nd-toggle{display:flex;align-items:center;gap:5px;cursor:pointer;color:rgba(255,255,255,.7);font-size:.875rem;font-weight:400;border:none;background:none;font-family:var(--fb);padding:0;transition:color .3s;position:relative;padding-bottom:2px}
    #nav.s .nd-toggle{color:var(--muted)}
    .nav-dd.open .nd-toggle,.nd-toggle:hover{color:#FFF}
    #nav.s .nav-dd.open .nd-toggle,#nav.s .nd-toggle:hover{color:var(--text)}
    .nd-chev{transition:transform .25s ease;flex-shrink:0}
    .nav-dd.open .nd-chev{transform:rotate(180deg)}
    .mega-wrap{position:absolute;top:calc(100% + 14px);left:50%;transform:translateX(-50%) translateY(-12px);width:min(1080px,calc(100vw - 2rem));background:#FFFFFF;border:1px solid rgba(0,0,0,.09);border-radius:20px;overflow:hidden;box-shadow:0 4px 6px rgba(0,0,0,.04),0 20px 50px rgba(0,0,0,.1);opacity:0;pointer-events:none;transition:opacity .22s ease,transform .22s cubic-bezier(.22,1,.36,1);z-index:400}
    .nav-dd.open .mega-wrap{opacity:1;pointer-events:auto;transform:translateX(-50%) translateY(0)}
    .mega-wrap::before{content:"";position:absolute;top:0;left:15%;right:15%;height:1px;background:linear-gradient(90deg,transparent,rgba(212,32,32,.8) 40%,rgba(212,32,32,.9) 50%,rgba(212,32,32,.8) 60%,transparent);z-index:2}
    .mega-bg{position:absolute;inset:0;background:transparent}
    .mega-head{display:flex;align-items:center;justify-content:space-between;padding:1.1rem 1.5rem .85rem;position:relative;z-index:1}
    .mega-eye{font-size:.6rem;font-weight:400;letter-spacing:.22em;text-transform:uppercase;color:rgba(0,0,0,.35)}
    .mega-all-link{font-size:.76rem;color:rgba(0,0,0,.4);transition:color .2s;display:flex;align-items:center;gap:.35rem}
    .mega-all-link:hover{color:rgba(0,0,0,.8)}
    .mega-divider{height:1px;background:rgba(0,0,0,.08)}
    .mega-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.4rem;padding:1rem;position:relative;z-index:1}
    .mc{display:flex;flex-direction:column;padding:1.3rem 1.2rem 1.4rem;border-radius:14px;text-decoration:none;position:relative;overflow:hidden;transition:background .2s}
    .mc::after{content:"";position:absolute;inset:0;border-radius:14px;border:1px solid transparent;transition:border-color .2s;pointer-events:none}
    .mc-img-w{height:160px;display:flex;align-items:flex-end;justify-content:center;margin-bottom:.9rem}
    .mc-img-w img{height:150px;width:auto;object-fit:contain;filter:drop-shadow(0 4px 14px rgba(0,0,0,.2));transition:transform .35s cubic-bezier(.22,1,.36,1),filter .35s ease}
    .mc:hover .mc-img-w img{transform:translateY(-8px) scale(1.06);filter:drop-shadow(0 10px 24px rgba(0,0,0,.28))}
    .mc-svg-w{height:120px;display:flex;align-items:center;justify-content:center;margin-bottom:.9rem;transition:transform .35s cubic-bezier(.22,1,.36,1)}
    .mc:hover .mc-svg-w{transform:translateY(-6px) scale(1.05)}
    .mc-badge{display:inline-block;font-size:.59rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;padding:.17rem .65rem;border-radius:100px;margin-bottom:.45rem;width:fit-content}
    .mc-name{font-size:.95rem;font-weight:400;color:#0A0A0F;letter-spacing:-.01em;margin-bottom:.3rem}
    .mc-desc{font-size:.71rem;color:rgba(0,0,0,.45);line-height:1.55;flex:1}
    .mc-link{display:inline-flex;align-items:center;gap:.3rem;margin-top:.7rem;font-size:.72rem;font-weight:400;opacity:0;transform:translateX(-5px);transition:opacity .18s,transform .18s}
    .mc:hover .mc-link{opacity:1;transform:none}
    .mc-vrt:hover{background:rgba(212,32,32,.05)}.mc-vrt:hover::after{border-color:rgba(212,32,32,.2)}.mc-vrt .mc-badge{background:rgba(212,32,32,.1);color:#EF5050;border:1px solid rgba(212,32,32,.22)}.mc-vrt .mc-link{color:#EF5050}
    .mc-plus:hover{background:rgba(184,134,11,.05)}.mc-plus:hover::after{border-color:rgba(146,64,14,.22)}.mc-plus .mc-badge{background:rgba(184,134,11,.1);color:#92400E;border:1px solid rgba(146,64,14,.25)}.mc-plus .mc-link{color:#92400E}
    .mc-art:hover{background:rgba(99,102,241,.05)}.mc-art:hover::after{border-color:rgba(67,56,202,.2)}.mc-art .mc-badge{background:rgba(99,102,241,.1);color:#4338CA;border:1px solid rgba(67,56,202,.22)}.mc-art .mc-link{color:#4338CA}
