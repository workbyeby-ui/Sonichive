<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ART Pod Series | SonicHive Designer Acoustic Pods | Dubai</title>
  <meta name="description" content="SonicHive ART Pod. where design meets silence. Architectural acoustic pods for premium workspaces. Solo, Duo, Quartet, Hexa. Dubai UAE.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#FAFAFA;--bg2:#F2F3F5;--bg3:#E8EAED;--red:#D42020;--red-d:rgba(212,32,32,.07);--red-b:rgba(212,32,32,.22);--text:#0A0A0F;--muted:#6B7280;--border:rgba(0,0,0,.09);--card:rgba(0,0,0,.03);--fh:'Poppins',sans-serif;--fb:'Poppins',sans-serif;--max:1280px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{word-spacing:0.15em;background:var(--bg);color:var(--text);font-family:var(--fb);-webkit-font-smoothing:antialiased;overflow-x:hidden}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .wrap{max-width:var(--max);margin:0 auto;padding:0 2rem}
    .r{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .75s cubic-bezier(.22,1,.36,1)}
    .r.on{opacity:1;transform:none}
    .d1{transition-delay:.08s}.d2{transition-delay:.18s}.d3{transition-delay:.28s}.d4{transition-delay:.38s}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

    /* NAV */
    #nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(250,250,250,.96);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
    .nav-i{max-width:var(--max);margin:0 auto;padding:1.2rem 2rem;display:flex;align-items:center;justify-content:space-between;gap:2rem}
    .logo{display:flex;align-items:center;gap:10px}
    .logo-t{font-family:var(--fh);font-size:1.3rem;font-weight:400;letter-spacing:-.02em}
    .logo-t em{color:var(--red);font-style:normal}
    .nav-links{display:flex;gap:1.75rem;align-items:center}
    .nav-links a{font-size:.875rem;color:var(--muted);font-weight:500;transition:color .2s}
    .nav-links a:hover,.nav-links a.cur{color:var(--text)}
    .nav-cta{background:var(--red);color:#FFF;border:none;border-radius:100px;padding:.6rem 1.4rem;font-size:.875rem;font-weight:400;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:var(--fb);white-space:nowrap;display:inline-block}
    .nav-cta:hover{transform:scale(1.04);box-shadow:0 0 24px rgba(212,32,32,.4)}
    /* MEGA MENU */
    .nav-dd{position:static;display:flex;align-items:center}
    .nd-toggle{display:flex;align-items:center;gap:5px;cursor:pointer;color:var(--muted);font-size:.875rem;font-weight:500;border:none;background:none;font-family:var(--fb);padding:0;transition:color .2s;position:relative;padding-bottom:2px}
    .nav-dd.open .nd-toggle,.nd-toggle:hover{color:var(--text)}
    .nd-chev{transition:transform .25s ease;flex-shrink:0}
    .nav-dd.open .nd-chev{transform:rotate(180deg)}
    .mega-wrap{position:absolute;top:calc(100% + 14px);left:50%;transform:translateX(-50%) translateY(-12px);width:min(1080px,calc(100vw - 2rem));background:#FFFFFF;border:1px solid rgba(0,0,0,.09);border-radius:20px;overflow:hidden;box-shadow:0 4px 6px rgba(0,0,0,.04),0 20px 50px rgba(0,0,0,.1);opacity:0;pointer-events:none;transition:opacity .22s ease,transform .22s cubic-bezier(.22,1,.36,1);z-index:400}
    .nav-dd.open .mega-wrap{opacity:1;pointer-events:auto;transform:translateX(-50%) translateY(0)}
    .mega-wrap::before{content:"";position:absolute;top:0;left:15%;right:15%;height:1px;background:linear-gradient(90deg,transparent,rgba(212,32,32,.8) 40%,rgba(212,32,32,.9) 50%,rgba(212,32,32,.8) 60%,transparent);z-index:2}
    .mega-bg{position:absolute;inset:0;background:transparent}
    .mega-head{display:flex;align-items:center;justify-content:space-between;padding:1.1rem 1.5rem .85rem;position:relative;z-index:1}
    .mega-eye{font-size:.6rem;font-weight:400;letter-spacing:.22em;text-transform:uppercase;color:rgba(0,0,0,.35)}
    .mega-all-link{font-size:.76rem;color:rgba(0,0,0,.4);transition:color .2s;display:flex;align-items:center;gap:.35rem}
    .mega-all-link:hover{color:rgba(0,0,0,.8)}
    .mega-divider{height:1px;background:rgba(0,0,0,.08)}
    .mega-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.4rem;padding:1rem;position:relative;z-index:1}
    .mc{display:flex;flex-direction:column;padding:1.3rem 1.2rem 1.4rem;border-radius:14px;text-decoration:none;position:relative;overflow:hidden;transition:background .2s}
    .mc::after{content:"";position:absolute;inset:0;border-radius:14px;border:1px solid transparent;transition:border-color .2s;pointer-events:none}
    .mc-img-w{height:160px;display:flex;align-items:flex-end;justify-content:center;margin-bottom:.9rem}
    .mc-img-w img{height:150px;width:auto;object-fit:contain;filter:drop-shadow(0 4px 14px rgba(0,0,0,.2));transition:transform .35s cubic-bezier(.22,1,.36,1),filter .35s ease}
    .mc:hover .mc-img-w img{transform:translateY(-8px) scale(1.06);filter:drop-shadow(0 10px 24px rgba(0,0,0,.28))}
    .mc-svg-w{height:120px;display:flex;align-items:center;justify-content:center;margin-bottom:.9rem;transition:transform .35s cubic-bezier(.22,1,.36,1)}
    .mc:hover .mc-svg-w{transform:translateY(-6px) scale(1.05)}
    .mc-badge{display:inline-block;font-size:.59rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;padding:.17rem .65rem;border-radius:100px;margin-bottom:.45rem;width:fit-content}
    .mc-name{font-size:.95rem;font-weight:400;color:#0A0A0F;letter-spacing:-.01em;margin-bottom:.3rem}
    .mc-desc{font-size:.71rem;color:rgba(0,0,0,.45);line-height:1.55;flex:1}
    .mc-link{display:inline-flex;align-items:center;gap:.3rem;margin-top:.7rem;font-size:.72rem;font-weight:400;opacity:0;transform:translateX(-5px);transition:opacity .18s,transform .18s}
    .mc:hover .mc-link{opacity:1;transform:none}
    .mc-vrt:hover{background:rgba(212,32,32,.05)}.mc-vrt:hover::after{border-color:rgba(212,32,32,.2)}.mc-vrt .mc-badge{background:rgba(212,32,32,.1);color:#EF5050;border:1px solid rgba(212,32,32,.22)}.mc-vrt .mc-link{color:#EF5050}
    .mc-plus:hover{background:rgba(184,134,11,.05)}.mc-plus:hover::after{border-color:rgba(184,134,11,.22)}.mc-plus .mc-badge{background:rgba(184,134,11,.1);color:#D4A020;border:1px solid rgba(184,134,11,.25)}.mc-plus .mc-link{color:#D4A020}
    .mc-art:hover{background:rgba(99,102,241,.05)}.mc-art:hover::after{border-color:rgba(99,102,241,.2)}.mc-art .mc-badge{background:rgba(99,102,241,.1);color:#A5B4FC;border:1px solid rgba(99,102,241,.22)}.mc-art .mc-link{color:#A5B4FC}
    .mc-home:hover{background:rgba(20,184,166,.05)}.mc-home:hover::after{border-color:rgba(20,184,166,.2)}.mc-home .mc-badge{background:rgba(20,184,166,.1);color:#2DD4BF;border:1px solid rgba(20,184,166,.22)}.mc-home .mc-link{color:#2DD4BF}
    .mega-foot{display:flex;align-items:center;gap:1.25rem;padding:.85rem 1.5rem;border-top:1px solid rgba(0,0,0,.08);position:relative;z-index:1}
    .mf-link{display:flex;align-items:center;gap:.45rem;font-size:.76rem;color:rgba(0,0,0,.45);transition:color .2s;text-decoration:none;white-space:nowrap}
    .mf-link:hover{color:rgba(0,0,0,.75)}
    .mf-sep{width:1px;height:14px;background:rgba(0,0,0,.1);flex-shrink:0}
    .mf-cta{color:rgba(212,32,32,.75)!important}.mf-cta:hover{color:#D42020!important}

    /* SERIES HERO, Dark editorial aesthetic */
    .series-hero{padding:8rem 2rem 5.5rem;background:linear-gradient(140deg,#07090F 0%,#0B0F14 50%,#0A0A14 100%);position:relative;overflow:hidden}
    .series-hero::before{content:'';position:absolute;top:-150px;right:-100px;width:700px;height:700px;background:radial-gradient(circle,rgba(90,60,140,.12),transparent 65%);pointer-events:none}
    .series-hero::after{content:'';position:absolute;bottom:-200px;left:-80px;width:500px;height:500px;background:radial-gradient(circle,rgba(212,32,32,.07),transparent 65%);pointer-events:none}
    .hero-in{max-width:var(--max);margin:0 auto;position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
    @media(max-width:768px){.hero-in{grid-template-columns:1fr}.series-hero{padding:5.5rem 1.25rem 3.5rem}.size-section{padding:3.5rem 0 4rem}.design-sec{padding:3.5rem 0}.cta-sec{padding:4rem 0}}
    .series-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:100px;padding:.35rem 1rem;font-size:.7rem;font-weight:400;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:1.5rem}
    .s-dot{width:6px;height:6px;border-radius:50%;background:#FFF;animation:blink 2s infinite;flex-shrink:0}
    .series-name{font-family:var(--fh);font-size:clamp(3rem,7.5vw,6.5rem);font-weight:400;letter-spacing:-.04em;color:#FFF;line-height:.92;margin-bottom:1.2rem}
    .series-name em{color:#FF6B6B;font-style:normal}
    .series-tagline{color:rgba(255,255,255,.62);font-size:1.08rem;line-height:1.75;max-width:440px;margin-bottom:2.5rem}
    .series-badges{display:flex;gap:1.5rem;flex-wrap:wrap}
    .s-badge{display:flex;align-items:center;gap:.5rem;color:rgba(255,255,255,.45);font-size:.82rem}
    .hero-visual{display:flex;flex-direction:column;gap:1rem}
    .hv-main{height:320px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:20px;display:flex;align-items:center;justify-content:center}
    .hv-ph{display:flex;flex-direction:column;align-items:center;gap:.75rem;color:rgba(255,255,255,.2)}
    .hv-ph span{font-size:.68rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase}
    .hv-tags{display:flex;gap:.65rem;flex-wrap:wrap}
    .hv-tag{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:100px;padding:.4rem .9rem;font-size:.72rem;color:rgba(255,255,255,.5)}

    /* SIZE SECTION */
    .size-section{padding:6rem 0 7rem}
    .sec-header{text-align:center;margin-bottom:4rem}
    .s-label{font-size:.72rem;font-weight:400;letter-spacing:.15em;text-transform:uppercase;color:var(--red);margin-bottom:.75rem;display:flex;align-items:center;justify-content:center;gap:.6rem}
    .s-label::before,.s-label::after{content:'';flex:1;max-width:40px;height:2px;background:var(--red);border-radius:2px}
    .s-title{font-family:var(--fh);font-size:clamp(2rem,3.5vw,2.75rem);font-weight:400;letter-spacing:-.025em;margin-bottom:.75rem}
    .s-sub{color:var(--muted);font-size:1rem;line-height:1.7}
    .size-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem}
    @media(max-width:768px){.size-grid{grid-template-columns:1fr}}
    .size-card{background:#FFF;border:1px solid var(--border);border-radius:24px;overflow:hidden;transition:border-color .25s,transform .3s,box-shadow .3s;display:flex;flex-direction:column}
    .size-card:hover{border-color:var(--red-b);transform:translateY(-6px);box-shadow:0 20px 50px rgba(0,0,0,.09)}
    .sc-img{height:200px;background:linear-gradient(135deg,#F0EFF8,var(--bg2));display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;border-bottom:1px solid var(--border)}
    .sc-ph{display:flex;flex-direction:column;align-items:center;gap:.65rem;color:var(--muted);opacity:.4}
    .sc-ph span{font-size:.68rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase}
    .sc-body{padding:1.5rem;flex:1;display:flex;flex-direction:column}
    .sc-cap{display:inline-flex;align-items:center;gap:.35rem;background:var(--red-d);border:1px solid var(--red-b);border-radius:100px;padding:.25rem .75rem;font-size:.68rem;font-weight:400;letter-spacing:.08em;text-transform:uppercase;color:var(--red);margin-bottom:.85rem;width:fit-content}
    .sc-name{font-family:var(--fh);font-size:1.45rem;font-weight:400;letter-spacing:-.02em;margin-bottom:.35rem}
    .sc-desc{font-size:.85rem;color:var(--muted);line-height:1.65;margin-bottom:1.25rem;flex:1}
    .sc-specs{display:flex;gap:0;margin-bottom:1.4rem;border:1px solid var(--border);border-radius:12px;overflow:hidden}
    .sc-spec{flex:1;text-align:center;padding:.65rem .5rem;border-right:1px solid var(--border)}
    .sc-spec:last-child{border-right:none}
    .sc-spec strong{font-family:var(--fh);font-size:1rem;font-weight:400;color:var(--text);display:block;line-height:1.1}
    .sc-spec span{font-size:.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-top:2px;display:block}
    .sc-cta{display:block;text-align:center;background:var(--bg2);border:1px solid var(--border);border-radius:100px;padding:.7rem 1.5rem;font-size:.85rem;font-weight:400;color:var(--text);transition:all .2s}
    .size-card:hover .sc-cta{background:var(--red);color:#FFF;border-color:var(--red)}

    /* DESIGN PHILOSOPHY */
    .design-sec{padding:5.5rem 0;background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
    .design-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:2rem}
    @media(max-width:768px){.design-grid{grid-template-columns:1fr}}
    .design-card{background:#FFF;border:1px solid var(--border);border-radius:20px;padding:2rem;position:relative;overflow:hidden}
    .design-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--red),#FF6B6B)}
    .dc-num{font-family:var(--fh);font-size:3rem;font-weight:400;color:var(--red-d);line-height:1;margin-bottom:.75rem;letter-spacing:-.04em}
    .dc-title{font-family:var(--fh);font-size:1.1rem;font-weight:400;margin-bottom:.5rem}
    .dc-desc{font-size:.85rem;color:var(--muted);line-height:1.65}

    /* VARIANT TABS */
    .variant-tabs{display:flex;gap:.4rem;background:var(--bg2);border:1px solid var(--border);border-radius:100px;padding:.3rem;width:fit-content;margin:0 auto 3rem}
    .vt-btn{border:none;background:none;cursor:pointer;padding:.6rem 1.75rem;border-radius:100px;font-size:.875rem;font-weight:400;font-family:var(--fb);color:var(--muted);transition:all .2s;white-space:nowrap}
    .vt-btn.active{background:#FFF;color:var(--text);box-shadow:0 2px 8px rgba(0,0,0,.1)}
    .vt-btn.plus.active{background:linear-gradient(135deg,#1a1a2e,#16213e);color:#FFF;box-shadow:0 2px 12px rgba(26,26,46,.35)}
    .vt-pane{display:none}.vt-pane.active{display:block}
    .plus-badge{background:linear-gradient(135deg,#667eea,#764ba2);color:#FFF;font-size:.58rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;padding:.14rem .5rem;border-radius:100px;vertical-align:middle;margin-left:.35rem}
    @media(max-width:480px){.variant-tabs{width:calc(100% - 0rem);justify-content:center}.vt-btn{padding:.55rem 1.1rem;font-size:.82rem}}
    /* COLOR OPTIONS */
    .colors-sec{padding:4rem 0;background:#FFF;border-top:1px solid var(--border)}
    .colors-grid{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;margin-top:2rem}
    .color-swatch{display:flex;flex-direction:column;align-items:center;gap:.65rem;cursor:pointer;transition:transform .2s}
    .color-swatch:hover{transform:translateY(-4px)}
    .color-img-w{width:80px;height:80px;border-radius:16px;overflow:hidden;border:2px solid var(--border);background:var(--bg2)}
    .color-img-w img{width:100%;height:100%;object-fit:cover}
    .color-lbl{font-size:.68rem;color:var(--muted);text-align:center;letter-spacing:.04em}
    @media(max-width:480px){.color-img-w{width:68px;height:68px;border-radius:12px}.color-lbl{font-size:.62rem}}
    /* CTA */
    .cta-sec{padding:6rem 0;text-align:center}
    .cta-title{font-family:var(--fh);font-size:clamp(2rem,3.5vw,2.8rem);font-weight:400;letter-spacing:-.03em;margin-bottom:1rem}
    .cta-sub{color:var(--muted);font-size:1rem;margin-bottom:2.5rem;max-width:440px;margin-left:auto;margin-right:auto;line-height:1.7}
    .cta-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
    .btn-red{background:var(--red);color:#FFF;border-radius:100px;padding:.9rem 2.5rem;font-size:.975rem;font-weight:400;display:inline-block;transition:transform .2s,box-shadow .2s;font-family:var(--fb)}
    .btn-red:hover{transform:scale(1.04);box-shadow:0 0 32px rgba(212,32,32,.45)}
    .btn-o{border:1px solid var(--border);color:var(--text);border-radius:100px;padding:.9rem 2.5rem;font-size:.975rem;font-weight:500;display:inline-block;transition:all .2s;font-family:var(--fb)}
    .btn-o:hover{border-color:var(--red-b);color:var(--red)}

    /* FOOTER */
    footer{background:var(--bg2);border-top:1px solid var(--border);padding:2rem 0}
    .foot-in{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem}
    .foot-logo{display:flex;align-items:center;gap:8px;font-family:var(--fh);font-weight:400;letter-spacing:-.02em;font-size:1.1rem}
    .foot-logo em{color:var(--red);font-style:normal}
    .foot-copy{font-size:.78rem;color:var(--muted)}
    .foot-links{display:flex;gap:1.5rem}
    .foot-links a{font-size:.78rem;color:var(--muted);transition:color .2s}
    .foot-links a:hover{color:var(--text)}
  </style>
<style id="mobile-nav-fix">
