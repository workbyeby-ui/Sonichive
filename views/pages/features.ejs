<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/webp" href="images/Faveicon-black.webp">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Features & Technology, SonicHive Acoustic Pods</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#FAFAFA;--bg2:#F2F3F5;--bg3:#E8EAED;--red:#D42020;--red-d:rgba(212,32,32,.07);--red-b:rgba(212,32,32,.22);--text:#0A0A0F;--muted:#6B7280;--border:rgba(0,0,0,.09);--card:rgba(0,0,0,.03);--fh:'Poppins',sans-serif;--fb:'Poppins',sans-serif;--max:1280px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:var(--fb);-webkit-font-smoothing:antialiased;overflow-x:hidden}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .wrap{max-width:var(--max);margin:0 auto;padding:0 2rem}
    .r{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease}
    .r.on{opacity:1;transform:none}
    .d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}
    .s-label{font-size:.72rem;font-weight:400;letter-spacing:.15em;text-transform:uppercase;color:var(--red);margin-bottom:.9rem}
    .s-title{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:400;line-height:1.05;letter-spacing:-.025em;margin-bottom:1rem}


    /* PAGE HERO */
    .page-hero{padding:9rem 2rem 6rem;background:var(--bg) url('images/features-hero-bg.webp') center/cover no-repeat;position:relative;overflow:hidden}
    .ph-inner{max-width:var(--max);margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center;position:relative}
    .ph-left{position:relative}
    .ph-label{display:flex;align-items:center;gap:.65rem;font-size:.72rem;font-weight:400;letter-spacing:.15em;text-transform:uppercase;color:var(--red);margin-bottom:1.5rem}
    .ph-label::before{content:'';width:22px;height:2px;background:var(--red);border-radius:2px;flex-shrink:0}
    .ph-left h1{font-family:var(--fh);font-size:clamp(2.6rem,4.5vw,4rem);font-weight:400;letter-spacing:-.04em;line-height:1.02;margin-bottom:1.1rem;color:var(--text)}
    .ph-left h1 em{color:var(--red);font-style:normal;display:block}
    .ph-hdivider{width:32px;height:3px;background:var(--text);border-radius:2px;margin-bottom:1.5rem;opacity:.25}
    .ph-left p{color:var(--muted);font-size:.975rem;line-height:1.85;max-width:400px}
    .ph-wave{position:absolute;bottom:-3.5rem;left:-1.5rem;pointer-events:none;opacity:.9}
    .ph-right{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .ph-stat{background:#FFF;border:1px solid var(--border);border-radius:20px;padding:1.75rem;transition:box-shadow .3s,border-color .3s}
    .ph-stat:hover{box-shadow:0 8px 32px rgba(0,0,0,.08);border-color:var(--red-b)}
    .ph-stat-icon{width:46px;height:46px;border-radius:50%;background:rgba(212,32,32,.08);display:flex;align-items:center;justify-content:center;color:var(--red);margin-bottom:1rem;flex-shrink:0}
    .ph-stat-n{font-family:var(--fh);font-size:2.6rem;font-weight:400;color:var(--red);line-height:1;margin-bottom:.4rem}
    .ph-stat-name{font-size:.95rem;font-weight:400;color:var(--text);margin-bottom:.55rem}
    .ph-stat-bar{width:22px;height:2px;background:var(--red);border-radius:2px;margin-bottom:.65rem}
    .ph-stat-l{font-size:.8rem;color:var(--muted);line-height:1.55}

    /* CORE FEATURES */
    #core{padding:7rem 0;background:var(--bg) url('images/features-hero-bg.webp') center/cover no-repeat}
    .core-head{text-align:center;margin-bottom:3.5rem}
    .core-label{display:flex;align-items:center;justify-content:center;gap:.75rem;font-size:.72rem;font-weight:400;letter-spacing:.15em;text-transform:uppercase;color:var(--red);margin-bottom:1.25rem}
    .core-label::before,.core-label::after{content:'';width:28px;height:2px;background:var(--red);border-radius:2px;flex-shrink:0}
    .core-head h2{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:400;letter-spacing:-.025em;line-height:1.05;margin-bottom:1rem}
    .core-head h2 em{color:var(--red);font-style:normal}
    .core-head p{color:var(--muted);font-size:1rem;line-height:1.75;max-width:500px;margin:0 auto}
    .core-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-top:0}
    .cf{background:rgba(255,255,255,.92);backdrop-filter:blur(8px);border-radius:20px;padding:2rem 1.75rem;display:flex;align-items:flex-start;gap:1.4rem;transition:box-shadow .3s,transform .3s;border:1px solid rgba(255,255,255,.8)}
    .cf:hover{box-shadow:0 14px 44px rgba(0,0,0,.1);transform:translateY(-4px)}
    .cf-icon-wrap{position:relative;flex-shrink:0;width:76px;height:76px;display:flex;align-items:center;justify-content:center}
    .cf-icon-circle{width:56px;height:56px;border-radius:50%;background:rgba(212,32,32,.09);display:flex;align-items:center;justify-content:center;color:var(--red);position:relative;z-index:1}
    .cf-body{flex:1;min-width:0}
    .cf-n{font-family:var(--fh);font-size:1rem;font-weight:400;margin-bottom:.45rem;color:var(--text)}
    .cf-bar{width:22px;height:2px;background:var(--red);border-radius:2px;margin-bottom:.65rem}
    .cf-d{font-size:.84rem;color:var(--muted);line-height:1.72}

    /* SCROLL ANIMATIONS - extra variants */
    .r-left{opacity:0;transform:translateX(-36px);transition:opacity .85s cubic-bezier(.22,1,.36,1),transform .85s cubic-bezier(.22,1,.36,1)}
    .r-right{opacity:0;transform:translateX(36px);transition:opacity .85s cubic-bezier(.22,1,.36,1),transform .85s cubic-bezier(.22,1,.36,1)}
    .r-scale{opacity:0;transform:scale(.94);transition:opacity .8s ease,transform .8s cubic-bezier(.22,1,.36,1)}
    .r-left.on,.r-right.on,.r-scale.on{opacity:1;transform:none}

    /* ACOUSTIC SCIENCE */
    #acoustic{background:#fff url('images/Site image 1.webp') calc(100% + 80px) center/auto 85% no-repeat;overflow:hidden;position:relative}
    .ac-wrap{max-width:var(--max);margin:0 auto;padding:8rem 2rem 0}
    .ac-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start;min-height:480px}
    .ac-eyebrow{font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--red);opacity:.75;margin-bottom:2rem}
    .ac-num{font-family:var(--fh);font-size:clamp(3rem,6vw,5rem);font-weight:300;line-height:.85;letter-spacing:-.04em;color:var(--text);margin-bottom:1.5rem}
    .ac-num em{color:var(--red);font-style:normal}
    .ac-subhead{font-family:var(--fh);font-size:clamp(1.3rem,2.5vw,1.9rem);font-weight:300;letter-spacing:-.02em;color:var(--muted);line-height:1.4;margin-bottom:2rem}
    .ac-body-text p{color:var(--muted);font-size:.93rem;line-height:1.9;margin-bottom:1rem}
    .ac-right{position:relative;padding-top:2rem}
    .ac-img{width:100%;height:560px;object-fit:cover;border-radius:20px 20px 0 0;display:block}
    .ac-badge{position:absolute;top:4rem;right:2rem;background:rgba(255,255,255,.92);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border:1px solid var(--border);border-radius:16px;padding:1.25rem 1.5rem;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,.1)}
    .ac-badge strong{font-family:var(--fh);font-size:2.25rem;font-weight:300;color:var(--red);display:block;line-height:1;letter-spacing:-.03em}
    .ac-badge span{font-size:.7rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase}
    .ac-strip{display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid var(--border);margin-top:5rem}
    .ac-strip-item{padding:2.5rem 2rem;border-right:1px solid var(--border);transition:background .25s}
    .ac-strip-item:last-child{border-right:none}
    .ac-strip-item:hover{background:rgba(0,0,0,.025)}
    .ac-strip-n{font-family:var(--fh);font-size:2rem;font-weight:300;color:var(--text);letter-spacing:-.03em;line-height:1;margin-bottom:.4rem}
    .ac-strip-l{font-size:.77rem;color:var(--muted);line-height:1.55}

    /* MATERIALS */
    #materials{padding:8rem 0;background:var(--bg)}
    .mat-head{text-align:center;margin-bottom:4rem}
    .mat-head .s-label{color:var(--red)}
    .mat-head .s-title{color:var(--text)}
    .mat-head p{color:var(--muted)}
    .mat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:24px;overflow:hidden}
    .mat-card{background:#FFF;padding:2.5rem 2rem;text-align:left;transition:background .3s,box-shadow .3s;position:relative;overflow:hidden}
    .mat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,rgba(212,32,32,.5),transparent);opacity:0;transition:opacity .3s}
    .mat-card:hover{background:var(--bg2)}
    .mat-card:hover::before{opacity:1}
    .mat-ic{width:52px;height:52px;border-radius:14px;background:rgba(212,32,32,.1);border:1px solid rgba(212,32,32,.18);display:flex;align-items:center;justify-content:center;color:var(--red);margin-bottom:1.75rem}
    .mat-n{font-family:var(--fh);font-size:.95rem;font-weight:400;color:var(--text);margin-bottom:.35rem}
    .mat-bar{width:18px;height:1.5px;background:var(--red);border-radius:2px;margin:.35rem 0 .8rem;opacity:.6}
    .mat-d{font-size:.83rem;color:var(--muted);line-height:1.75}

    /* INSTALLATION - Apple numbered flow */
    #installation{padding:8rem 0;background:#FAFAFA}
    .inst-hd{text-align:center;margin-bottom:5rem}
    .inst-hd h2{font-family:var(--fh);font-size:clamp(2rem,4vw,3.2rem);font-weight:300;letter-spacing:-.03em;line-height:1.05;color:var(--text);margin-bottom:.75rem}
    .inst-hd h2 em{color:var(--red);font-style:normal}
    .inst-hd p{color:var(--muted);font-size:1rem;line-height:1.75;max-width:460px;margin:0 auto}
    .inst-flow{display:grid;grid-template-columns:repeat(5,1fr);gap:0;position:relative;margin-bottom:4rem}
    .inst-flow::before{content:'';position:absolute;top:36px;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,rgba(212,32,32,.25) 20%,rgba(212,32,32,.25) 80%,transparent);z-index:0}
    .inst-item{text-align:center;padding:0 .75rem;position:relative;z-index:1}
    .inst-dot{width:72px;height:72px;border-radius:50%;background:#FFF;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-family:var(--fh);font-size:1.2rem;font-weight:300;color:var(--text);transition:background .3s,border-color .3s,color .3s;letter-spacing:-.02em;box-shadow:0 2px 12px rgba(0,0,0,.06)}
    .inst-item:hover .inst-dot{background:var(--red);border-color:var(--red);color:#FFF;box-shadow:0 4px 20px rgba(212,32,32,.3)}
    .inst-item h3{font-family:var(--fh);font-size:.85rem;font-weight:400;margin-bottom:.5rem;color:var(--text)}
    .inst-item p{font-size:.77rem;color:var(--muted);line-height:1.65}
    .inst-bottom{display:grid;grid-template-columns:1.1fr 1fr;gap:1.5rem;margin-top:1rem}
    .inst-img-big{border-radius:20px;overflow:hidden;position:relative}
    .inst-img-big img{width:100%;height:380px;object-fit:cover;display:block}
    .inst-img-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.35),transparent 50%)}
    .inst-img-caption{position:absolute;bottom:1.75rem;left:1.75rem;color:#FFF}
    .inst-img-caption strong{font-family:var(--fh);font-size:1.5rem;font-weight:300;letter-spacing:-.02em;display:block;line-height:1}
    .inst-img-caption span{font-size:.78rem;opacity:.6}
    .inst-note{background:#FFF;border:1px solid var(--border);border-radius:20px;padding:2.25rem;display:flex;flex-direction:column}
    .inst-note-head{display:flex;align-items:center;gap:.65rem;margin-bottom:1.25rem}
    .inst-note-head svg{color:var(--red);flex-shrink:0}
    .inst-note h4{font-family:var(--fh);font-size:1.05rem;font-weight:300;letter-spacing:-.015em;margin:0;color:var(--text)}
    .inst-note p{font-size:.875rem;color:var(--muted);line-height:1.8;flex:1;margin-bottom:1.5rem}
    .inst-tags{display:flex;flex-wrap:wrap;gap:.5rem}
    .inst-tag{font-size:.72rem;color:var(--muted);background:var(--bg2);border:1px solid var(--border);border-radius:100px;padding:.3rem .9rem}

    /* TECH SPECS */
    #specs{padding:8rem 0;background:var(--bg2)}
    .spec-head{text-align:center;margin-bottom:3.5rem}
    .spec-head .s-label{color:var(--red)}
    .spec-head .s-title{color:var(--text)}
    .spec-wrap{border-radius:20px;overflow:hidden;border:1px solid var(--border)}
    .spec-table{width:100%;border-collapse:collapse}
    .spec-table th{background:var(--bg3);padding:1.2rem 1.5rem;text-align:left;font-family:var(--fh);font-size:.75rem;font-weight:400;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border)}
    .spec-table td{padding:1.1rem 1.5rem;border-bottom:1px solid var(--border);font-size:.88rem;color:var(--muted);background:#FFF;vertical-align:middle}
    .spec-table tr:last-child td{border-bottom:none}
    .spec-table tr:hover td{background:var(--bg2);color:var(--text)}
    .spec-table .feat-name{font-weight:400;color:var(--text)}
    .spec-chk{display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;background:rgba(212,32,32,.12);border-radius:50%;color:var(--red)}
    .spec-dash{display:inline-block;width:16px;height:1.5px;background:rgba(0,0,0,.15);border-radius:2px;vertical-align:middle}
    @media(max-width:640px){
      .spec-wrap{border-radius:12px}
      .spec-table thead{display:none}
      .spec-table,.spec-table tbody{display:block;width:100%}
      .spec-table tbody tr{display:block;border-bottom:1px solid var(--border)}
      .spec-table tbody tr:last-child{border-bottom:none}
      .spec-table td{display:flex;align-items:center;justify-content:space-between;padding:.7rem 1rem;font-size:.82rem;border-bottom:1px solid rgba(0,0,0,.05)}
      .spec-table td:last-child{border-bottom:none}
      .spec-table td.feat-name{background:var(--bg3);font-size:.72rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--muted);justify-content:flex-start;padding:.6rem 1rem;border-bottom:1px solid var(--border)}
      .spec-table td.feat-name::before{display:none}
      .spec-table td::before{content:attr(data-label);font-size:.68rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);opacity:.6;flex-shrink:0;margin-right:.75rem}
    }

    /* CTA */
    #feat-cta{padding:10rem 0;background:linear-gradient(135deg,#fff5f5 0%,var(--bg2) 60%,#fff0f0 100%);position:relative;overflow:hidden}
    #feat-cta::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(212,32,32,.08),transparent 65%);pointer-events:none}
    #feat-cta::after{content:'';position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,transparent,transparent 79px,rgba(0,0,0,.025) 79px,rgba(0,0,0,.025) 80px),repeating-linear-gradient(90deg,transparent,transparent 79px,rgba(0,0,0,.025) 79px,rgba(0,0,0,.025) 80px);pointer-events:none}
    .fcta-in{position:relative;text-align:center;max-width:680px;margin:0 auto;z-index:1}
    .fcta-eyebrow{font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--red);margin-bottom:1.75rem}
    .fcta-in h2{font-family:var(--fh);font-size:clamp(2.5rem,5vw,4rem);font-weight:300;letter-spacing:-.035em;color:var(--text);margin-bottom:1.25rem;line-height:1.05}
    .fcta-in p{color:var(--muted);line-height:1.8;margin-bottom:2.75rem;font-size:.975rem}
    .btn-red{background:var(--red);color:#FFF;border:none;border-radius:100px;padding:.875rem 2.25rem;font-size:.95rem;font-weight:400;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:var(--fb);display:inline-block}
    .btn-red:hover{transform:scale(1.04);box-shadow:0 0 28px rgba(212,32,32,.45)}
    .btn-wh{background:#FFF;border:1px solid var(--border);color:var(--text);border-radius:100px;padding:.875rem 2.25rem;font-size:.95rem;font-weight:400;cursor:pointer;transition:all .2s;font-family:var(--fb);display:inline-block}
    .btn-wh:hover{background:var(--bg2);border-color:rgba(0,0,0,.15)}
    .btn-row{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}

    @media(max-width:1024px){.ph-inner{grid-template-columns:1fr;gap:3rem}.ph-wave{display:none}.ac-grid{grid-template-columns:1fr;gap:3rem}.ac-right{padding-top:0}.ac-img{height:360px;border-radius:16px}.ac-strip{grid-template-columns:repeat(2,1fr)}.ac-strip-item:nth-child(2){border-right:none}.inst-flow{grid-template-columns:repeat(3,1fr)}.inst-flow::before{display:none}.inst-bottom{grid-template-columns:1fr}.inst-img-big img{height:280px}.core-grid{grid-template-columns:1fr 1fr}.mat-grid{grid-template-columns:1fr 1fr;border-radius:16px}}
    @media(max-width:768px){.core-grid{grid-template-columns:1fr}.mat-grid{grid-template-columns:1fr 1fr}.page-hero{padding:6rem 1.25rem 3.5rem}.ph-right{grid-template-columns:1fr}.ph-inner{gap:2rem}.inst-flow{grid-template-columns:repeat(2,1fr)}.ac-num{font-size:clamp(4rem,15vw,7rem)}.ac-strip{grid-template-columns:repeat(2,1fr)}.ac-wrap{padding:5rem 1.25rem 0}#acoustic{background-image:none}#materials,#installation,#specs,#feat-cta,#core{padding:5rem 0}}
    @media(max-width:480px){.mat-grid{grid-template-columns:1fr}.ph-left h1{font-size:clamp(2rem,7vw,3rem)}.ph-stat-n{font-size:1.75rem}.inst-flow{grid-template-columns:1fr 1fr}.ac-strip{grid-template-columns:1fr 1fr}.core-grid{grid-template-columns:1fr}}
    
  @media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important;animation-iteration-count:1!important}}
    </style>
</head>
<body>

<%- include('../partials/header', { page: 'features' }) %>
<div id="main-content" tabindex="-1" style="outline:none;position:absolute"></div>

<!-- PAGE HERO -->
<div class="page-hero">
  <div class="ph-inner">
    <div class="ph-left r">
      <div class="ph-label">Features & Technology</div>
      <h1>Acoustic Science.<em>Workspace Design.</em></h1>
      <div class="ph-hdivider"></div>
      <p>Every SonicHive pod is engineered to deliver genuine, measurable acoustic performance, backed by Asia's largest acoustic testing lab and built for the demands of the modern Middle East workspace.</p>
      <!-- Decorative wave -->
      <svg class="ph-wave" width="360" height="170" viewBox="0 0 360 170" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M-10,155 C30,120 70,165 110,130 C150,95 190,155 230,118 C265,85 295,130 340,105" stroke="rgba(212,32,32,0.18)" stroke-width="1.2" fill="none"/>
        <path d="M-10,145 C30,110 70,155 110,120 C150,85 190,145 230,108 C265,75 295,120 340,95" stroke="rgba(212,32,32,0.15)" stroke-width="1.2" fill="none"/>
        <path d="M-10,135 C30,100 70,145 110,110 C150,75 190,135 230,98 C265,65 295,110 340,85" stroke="rgba(212,32,32,0.13)" stroke-width="1.1" fill="none"/>
        <path d="M-10,125 C30,90 70,135 110,100 C150,65 190,125 230,88 C265,55 295,100 340,75" stroke="rgba(212,32,32,0.11)" stroke-width="1.1" fill="none"/>
        <path d="M-10,115 C30,80 70,125 110,90 C150,55 190,115 230,78 C265,45 295,90 340,65" stroke="rgba(212,32,32,0.09)" stroke-width="1" fill="none"/>
        <path d="M-10,105 C30,70 70,115 110,80 C150,45 190,105 230,68 C265,35 295,80 340,55" stroke="rgba(212,32,32,0.07)" stroke-width="1" fill="none"/>
        <path d="M-10,165 C30,130 70,175 110,140 C150,105 190,165 230,128 C265,95 295,140 340,115" stroke="rgba(212,32,32,0.2)" stroke-width="1.3" fill="none"/>
        <path d="M-10,95 C30,60 70,105 110,70 C150,35 190,95 230,58 C265,25 295,70 340,45" stroke="rgba(212,32,32,0.06)" stroke-width="1" fill="none"/>
        <path d="M-10,85 C30,50 70,95 110,60 C150,25 190,85 230,48 C265,15 295,60 340,35" stroke="rgba(212,32,32,0.04)" stroke-width="0.9" fill="none"/>
        <!-- Dot accents -->
        <circle cx="50" cy="148" r="2" fill="rgba(212,32,32,0.25)"/>
        <circle cx="130" cy="118" r="1.5" fill="rgba(212,32,32,0.2)"/>
