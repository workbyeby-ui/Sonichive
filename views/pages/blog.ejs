<script>
const obs = new IntersectionObserver(es => es.forEach(e => { if(e.isIntersecting) e.target.classList.add('on') }), {threshold:.1});
document.querySelectorAll('.r').forEach(el => obs.observe(el));

(function(){
  var nav = document.getElementById('nav');
  function update(){ nav.classList.toggle('s', window.scrollY > 80); }
  window.addEventListener('scroll', update, {passive:true});
  update();
})();

document.querySelectorAll('.bh-cat').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.bh-cat').forEach(b => b.classList.remove('act'));
    btn.classList.add('act');
  });
});
</script>
