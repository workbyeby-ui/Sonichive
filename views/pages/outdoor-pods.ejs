<script>
const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('on');obs.unobserve(e.target)}}),{threshold:.08});
document.querySelectorAll('.r').forEach(el=>obs.observe(el));
</script>

<!-- Product image gallery -->
<script>
(function(){
  var pimg=document.getElementById('pimg');
  if(!pimg)return;
  var thumbs=document.querySelectorAll('#pthumbs .ph-thumb');
  var swatches=document.querySelectorAll('.ph-swatches .sw');

  function applyImg(src){
    pimg.classList.add('fade');
    setTimeout(function(){pimg.src=src;pimg.classList.remove('fade');},220);
  }

  thumbs.forEach(function(btn){
    btn.addEventListener('click',function(){
      thumbs.forEach(function(t){t.classList.remove('act');});
      btn.classList.add('act');
      applyImg(btn.dataset.src);
    });
  });

  swatches.forEach(function(sw){
    sw.addEventListener('click',function(){
      swatches.forEach(function(s){s.classList.remove('act');});
      sw.classList.add('act');
    });
  });
})();
</script>

