<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/webp" href="images/Faveicon-black.webp">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Outdoor Pods, SonicHive | Backyard Silence Booth Dubai</title>
  <meta name="description" content="SonicHive Backyard Silence Booths — weather-resistant, air-conditioned soundproof pods for outdoor use. Backyards, terraces, courtyards and public spaces. SRPW-L, XL and XXL models.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"></noscript>
  <style>
    :root{--bg:#FAFAFA;--bg2:#F2F3F5;--bg3:#E8EAED;--red:#D42020;--red-d:rgba(212,32,32,.07);--red-b:rgba(212,32,32,.22);--text:#0A0A0F;--muted:#6B7280;--border:rgba(0,0,0,.09);--card:rgba(0,0,0,.03);--fh:'Poppins',sans-serif;--fb:'Poppins',sans-serif;--max:1280px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth;overflow-x:hidden}
    body{background:var(--bg);color:var(--text);font-family:var(--fb);-webkit-font-smoothing:antialiased;overflow-x:hidden}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .wrap{max-width:var(--max);margin:0 auto;padding:0 2rem}
    .r{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease}
    .r.on{opacity:1;transform:none}
    .d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}
    .s-label{font-size:.72rem;font-weight:400;letter-spacing:.15em;text-transform:uppercase;color:var(--red);margin-bottom:.9rem}
    .s-title{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:400;line-height:1.05;letter-spacing:-.025em;margin-bottom:1rem}

    /* ── HERO ── */
    #prod-hero{background:#FFF;min-height:92vh;display:flex;align-items:center;position:relative;overflow:hidden;padding:8rem 2rem 5rem}
    #prod-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 65% 50%,rgba(212,32,32,.05),transparent 60%)}
    .ph-grid{max-width:var(--max);margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center;position:relative;width:100%}
    .ph-img-wrap{display:flex;flex-direction:column;gap:1rem}
    .ph-main-wrap{position:relative;border-radius:20px;background:var(--bg2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;overflow:hidden;min-height:360px}
    .ph-img-glow{position:absolute;inset:0;background:radial-gradient(circle,rgba(212,32,32,.06),transparent 65%);pointer-events:none;z-index:0}
    .ph-img{width:82%;object-fit:contain;padding:1.5rem 1rem;transition:opacity .3s,transform .4s;position:relative;z-index:1}
    .ph-img.fade{opacity:0;transform:scale(.96)}
    .ph-img:hover{transform:scale(1.04) translateY(-5px)}
    .ph-thumbs{display:flex;gap:.55rem;overflow-x:auto;scrollbar-width:none;-ms-overflow-style:none}
    .ph-thumbs::-webkit-scrollbar{display:none}
    .ph-thumb{flex-shrink:0;width:72px;height:72px;border-radius:12px;border:2px solid var(--border);background:#FFF;cursor:pointer;transition:border-color .2s,transform .15s;padding:3px;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
    .ph-thumb img{width:100%;height:100%;object-fit:contain;transition:transform .3s}
    .ph-thumb:hover{border-color:var(--red-b);transform:translateY(-2px)}
    .ph-thumb:hover img{transform:scale(1.06)}
    .ph-thumb.act{border-color:var(--red);box-shadow:0 0 0 3px var(--red-d)}
    .ph-tlabel{position:absolute;bottom:0;left:0;right:0;font-size:.48rem;font-weight:400;text-align:center;background:rgba(0,0,0,.55);color:#FFF;padding:.2rem 0;letter-spacing:.06em;text-transform:uppercase;pointer-events:none}
    .ph-color-bar{display:flex;align-items:center;gap:.8rem;flex-wrap:wrap;padding:.65rem 1rem;background:#FFF;border:1px solid var(--border);border-radius:12px}
    .ph-clabel{font-size:.78rem;color:var(--muted);white-space:nowrap;flex-shrink:0}
    .ph-clabel b{color:var(--text)}
    .ph-swatches{display:flex;gap:.45rem;align-items:center;flex-wrap:wrap}
    .sw{width:24px;height:24px;border-radius:50%;cursor:pointer;transition:transform .18s,box-shadow .18s;border:2px solid rgba(0,0,0,.1);flex-shrink:0;outline:none;display:flex;align-items:center;justify-content:center}
    .sw:hover{transform:scale(1.22)}
    .sw.act{box-shadow:0 0 0 2px #FFF,0 0 0 4px var(--red);transform:scale(1.12)}
    .ph-info .breadcrumb{font-size:.75rem;color:var(--muted);margin-bottom:1.5rem;display:flex;align-items:center;gap:.5rem}
    .ph-info .breadcrumb a{color:var(--muted);transition:color .2s}
    .ph-info .breadcrumb a:hover{color:var(--red)}
    .ph-tag{display:inline-flex;align-items:center;gap:.5rem;background:var(--red-d);border:1px solid var(--red-b);border-radius:100px;padding:.35rem 1rem;font-size:.72rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;color:var(--red);margin-bottom:1.5rem}
    .ph-name{font-family:var(--fh);font-size:clamp(2.5rem,5vw,4.5rem);font-weight:400;letter-spacing:-.04em;color:var(--text);line-height:.95;margin-bottom:.75rem}
    .ph-cap{color:var(--red);font-size:1.1rem;font-weight:400;margin-bottom:1.25rem}
    .ph-desc{color:var(--muted);font-size:1rem;line-height:1.8;max-width:480px;margin-bottom:2.5rem}
    .ph-specs-row{display:flex;gap:2rem;flex-wrap:wrap;margin-bottom:2.5rem}
    .ph-spec{text-align:center}
    .ph-spec strong{font-family:var(--fh);font-size:1.6rem;font-weight:400;color:var(--text);display:block;line-height:1}
    .ph-spec span{font-size:.72rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-top:.2rem;display:block}
    .ph-actions{display:flex;gap:1rem;flex-wrap:wrap}
    .btn-red{background:var(--red);color:#FFF;border:none;border-radius:100px;padding:.9rem 2.5rem;font-size:.975rem;font-weight:400;cursor:pointer;transition:transform .2s,box-shadow .2s;font-family:var(--fb);display:inline-block}
    .btn-red:hover{transform:scale(1.04);box-shadow:0 0 32px rgba(212,32,32,.45)}
    .btn-wh{background:transparent;border:1px solid rgba(0,0,0,.15);color:var(--text);border-radius:100px;padding:.9rem 2.5rem;font-size:.975rem;font-weight:500;transition:all .2s;font-family:var(--fb);display:inline-block}
    .btn-wh:hover{background:var(--bg2);border-color:rgba(0,0,0,.25)}
    .btn-o{background:transparent;border:1px solid var(--border);color:var(--text);border-radius:100px;padding:.875rem 2.25rem;font-size:.95rem;font-weight:500;cursor:pointer;transition:all .2s;font-family:var(--fb);display:inline-block}
    .btn-o:hover{border-color:var(--red-b);color:var(--red)}

    /* ── MODEL SELECTOR ── */
    #model-selector{padding:4rem 0 0;background:#FFF}
    .ms-tabs{display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap;margin-bottom:3rem}
    .ms-tab{background:var(--bg2);border:1px solid var(--border);border-radius:100px;padding:.6rem 1.5rem;font-size:.875rem;font-weight:400;cursor:pointer;transition:all .2s;font-family:var(--fb);color:var(--muted)}
    .ms-tab.act{background:var(--red);border-color:var(--red);color:#FFF}
    .ms-tab:hover:not(.act){border-color:var(--red-b);color:var(--red)}
    .ms-panel{display:none}
    .ms-panel.act{display:block}

    /* ── BADGES ── */
    #badges{background:#111;border-top:1px solid rgba(255,255,255,.06);border-bottom:1px solid rgba(255,255,255,.06);padding:2rem 0}
    .badges-row{display:flex;gap:3rem;align-items:center;justify-content:center;flex-wrap:wrap}
    .badge-item{display:flex;align-items:center;gap:.75rem;color:rgba(255,255,255,.5);font-size:.875rem}
    .badge-item strong{color:#FFF;font-weight:400}
    .badge-ic{width:36px;height:36px;border-radius:10px;background:var(--red-d);border:1px solid var(--red-b);display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}

    /* ── FEATURES ── */
    #features{padding:7rem 0;background:#FFF}
    .feat-head{text-align:center;margin-bottom:4.5rem}
    .feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.75rem}
    .feat-card{background:#FFF;border:1px solid var(--border);border-radius:20px;overflow:hidden;display:flex;flex-direction:column;transition:transform .35s cubic-bezier(.22,1,.36,1),box-shadow .35s}
    .feat-card:hover{transform:translateY(-7px);box-shadow:0 24px 56px rgba(0,0,0,.11)}
    .feat-card-img{height:230px;overflow:hidden;background:var(--bg2);flex-shrink:0}
    .feat-card-img img{width:100%;height:100%;object-fit:cover;transition:transform .55s ease}
    .feat-card:hover .feat-card-img img{transform:scale(1.06)}
    .feat-card-body{padding:1.6rem;flex:1;display:flex;flex-direction:column;border-top:1px solid var(--border)}
    .feat-num{font-size:.68rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:#16A34A;background:rgba(22,163,74,.08);border:1px solid rgba(22,163,74,.22);border-radius:100px;padding:.22rem .75rem;display:inline-block;margin-bottom:1rem;align-self:flex-start}
    .feat-name{font-family:var(--fh);font-size:1rem;font-weight:500;margin-bottom:.55rem;color:var(--text);letter-spacing:-.015em;line-height:1.3}
    .feat-desc{font-size:.875rem;color:var(--muted);line-height:1.75;flex:1}

    /* ── PERFECT FOR ── */
    #perfect-for{padding:7rem 0;background:var(--bg2)}
    .pf-lay{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
    .pf-txt h2{font-family:var(--fh);font-size:clamp(2rem,3.5vw,2.8rem);font-weight:400;letter-spacing:-.025em;margin-bottom:1.25rem;line-height:1.05}
    .pf-txt p{color:var(--muted);line-height:1.85;font-size:.975rem;margin-bottom:1.5rem}
    .pf-list{display:flex;flex-direction:column;gap:.85rem;margin-top:1rem}
    .pf-item{display:flex;align-items:flex-start;gap:1rem;background:#FFF;border:1px solid var(--border);border-radius:12px;padding:1rem 1.25rem;transition:border-color .2s}
    .pf-item:hover{border-color:var(--red-b)}
    .pf-item-ic{font-size:1.3rem;flex-shrink:0;margin-top:.05rem}
    .pf-item h4{font-family:var(--fh);font-size:.9rem;font-weight:400;margin-bottom:.2rem}
    .pf-item p{font-size:.825rem;color:var(--muted);line-height:1.55}
    .pf-img-wrap{border-radius:24px;overflow:hidden;position:relative}
    .pf-img-wrap img{width:100%;height:480px;object-fit:cover;transition:transform .5s}
    .pf-img-wrap:hover img{transform:scale(1.03)}

    /* ── SPECS ── */
    #specs{padding:7rem 0}
    .spec-inner{max-width:var(--max);margin:0 auto}
    .spec-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
    .spec-col{background:#FFF;border:1px solid var(--border);border-radius:20px;overflow:hidden;display:flex;flex-direction:column;transition:box-shadow .3s,transform .3s}
    .spec-col:hover{transform:translateY(-4px);box-shadow:0 20px 48px rgba(0,0,0,.09)}
    .sc-img{background:var(--bg2);display:flex;align-items:center;justify-content:center;padding:2rem 1.5rem;min-height:200px;border-bottom:1px solid var(--border)}
    .sc-img img{max-height:180px;width:auto;object-fit:contain;transition:transform .4s cubic-bezier(.34,1.56,.64,1)}
    .spec-col:hover .sc-img img{transform:scale(1.06) translateY(-6px)}
    .sc-head{padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);background:var(--bg2)}
    .sc-model{font-family:var(--fh);font-size:1rem;font-weight:600;color:var(--text);letter-spacing:-.01em}
    .sc-pax{display:inline-flex;align-items:center;gap:.4rem;font-size:.72rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;color:var(--red);background:var(--red-d);border:1px solid var(--red-b);border-radius:100px;padding:.2rem .7rem;margin-top:.4rem}
    .sc-table{width:100%;border-collapse:collapse;flex:1}
    .sc-table td{padding:.75rem 1.25rem;border-bottom:1px solid var(--border);font-size:.82rem;vertical-align:top;line-height:1.45}
    .sc-table tr:last-child td{border-bottom:none}
    .sc-table tr:hover td{background:var(--bg2)}
    .sc-table .sn{color:var(--muted);width:48%}
    .sc-table .sv{color:var(--text);font-weight:400}
    .sc-table .chk{color:var(--red);font-weight:400}
    @media(max-width:1024px){.spec-grid{grid-template-columns:1fr 1fr}}
    @media(max-width:640px){.spec-grid{grid-template-columns:1fr}}

    /* ── TESTIMONIAL ── */
    #testimonial{padding:7rem 0;background:#0A0A0A;position:relative;overflow:hidden}
    #testimonial::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(212,32,32,.08),transparent 65%)}
    .testi-in{position:relative;max-width:760px;margin:0 auto;text-align:center}
    .testi-stars{color:var(--red);font-size:1.1rem;letter-spacing:4px;margin-bottom:2rem}
    .testi-q{font-family:var(--fh);font-size:clamp(1.25rem,2.5vw,1.75rem);font-weight:400;color:#FFF;line-height:1.5;font-style:italic;margin-bottom:2rem}
    .testi-name{font-size:.9rem;font-weight:400;color:rgba(255,255,255,.6)}
    .testi-loc{font-size:.8rem;color:rgba(255,255,255,.35);margin-top:.2rem}

    /* ── RELATED ── */
    #related{padding:7rem 0;background:var(--bg2)}
    .related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
    .rel-card{background:#FFF;border:1px solid var(--border);border-radius:20px;padding:2rem;cursor:pointer;transition:transform .3s,border-color .3s,box-shadow .3s;display:flex;flex-direction:column}
    .rel-card:hover{transform:translateY(-6px);border-color:var(--red-b);box-shadow:0 20px 50px rgba(0,0,0,.1)}
    .rel-tag{font-size:.7rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;color:var(--red);background:var(--red-d);border-radius:100px;padding:.25rem .75rem;display:inline-block;margin-bottom:1rem;align-self:flex-start}
    .rel-img{height:160px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem}
    .rel-img img{height:100%;width:auto;object-fit:contain;filter:drop-shadow(0 10px 24px rgba(0,0,0,.12));transition:transform .4s}
    .rel-card:hover .rel-img img{transform:scale(1.06) translateY(-4px)}
    .rel-name{font-family:var(--fh);font-size:1rem;font-weight:400;margin-bottom:.3rem}
    .rel-cap{font-size:.78rem;color:var(--red);font-weight:400;margin-bottom:.6rem}
    .rel-desc{font-size:.85rem;color:var(--muted);line-height:1.6;flex:1}
    .rel-link{margin-top:1.25rem;font-size:.82rem;font-weight:400;color:var(--text);display:inline-flex;align-items:center;gap:.4rem;transition:gap .2s,color .2s}
    .rel-link:hover{color:var(--red);gap:.75rem}

    /* ── CTA ── */
    #prod-cta{padding:7rem 0}
    .pcta-in{text-align:center;max-width:680px;margin:0 auto}
    .pcta-in h2{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:400;letter-spacing:-.025em;margin-bottom:1rem}
    .pcta-in p{color:var(--muted);line-height:1.75;margin-bottom:2.5rem;font-size:1.05rem}
    .btn-row{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}

    /* ── RESPONSIVE ── */
    @media(max-width:1024px){.ph-grid{grid-template-columns:1fr;gap:3rem;text-align:center}.ph-main-wrap{min-height:260px}.ph-specs-row{justify-content:center}.ph-actions{justify-content:center}.ph-desc{margin:0 auto 2.5rem}.pf-lay{grid-template-columns:1fr;gap:3rem}.related-grid{grid-template-columns:1fr 1fr}}
    @media(max-width:768px){.feat-grid{grid-template-columns:1fr 1fr}.feat-card-img{height:180px}.related-grid{grid-template-columns:1fr}.badges-row{gap:1.5rem}#prod-hero{padding:5.5rem 1.25rem 3rem}.ph-grid{gap:2rem}.ph-name{font-size:clamp(2rem,7vw,3.5rem)}.ph-actions{flex-direction:column;gap:.75rem}.btn-red,.btn-wh{text-align:center;width:100%}.pf-lay{gap:2rem}.pf-img-wrap img{height:280px}#features,#perfect-for,#specs,#testimonial,#related,#prod-cta{padding:4.5rem 0}.feat-head{margin-bottom:2.5rem}.ms-tabs{gap:.5rem}}
    @media(max-width:520px){.feat-grid{grid-template-columns:1fr}.feat-card-img{height:200px}.ph-specs-row{gap:1rem}.badges-row{justify-content:flex-start}.badge-item{width:calc(50% - .75rem)}}
    @media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important;animation-iteration-count:1!important}}
  </style>
</head>
<body>

<%- include('../partials/header', { page: 'outdoor-pods' }) %>
<div id="main-content" tabindex="-1" style="outline:none;position:absolute"></div>

<!-- ══════════ HERO ══════════ -->
<section id="prod-hero">
  <div class="ph-grid">
    <div class="ph-img-wrap r">
      <div class="ph-main-wrap">
        <div class="ph-img-glow"></div>
        <img id="pimg" class="ph-img" src="images/Pods/OutDoor%20Pods/Outdoor%20pod%20-%20L.webp" alt="Outdoor Backyard Silence Booth — 4 Pax">
      </div>
      <div class="ph-thumbs" id="pthumbs">
        <button class="ph-thumb act" data-src="images/Pods/OutDoor%20Pods/Outdoor%20pod%20-%20L.webp"><img src="images/Pods/OutDoor%20Pods/Outdoor%20pod%20-%20L.webp" alt="SRPW-L 4 Pax"><span class="ph-tlabel">4 Pax — L</span></button>
        <button class="ph-thumb" data-src="images/Pods/OutDoor%20Pods/Outdoor%20Pod%20XL.webp"><img src="images/Pods/OutDoor%20Pods/Outdoor%20Pod%20XL.webp" alt="SRPW-XL 6 Pax"><span class="ph-tlabel">6 Pax — XL</span></button>
        <button class="ph-thumb" data-src="images/Pods/OutDoor%20Pods/Outdoor%20Pod%20XXL.webp"><img src="images/Pods/OutDoor%20Pods/Outdoor%20Pod%20XXL.webp" alt="SRPW-XXL 8 Pax"><span class="ph-tlabel">8 Pax — XXL</span></button>
      </div>
      <div class="ph-color-bar">
        <span class="ph-clabel">Available finishes:</span>
        <div class="ph-swatches">
          <button class="sw act" style="background:#F5F5F5" title="White (S115)"></button>
          <button class="sw" style="background:#9E9E9E" title="Silver Grey (S235)"></button>
          <button class="sw" style="background:#D96E2A" title="Orange (S369)"></button>
          <button class="sw" style="background:#444444" title="Dark Grey (S201)"></button>
          <button class="sw" style="background:#1A1A1A" title="Black (S211)"></button>
        </div>
        <span style="font-size:.72rem;color:var(--muted)">5 standard colours</span>
      </div>
    </div>

    <div class="ph-info r d2">
      <div class="breadcrumb">
        <a href="/">Home</a> /
        <a href="/vr">Products</a> /
        Outdoor Pods
      </div>
      <div class="ph-tag">Outdoor · Weatherproof · Air Conditioned</div>
      <h1 class="ph-name">Backyard<br>Silence Booth</h1>
      <div class="ph-cap">Purpose-built for outdoor environments. No compromises.</div>
      <p class="ph-desc">Weather-resistant, air-conditioned soundproof pods engineered for outdoor use — backyards, terraces, commercial courtyards, and public spaces. 15+ years major in acoustic treatment. Available in 3 sizes: 4, 6, and 8 persons.</p>
      <div class="ph-specs-row">
        <div class="ph-spec"><strong>30–35 dB</strong><span>Sound Insulation</span></div>
        <div class="ph-spec"><strong>3 Sizes</strong><span>4 · 6 · 8 Pax</span></div>
        <div class="ph-spec"><strong>5</strong><span>Colours</span></div>
        <div class="ph-spec"><strong>E0</strong><span>Certified</span></div>
      </div>
      <div class="ph-actions">
        <a href="contact.html" class="btn-red">Get a Quote &#x2192;</a>
        <a href="https://wa.me/971585550099?text=Hi, I'm interested in the Outdoor Backyard Silence Booth." target="_blank" class="btn-wh">Chat on WhatsApp</a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════ BADGES ══════════ -->
<div id="badges">
  <div class="wrap">
    <div class="badges-row">
      <div class="badge-item">
        <div class="badge-ic"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:20px;height:20px"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 .906-7.38 5.25 5.25 0 0 0-10.233-2.33 3 3 0 0 0-4.047 3.51 4.5 4.5 0 0 0-.376 1.7Z"/></svg></div>
        <div><strong>Grade III</strong> Waterproof</div>
